.bill_history_center_bill .invoice-title h2, .invoice-title h3 {
    display: inline-block;
}

.bill_history_center_bill .table > tbody > tr > .no-line {
    border-top: none;
}

.bill_history_center_bill .table > thead > tr > .no-line {
    border-bottom: none;
}

.bill_history_center_bill .table > tbody > tr > .thick-line {
    border-top: 2px solid;
}
.bill_history_center_bill .panel-body{padding: 0;/*max-height: 320px;*//*height: 90vh;overflow: auto;max-height: 48vh;*/overflow: visible;}
.bill_history_center_bill .panel-default{border: 0}
.bill_history_center_bill .panel-default td{border-top: 1px dashed #cecece  !important;text-align: left;vertical-align: middle}
.bill_history_center_bill .pay_change_button{position: static;text-align: center}
.bill_history_center_bill .panel-default .table > tbody > tr > .thick-line{border: 0}
.bill_history_center_bill .text-center{text-align: center !important}
.bill_history_center_bill .text-right{text-align: RIGHT !important}
.bill_history_center_bill .panel-body strong{font-size: 14px;}
.bill_histo_gram{font-size: 13px;color: #EB6769}
.item_table_scr{
	width: 100%;
    /*min-height: 150px;*/
    overflow: auto;
    max-height: 23vh;
}
.table-condensed{margin-bottom: 0}
.bill_his_order_btm_detail{
    width: 100%;
    height: auto;
    float: left;
    text-align: left;
   
}
.item_table_scr td{border: #fff solid;padding: 2px 0 !important;}
.bill_history_tax_btm_cc{
     width: 95%;
    height: auto;
    float: left;
    text-align: left;
     position: absolute;
    bottom: 55px;
}