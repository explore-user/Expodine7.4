    margin-top: 9px;
}*/

.backto_table_select {
    width:158px;
    height: 30px;
    float: right;
    margin-top: 2px;
    margin-right: 3px;
    background-color: #B31700;
    -moz-border-radius-topleft: 12px;
    -moz-border-radius-topright: 5px;
    -moz-border-radius-bottomleft: 15px;
    -moz-border-radius-bottomright: 5px;
    -webkit-border-top-left-radius: 10px;
    -webkit-border-top-right-radius: 5px;
    -webkit-border-bottom-left-radius: 15px;
    -webkit-border-bottom-right-radius: 5px;
    border-top-left-radius: 12px;
    border-top-right-radius: 5px;
    border-bottom-left-radius: 15px;
    border-bottom-right-radius: 5px;
    transition: all 0.2s ease;
	}
.backto_table_select:hover{background-color:#D2922A}	
.backtable_ico {
    width: 28px;
    height: 28px;
    background-position: center;
    float: left;
    background-image: url("../img/back_icon.png");
}
.tableselect_text {
    width: 172px;
    height: 30px;
    float: left;
    text-align: center;
    padding-left: 5px;
    line-height: 28px;
    color: #fff;
    font-size: 15px;
   font-family: 'CALIBRI_0';
}

.kot_his_order_detail_head{
	width: 100%;
    height: 25px;
    float: left;
    background-color: rgba(0, 0, 0, 0.3);
    font-size: 14px;
	}	
.kot_his_order_detail_head table th{height:27px;font-family: 'CALIBRIB_0';}	
.pay_change_button{
    width: 100px;
    height: 32px;
    position: absolute;
    right: 3px;
    top: 2px;
    color: #fff;
    background-color: #AD8C43;
    border-radius: 5px;
    line-height: 32px;
    font-size: 14px;
    cursor: pointer;
	}
.pay_change_button img{height:100%;  margin-top: -1px;}	
.settle_ment_detail_paid_cc{
	width:100%;
	height:120px;
	min-height:22vh;
	float:left;
	overflow:auto;
	}	
.tax_table td{border:none !important;}	
.tax_textbox {
    width: 93%;
    height: 30px;
    font-size: 13px;
    padding-left: 5px;
    line-height: 33px;
    float: left;
    border-radius: 5px;
    border: solid 1px #626262;
    color: #fff;
    background-color: transparent;
	border: solid 1px #C7C7C7;
    color: #000;
    line-height: 28px;
}
.tax_table select {
    -moz-appearance: none;
    -webkit-appearance: none;
    background-image: url(../img/drop_arrow1.png);
    background-position: 95% 60%;
    background-repeat: no-repeat;
}
.payment_pend_right_cash_head {
    width: 100%;
    height: 30px;
    float: left;
    background-color: #333;
    color: #f00;
}
