/***bill history**/

.left_bill_history_contain{
	width:18%;
	min-height:510px;
	height:87vh;
	float:left;
	background-color:rgba(255,255,255,0.1);
	margin-top:0.5%;
	overflow:auto;
	}
.bill_number_head{
	width:100%;
	height:30px;
	float:left;
	background-color:rgba(245, 138, 27, 0.25);
	line-height:30px;
	text-align:center;
	color:#fff; 
	font-size:16px;
	}	
.bill_history_number{
	width:100%;
	height:25px;
	border-bottom:1px solid rgba(255,255,255,0.2);
	line-height:25px;
	color:#fff; 
	font-size:14px;
	transition:all 0.2s ease;
	cursor:pointer;
	}
.bill_history_number td{  text-align:center;}
		
.bill_history_active{background-color:rgb(193, 94, 18) !important;}	
.bill_history_cancel{background-color:rgba(255, 148, 148, 0.78);}	
.bill_history_number:hover{padding-left:10px;background-color:rgb(193, 94, 18)}	

.bill_history_center_bill{
	width:42%;
	min-height:510px;
	height:87vh;
	float:left;
	background-color:rgba(255,255,255,0.1);
	margin-top:0.5%;
	overflow:auto;
	margin-left:0.5%;
	}
.bill_history_details_table{
	width:100%;
	min-height: 480px;
	height:82vh;
	overflow:auto;
	float:left;
	}
.bill_history_details_table td{
	height:33px;
	vertical-align:middle;
	border:0;
border:solid 1px rgba(255,255,255,0.1);
color:#fff;
font-size:13px;
	}
.bill_history_right_detail .bill_history_details_table td{border: 0 !important}
.bill_his_order_detail_head  td{
	height:25px;
	vertical-align:middle;
	border:0;
border:solid 1px rgba(255,255,255,0.1);
color:#fff;
font-size:14px;
font-family: 'CALIBRI_0';
	}	
.bill_history_details_table td strong{font-size:15px;font-family: 'CALIBRIB_0';}	

.bill_history_right_detail{
	width: 38.5%;
	min-height:510px;
	height:87vh;
	float:left;
	background-color:rgba(255,255,255,0.1);
	margin-top:0.5%;
	overflow:auto;
	margin-left:0.5%;
	position:relative;
	}
.bill_his_order_detail_head{
	width:100%;
	height:25px;
	float:left;
	background-color:rgba(132, 169, 224, 0.18);
	font-size:14px;
	}	
.bill_history_orderd_cont{
	width:100%;
	min-height:400px;
	height:70vh;
	  overflow-y: scroll;
	float:left;
	margin-top:7px;
	}
.bil_his_sl_no{
	width: 13.5%;
	height:25px;
	float:left;
	border:solid 1px rgba(255,255,255,0.1);
	color:#fff;
	font-size:14px;
	line-height:25px;
	position: relative;
	}
.bil_his_dish_name{
	width:46%;
	height:25px;
	float:left;
	border:solid 1px rgba(255,255,255,0.1);
	color:#fff;
	font-size:14px;
	line-height:25px;
	word-break: break-word;
	}		
		
.right_bill_history_detail{
		width:100%;
		height:30px;
		overflow:hidden;
		margin-bottom:0.5%;
		float:left;
		}	
.bill_his_buton_cc{
		width:99%;
		height:47px;
		position:absolute;
		bottom:0px;
		margin:0.5%;
		border-top:1px solid rgba(255,255,255,0.2);
		}
.bill_cancel_btn{
	width:46%;
	height:40px;
	float:left;
	top:3px;
	position:absolute;
	left:2%;
	/*background-color:rgb(125, 61, 7);*/
	    background-color: #8F1200;
	color:#fff;
	font-size:14px;
	line-height:40px;
	border-radius:5px;
	text-align:left;
	padding-left:13%;
	cursor:pointer;
	transition:all 0.2s ease;
	background-image:url(../img/print_re.png);
	background-position: 80% 50%;
	background-repeat:no-repeat;
    background-size: 15%;
	}
.bill_cancel_btn a{
	text-decoration:none;color:#fff;
	font-size:14px;
	line-height:35px;}	
.bill_cancel_btn:hover{background-color:rgba(255, 0, 0, 0.8);}								

.bill_history_close_btn{
	color:#f00;
	background-color:rgba(255,255,255,0.5);
	width:22px;
	height:22px;
	float:left;
	border-radius:50%;
	text-align:center;
	font-size: 12px;
    line-height: 22px;
	    position: absolute;
    left: 2px;
	font-weight:bold;
	}
.bill_history_close_btn:hover{text-decoration:none;background-color:rgba(255,255,255,1);}	
.new_error_div {
    width: 100%;
    height: 20px;
    float: left;
}
.popup_conform_his{
	    display: block;
    width: 100%;
    height: 33px;
    padding: 8px 12px;
    font-size: 14px;
    line-height: 1.42857143;
    color: #555555;
    background-color: #ffffff;
    background-image: none;
    border: 1px solid #cccccc;
    border-radius: 4px;
    -webkit-box-shadow: inset 0 1px 1px rgba(0,0,0,0.075);
    box-shadow: inset 0 1px 1px rgba(0,0,0,0.075);
    -webkit-transition: border-color ease-in-out .15s,box-shadow ease-in-out .15s;
    -o-transition: border-color ease-in-out .15s,box-shadow ease-in-out .15s;
    transition: border-color ease-in-out .15s,box-shadow ease-in-out .15s;
    border: 1px solid #C1C1C1;
    display: inline-block;
	}

.sm_pop_head{
	width:100%;
	height:30px;
	float:left;
	text-align: left;
	padding-left:20px;
	color: #000;
    background-color: #E4E4E4;
    line-height: 30px;
    border-bottom: 1px #ccc solid;
	font-size:19px;
	margin:0px;
	}
.contenttext{
	font-family: 'CALIBRI_0';
    letter-spacing: 1px;
	  font-size: 14px;
    color: #000;
	}
.otp_gent_btn{
	     width: 45% !important;
    float: right;
     height: 32px !important;
    line-height: 31px !important;
    background-color: #FF2306;
    text-align: center !important;
    border-radius: 5px !important;
    transition: all 0.2s ease;
    display: none;
    margin-top: -4px !important;
    margin-left: 0px !important;
	}
.bill_his_back_btn{
	    width: 120px;
    height: 35px;
    float: left;
    text-align: center;
    color: #fff;
    font-family: 'CALIBRI_0';
    font-size: 14px;
    line-height: 35px;
    margin-top: 1px;
	 background-color:#F5351B;
	 border-radius:7px;
	 background-image:url(../img/arrow-bt.png);
	 background-position:10px 50%;
	 background-repeat:no-repeat;
	 padding-left:10px;
	}	
.bill_history_head{
	width:48%;
	height:35px;
	float:left;
	text-align:right;
	line-height:37px;
	color:#fff;
	 font-family: 'CALIBRIB_0';
	 font-weight:bold;
	 font-size:18px;
	/* 	background-color: rgba(0, 0, 0, 0.52);
    box-shadow: inset 0px 0px 20px -2px #000;*/
	}
.navbar {
    border-radius: 0px !important;
    min-height: 57px !important;
    border: none !important;
    margin-bottom: 0px !important;
    background-color: #191919 !IMPORTANT;
    background-image: none;
}
.navbar-brand {
    margin-top: -13px !important;
    position: relative;
    left: -6px;
}
