.kot_sorting_1 .trigger{
	height:37px;
	  border: 1px solid #ccc  !important;
	  background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #3b2751), color-stop(100%, #ccc));
  background-image: -webkit-linear-gradient(#fff, #fff) !important;
  background-image: -moz-linear-gradient(#fff, #fff) !important;
  background-image: -o-linear-gradient(#fff, #fff) !important;
  background-image: linear-gradient(#fff, #FFFFFF) !important;
	}
.fancy-select select:focus + div.trigger{box-shadow:none !important;}	
