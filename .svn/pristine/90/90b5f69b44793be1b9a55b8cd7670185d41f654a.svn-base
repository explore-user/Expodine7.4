 if($check=='test_print'){ 
     
     
      if($_SESSION['s_printst']=='Y'){
        
          
        if($_REQUEST['port']!='9100'){
					 
	$printer="\\\\".$_REQUEST['ip']."\\".$_REQUEST['port'];
	$connector = new FilePrintConnector($printer);
	$printers = new Escpos($connector);
        
	}else{
            
	$connector = new NetworkPrintConnector($_REQUEST['ip'], $_REQUEST['port']);
	$printers = new Escpos($connector);
        
	}
        
                         if($_REQUEST['port']=='9100'){ 
                             
                          if (strtoupper(substr(PHP_OS, 0, 3)) === 'WIN') {
                            exec("ping -n 1 -w 1 ".$_REQUEST['ip'], $output, $result);               
                            
                          }
                          
                          $nm='LAN';
                          
                         }else{
                            
                             $result=0;
                             
                              $nm='USB'; 
                         }    
                          
                            echo $result;
                         
                            if(!$result == 0 )
                            {
                                      
                              echo "No Connection to ".$_REQUEST['ip'];
                                     
                            }else{
                                
                               
                                      
                                $printers -> setJustification(Escpos::JUSTIFY_CENTER);
				$printers -> selectPrintMode(Escpos::MODE_DOUBLE_HEIGHT);
				$printers -> selectPrintMode(Escpos::MODE_DOUBLE_WIDTH);
				$printers -> setEmphasis(true);
				$printers -> setTextSize(1,1);
                                $printers -> text($nm." TEST PRINT");
                                $printers -> feed();
                                $printers -> text(" ");
                                
                                $printers -> setEmphasis(false);
				$printers -> setTextSize(1, 1);
                                
                                $printers -> setEmphasis(false);
								$printers -> setFont(Escpos::FONT_A);
								$printers -> setJustification(Escpos::JUSTIFY_LEFT);
								
								$printers -> setEmphasis(true);
								$printers -> setFont(Escpos::FONT_A);
								$printers -> setJustification(Escpos::JUSTIFY_LEFT);
								
								$printers -> feed();
                                                                
                                                                $printers -> text('NAME : '.$_REQUEST['name']);
                                                                
                                                                
                                                                $printers -> feed();
                                                                
                                                                $printers -> text('PRINTER IP : '.$_REQUEST['ip']);
                                                                
								$printers -> setEmphasis(true);
								$printers -> setFont(Escpos::FONT_A);
								$printers -> setJustification(Escpos::JUSTIFY_LEFT);
								
								$printers -> setEmphasis(true);
								$printers -> setFont(Escpos::FONT_A);
								$printers -> setJustification(Escpos::JUSTIFY_LEFT);
								$printers -> feed();
                                                                   
                                                                $printers -> text('PORT : '.$_REQUEST['port']);
                                                              
								$printers -> feed();
                                                                  
				$printers -> selectPrintMode();
				$printers -> feed();
				$printers -> cut();
				$printers -> close();
                                
			     }
          
  }else{
      
    echo 'Print_all_off'; 
     
 }
 
 
 }
