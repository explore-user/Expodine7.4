        address,csname,csnum,ref,billno,discount,remarks,status,amount,time,floor,tip,floorid from
            
        (select bm.bm_tableno as table_name,bm.bm_paymode as paymode,((bm_finaltotal-bm_taxable_amount)-bm_roundoff_value) as tax,
        bm.bm_settlement_login as login,bm.bm_subtotal as sub,
        bm.bm_dayclosedate as date,bm.bm_cname as customer, bm.bm_cnumber as number,null as address,null as csname,null as csnum,
        bm.bm_bill_ref as ref,bm.bm_billno as billno ,bm.bm_discountvalue as discount,bm.bm_gst as remarks,
        bm.bm_status as status, bm.bm_finaltotal as amount,bm.bm_billtime as time,tf.fr_floorname as floor,
        bm.bm_tips_given as tip ,bm.bm_floorid as floorid
        FROM tbl_tablebillmaster bm 
        left join tbl_tablebill_extra_tax_master te on te.bem_billno=bm.bm_billno 
         left join tbl_tableorder tb on tb.ter_billnumber=bm.bm_billno
         left join tbl_floormaster tf on tf.fr_floorid=bm.bm_floorid
        where  bm.bm_dayclosedate='".$_REQUEST['date']."'  $src group by bm.bm_billno order by bm.bm_billtime desc
                                                
        union all
                                                
        select null as table_name,tbm.tab_paymode as paymode,((tab_netamt-tab_taxable_amount)-tab_roundoff_value) as tax,tab_settlement_login as login,
        tbm.tab_subtotal as sub,tab_dayclosedate as date,tac_customername as customer, tac_contactno as number,
        tac_address as address ,tbm.tab_name as csname,tbm.tab_phone as csnum,tab_bill_ref as ref,
        tab_billno as billno,tbm.tab_discountvalue as discount,tac_remarks as remarks ,tbm.tab_status as status,
        tbm.tab_netamt as amount,tbm.tab_time as time,null as floor,tbm.tab_tips_given as tip,null as floorid
        
        FROM tbl_takeaway_billmaster tbm LEFT JOIN tbl_takeaway_customer ts ON ts.tac_customerid=tbm.tab_hdcustomerid 
        left join tbl_takeaway_bill_extra_tax_master te on te.tbe_billno=tbm.tab_billno
        where tbm.tab_dayclosedate='".$_REQUEST['date']."' $src1 group by tbm.tab_billno order by tbm.tab_time desc )x group by billno order by time desc";
              
        
