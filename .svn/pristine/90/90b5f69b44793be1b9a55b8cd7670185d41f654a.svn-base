	$bill_sorry=1;
	$sql_kots="Select pr_defaultusb,pr_printerip,pr_printerport,pr_printername From tbl_printersettings  Where"
        . "  pr_printertype= '5' and  pr_enable='Y' and pr_defaultusb = 'N' group by pr_printerip ";
