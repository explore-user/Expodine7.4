@font-face {
    font-family: 'CALIBRI_0';
    src: url('../fonts/CALIBRI_0.eot');
    src: url('../fonts/CALIBRI_0.eot') format('embedded-opentype'),
         url('../fonts/CALIBRI_0.woff2') format('woff2'),
         url('../fonts/CALIBRI_0.woff') format('woff'),
         url('../fonts/CALIBRI_0.ttf') format('truetype'),
         url('../fonts/CALIBRI_0.svg#CALIBRI_0') format('svg');
}


a {
  text-decoration: none;
}

h1 {
  margin-top: 0;
}

#contentWrapper {
  width: 100%;
  height: 100%;
  position: relative;
}

#contentLeft {
  z-index: 10;
  width: 250px;
  height: 100%;
  position: absolute;
  top:0px;
  left: 0;
/*  background-color: #283c51;*/
}

#contentRight {
  padding: 1.3rem 2rem;
  margin-left: 250px;
}

#leftNavigation {
  margin:0;
}
#leftNavigation, #leftNavigation li ul {
  list-style: none;
  padding: 0;
}
#leftNavigation li a {
	background-color: #13171E;
/*  font-size: 0.875rem;*/
font-family: 'CALIBRIB_0';
  display: block;
  padding: 0.8rem 1rem 0.8rem 3rem;
  color: #adadad;
  border-bottom: solid 1px #343434;
  text-overflow: ellipsis;
  overflow: hidden;
  position: relative;
  -webkit-transition: color 0.2s ease;
  transition: color 0.2s ease;
  text-align:left;
}

#leftNavigation li a:focus {color:#fff}
#leftNavigation li a, #leftNavigation li a .leftNavIcon {
  line-height: 120%;
}
#leftNavigation li a .leftNavIcon {
  position: absolute;
  top: 0;
  left: 0;
  width: 3rem;
  padding: 0.8rem 0;
  text-align: center;
}
#leftNavigation li a:hover {
  color: white;
}
#leftNavigation li ul {
 /* height:0px;*/
 /* display:none;*/
    /*transform:scale(0);*/
  margin: 0;
  overflow:hidden;
   background-color: #120811;
  -webkit-transition:all 0.4s ease;
	-moz-transition:all 0.4s ease;
	-ms-transition:all 0.4s ease;
	-o-transition:all 0.4s ease;
	transition:all 0.4s ease;
}
#leftNavigation li ul li{height:0px;
-webkit-transition:all 0.4s ease;
	-moz-transition:all 0.4s ease;
	-ms-transition:all 0.4s ease;
	-o-transition:all 0.4s ease;
	transition:all 0.4s ease;
}
#leftNavigation li ul li a {
  border-bottom: solid 0px #202020;
}
#leftNavigation li ul li:last-child a {
  border-bottom: none;
}
#leftNavigation li ul li.active a {
  color: white;
}
#leftNavigation li.active > a {
  color: white;
}

#leftNavigation li.active ul {
  /*display: block;*/
  height:auto;
 
    /*transform:scale(1);*/
   overflow:visible;
}
#leftNavigation li.active ul li{
	margin-top:0px;
	 height:35px;
  padding: 0 !important;
  width: 100%;display:inherit !important;}
  #leftNavigation li.active ul li a{font-size:12px !important;  background-color: transparent !important;  color: #000;}
#leftNavigation > li.active a {
  background-color: #891500;
  text-decoration:none;
 /* background-image:url(../../images/main_manu_active.png);*/
  background-repeat:no-repeat;
  background-position:right;
    width: 101%;
}
/*#leftNavigation > li.active ul li a {
  background-color: #13171E !important;
  background-image:url(../../images/list_bg.png);
  background-repeat:no-repeat;
  display:block;
  background-position:10% 0;
  text-decoration:none;
}*/
#leftNavigation > li.active ul{border-bottom:2px #120811  solid;  background-color: #fff;  width: 96.5%;margin-left: 5px;overflow:hidden}
#leftNavigation > li.active ul li a:hover {  background-color: rgba(169, 169, 169, 1) !important;color: #000;}
#leftNavigation a:focus {text-decoration:none;color:#fff !important;}
.min-nav .menu 
{  min-height: 580px !important;
  height: 70vh !important;
	
  }
  
.active_dsble{
	height:auto;
	 } 
.active_dsble #leftNavigation li.active ul li{height:0px;padding-top:0;}	
.active_dsble ul{display:none !important}

  .mn_sub_li_a_active{  background-color: rgba(69, 69, 69, 0.9) !important;  color: #fff !important;}
#leftNavigation li ul li a {
  border-bottom: solid 0px #202020;
  background-color: #13171E !important;
}

  
