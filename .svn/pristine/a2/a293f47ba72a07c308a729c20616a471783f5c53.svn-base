/* Responsive styles
================================================== */

/* Large Devices, Wide Screens */


@media (max-width: 1200px) {
   .faq_contant_row_head{width: 77%;    font-size: 16px;}
}
@media (max-width: 1080px) {

}
@media (max-width: 1000px) {
 
}

@media (max-width: 991px) {
   .faq_contant_sec .container{width: 95%;max-width: inherit;}
   .faq_contant_row_ico {width: 24px;}
   .faq_contant_row_head { width: 77%;  font-size: 13px;}
   .scroll-to-fixed-fixed{left: 4%;}
  
 }
 @media (max-width: 768px) {
    .top_logo{text-align: center;}
    .faq_tp_img{text-align: center;display: none;}
    .scroll-to-fixed-fixed{width: 100% !important;position: static;}
    .faq_contant_row_ico {width: 30px;}
    .faq_contant_row_head { width: 77%;  font-size: 15px;}
    .faq_page_head_sec h2{font-size: 20px;}
    .faq_mn_img {width: 40%;}
    .faq_right_cnt_anw_sub_cnt span .fa{margin: 0 2px;}
    .faq_right_cnt_anw_sub_cnt{font-size: 13px;}
    .video_ttrl_sec{width: 100%;text-align: center;}
    .video_ttrl_sec_ico{display: inline-block;float: none;position: relative;  top: 11px;}
    .video_ttrl_sec_text{display: inline-block;float: none;    width: 140px;}

 }
 @media (max-width: 475px) {
   .top_logo img{max-width: inherit;width: 100%;}
   .faq_page_head_sec h2 { font-size: 17px;  }
 }
 @media (max-width: 510px) {
  
}