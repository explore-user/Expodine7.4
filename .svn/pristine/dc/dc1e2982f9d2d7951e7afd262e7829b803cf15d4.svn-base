.nopaddding{padding-left:0px !important;padding-right:0px !important}
.responstable {
   /* margin: 0.2em 0;*/
  width: 100%;
  overflow: hidden;
  background: #FFF;
  color: #4D4D4D;
 font-family: 'CALIBRI_0';
  font-weight:normal;
  font-size:14px;
  /*border-radius: 10px;*/
 /* border: 1px solid #167F92;*/
}
/*.responstable tr {
  border: 1px solid #D9E4E6;
    background-color: #E8E8E8  !important;
}
.responstable tr:nth-child(odd) {
  background-color: #EDEDED;
}
.responstable tr:nth-child(even) {
  background-color: #EDEDED;
}*/
.responstable td{border:solid 1px #ccc !important;border-top:0px !important}
.responstable th {
 /* display: none;*/
  border: 1px solid #FFF;
  background-color: #242424;
  color: #FFF;
  padding: 1em;
  font-family: 'CALIBRI_0';
  font-weight: lighter;
  text-align: center !important;
}
.responstable th:first-child {
 /* display: table-cell;*/
  text-align: center;
}
.responstable th:nth-child(2) {
/*  display: table-cell;*/
}
.responstable th:nth-child(2) span {
  display: none;
}
.responstable th:nth-child(2):after {
  content: attr(data-th);
}
@media (min-width: 480px) {
  .responstable th:nth-child(2) span {
    display: block;
  }
  .responstable th:nth-child(2):after {
    display: none;
  }
}
.responstable td {
 /* display: block;*/
  word-wrap: break-word;
 /* max-width: 7em;*/
  cursor:pointer;
}
.responstable td:first-child {
 /* display: table-cell;*/
  text-align: center;
  border: 1px solid #fff;
}
@media (min-width: 480px) {
  .responstable td {
    border: 1px solid #fff;
  }
}
.responstable th, .responstable td {
  text-align: left;
 /* margin: .5em 1em;*/
}
@media (min-width: 480px) {
  .responstable th, .responstable td {
    /*display: table-cell;*/ 
	 padding: 0.6em;
	font-family: 'CALIBRI_0';
  }
}

body {
  padding: 0 2em;
  font-family: 'CALIBRI_0';
  color: #024457;
  background: #f2f2f2;
}

h1 {
  font-family: 'CALIBRI_0';
  font-weight: normal;
  color: #024457;
}
h1 span {
  color: #167F92;
}

