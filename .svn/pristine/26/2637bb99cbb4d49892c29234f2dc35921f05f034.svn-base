            echo $row['ser_staffid']; 
        }
        echo "*reprint:".$row['ser_bill_reprint_per']."*regen:".$row['ser_bill_regen_per']."*change:".$row['ser_bill_settle_change_per']."*kotcancel:".$row['ser_cancelpermission']."*billcancel:".$row['ser_bill_cancel_permission']."*dayclose:".$row['ser_dayclose_permission']."*ordersplit:".$row['ser_order_split_permission'];
       
