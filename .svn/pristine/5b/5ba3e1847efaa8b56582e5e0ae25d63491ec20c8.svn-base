<!--  form validation  -->
<script type="text/javascript">
    
   function login_rf_id(){ 
      
       var pin = $('#pin1').val();
       
       if(pin!=''){
         
                        $('.alert_error_popup_all_in_one').show();
                                    
                        $('.alert_error_popup_all_in_one').text('PLEASE WAIT');
                        
                        $('.alert_error_popup_all_in_one').delay(2000).fadeOut('slow');
                       
                        document.loginpage.submit();
               
           }else{
          
                        $('.alert_error_popup_all_in_one').show();
                                    
                        $('.alert_error_popup_all_in_one').text('SCAN YOUR CARD');
                        $('.alert_error_popup_all_in_one').delay(500).fadeOut('slow');
                        $('#pin').focus();
      }
     
    }
    
    
    
function login_submit()
{
	if(validate_username())
	{
		if(validate_password())
		{
		    document.loginpage.submit();
		}
	}
       
}
function validate_username()   
{
	if(document.getElementById("username").value=="")
	{
		$("#username_div").addClass("has-error");
		document.loginpage.username.focus();
		return false;
	}else
		 {
			$("#username_div").removeClass("has-error");
			$(this).addClass("has-success");
			return true;
			
		 }
}
function validate_password()   
{
	if(document.getElementById("password").value=="")
	{
		$("#password_div").addClass("has-error");
		document.loginpage.password.focus();
		return false;
	}else
		 {
			$("#password_div").removeClass("has-error");
			$(this).addClass("has-success");
			return true;
			
		 }
}
function check_change(divid,controlid)
{
	if(document.getElementById(controlid).value=="")
	{
		$("#"+divid).addClass("has-error");
		$("#"+divid).removeClass("has-success");
	}else
	{
	         $("#"+divid).removeClass("has-error");
	         $("#"+divid).addClass("has-success");
	}
	
}


function exit_chrome(){
    
    $(".closechrome_popup").css("display","block");
    $(".language_overlay").css("display","block");
   
}


function lastclose(){
    
        var datastring = "exit_chrome=chrome_close";
    
            $.ajax({
            type: "POST",
            url: "login.php",
           
            data: datastring,
            success: function (data)
            {
              
            }
        });
}

function close_pop_chrome(){
    
          $(".closechrome_popup").css("display","none");
	  $(".language_overlay").css("display","none");
          $('#pin').focus();
}


</script>

