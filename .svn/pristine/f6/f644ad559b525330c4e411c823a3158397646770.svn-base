    letter-spacing: 0.2px;
    margin: 0;
    padding: 8px 0 8px 30px;
    text-align: left;
    width: 50%;
}
.map-table > ul {
    float: left;
    margin: 0;
    padding: 0;
    width: 100%;
}
.map-table li:nth-child(2n+1) {
