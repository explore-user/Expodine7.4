    font-size: 20px;
    height: 57px;
    line-height: 56px;
    margin-bottom: 15px;
    margin-right: 20px;
    margin-top: 15px;
    text-align: center;
    vertical-align: middle;
    width: 57px;
}
.welcome-bar > p {
    color: #474343;
