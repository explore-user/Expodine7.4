/* Panel Content */
.panel-content {
    float: left;
    margin-top: 0;
    padding-top: 0;
    width: 100%;
}
.panel-content .row {
    margin: 0 -7px;

}
.main_float_widget_cc{
		    -moz-columns: 300px 2;
    -webkit-column-count: 2;
    -moz-column-count: 2;
    column-count: 2;
    -webkit-column-gap: 0em;
    -moz-column-gap: 0em;
    column-gap: 0em;
	 /*   display: inline-block;*/
	}
.panel-content .row > div {
    padding: 0 7px;
}
.mini-stats-sec {
    float: left;
    width: 100%;
}
.mini-stats {
    background: #ffffff none repeat scroll 0 0;
    
    -webkit-border-radius: 5px;
