function edit_vendor(vid){
    $('.voucher_div').addClass('md-show');
    $('#pop_head').text('EDIT SUPPLIER VOUCHER');
    $('#return_div_new').hide();
    $('#bal_div').hide();
    $.ajax({
			type: "POST",
			url: "load_accounts_data.php",
			data: "set=edit_vendor_voucher&edit_id="+vid,
			success: function(msg)
			{
                            
                       var ed1=$.trim(msg);
                       
                       var ed=ed1.split('*');
       
     $('#v_paid_amount').prop("readonly", true);    
      $('.v_date').prop("readonly", true);    
     $('.v_date').css('pointer-events','none');
     
   $('#vendor_id').attr('voucher_update_id',vid);
  $('#vendor_id').val(ed[0]);
  $('#vendor_id').attr('vendor_id_set',ed[1]);
