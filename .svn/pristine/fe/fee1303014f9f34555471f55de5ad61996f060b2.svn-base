  $('#v_trn_detail').val(ed[8]);
  $('#v_remarks').val(ed[9]);
   $('#v_credit_amount').val(ed[10]);
  $('.type_vend').text(ed[11]);
   $('#v_discount').val(ed[12]);
    $('#v_purchase_type').val(ed[13]);
   $('#vendor_id').attr('vendor_typ_set',ed[11]);                            
                        }
                    });
       
}



function update_suplier_voucher()
{   
  var bal_pay=parseFloat($('#v_balance').val());

  if(bal_pay>0)
  { 
  var v_date=$('.v_date').val();
  var v_address=$('#v_address').val();
  var v_inv=$('#v_invoice').val();
  var v_inv_amount=$('#v_invoice_amount').val();
  var v_from=$('#v_from').val();
  var v_paid_amt=$('#v_paid_amount').val();
  var v_trn_detail=$('#v_trn_detail').val();
  var v_remark=$('#v_remarks').val();  
  var v_credit_amount=$('#v_credit_amount').val();
  var update_id=$('#vendor_id').attr('vendor_id_set'); 
  var vendor_typ=$('#vendor_id').attr('vendor_typ_set');  
  var v_purchase_type=$('#v_purchase_type').val();
  var discount= $('#v_discount').val();
   
   
    if(v_inv_amount!='' && v_date!=''  && v_paid_amt!='' &&  v_inv!='' && v_remark!=''){
        
       if(v_from =='' && v_paid_amt>0)
       {
            $('#error_pop_v').show();
            $('#error_pop_v').text('SELECT FROM ACC');
            $('#v_from').focus(); 
            $('#error_pop_v').delay(2000).fadeOut('slow');
             exit; 
        }
        var data_v="set=update_vendor_balance&v_date="+v_date+"&v_address="+v_address+"&v_inv="+v_inv+"&v_inv_amount="+v_inv_amount+"&v_from="+v_from+
          "&v_paid_amt="+v_paid_amt+"&v_trn_detail="+v_trn_detail+"&v_remark="+v_remark+"&update_id="+update_id+"&v_credit_amount="+v_credit_amount+"&vendor_typ="+vendor_typ+"&v_purchase_type="+v_purchase_type+"&discount="+discount;
        
        $.ajax({
			type: "POST",
			url: "load_accounts_data.php",
			data: data_v,
			success: function(msg)
			{                           
                $('#error_pop_v').show();
                $('#error_pop_v').css('background-color', '#549056');
                $('#error_pop_v').text('PAID SUCCESSFULLY');
                $('#error_pop_v').delay(2000).fadeOut('slow');
                $('.voucher_div').removeClass('md-show');
                search_vendor();  
               // setTimeout(function(){
                $.ajax({
                type: "POST",
                url: "load_ledger.php",
                data: "set=open_ledger_daywise&date="+v_date,
                success: function(msg1)
                {
                                     
                $.ajax({
                type: "POST",
                url: "load_ledger.php",
                data: "set=close_ledger_daywise&date="+v_date,
                success: function(msg)
                {
                                  
                }
                });    
                }
                });
                //search_vendor();
               // }, 500); 
            }
            });
        
        
        
        
        
    }else{
        
       $('#error_pop_v').show();
       
        
        
         if(v_paid_amt==''){
              
               $('#error_pop_v').text('ENTER PAID AMOUNT');
               $('#v_paid_amount').focus();
          }
        
         
        
           if(v_remark==''){
              
               $('#error_pop_v').text('ENTER PARTICULARS');
               $('#v_remarks').focus();
          }
          
          if(v_date==''){
              
               $('#error_pop_v').text('ENTER DATE');
               $('.v_date').focus();
          }
          
          
        $('#error_pop_v').delay(2000).fadeOut('slow');
      
      
            }
      
      
  }else{
  
  var v_date=$('.v_date').val();
  var v_address=$('#v_address').val();
  var v_inv=$('#v_invoice').val();
  var v_inv_amount=$('#v_invoice_amount').val();
  var v_from=$('#v_from').val();
  var v_paid_amt=$('#v_paid_amount').val();
  var v_trn_detail=$('#v_trn_detail').val();
  var v_remark=$('#v_remarks').val();  
  
  var v_credit_amount=$('#v_credit_amount').val();
   
   var update_id=$('#vendor_id').attr('voucher_update_id'); 
    var vendor_typ=$('#vendor_id').attr('vendor_typ_set');  
    var v_purchase_type=$('#v_purchase_type').val();
    
    var discount= $('#v_discount').val();
    
    if(v_inv_amount!='' && v_date!=''  && v_paid_amt!='' &&  v_inv!='' && v_remark!=''){
        
       if(v_from =='' ){
        
            
                $('#error_pop_v').show();
        
              
               $('#error_pop_v').text('SELECT FROM ACC');
               $('#v_from').focus(); 
                $('#error_pop_v').delay(2000).fadeOut('slow');
               exit;  
        }
        if(vendor_typ=='Normal'){

            if(parseFloat(v_paid_amt) != parseFloat(v_inv_amount)){
                
                $('#error_pop_v').show();
        
              
               $('#error_pop_v').text('PAID AMOUNT IS NOT EQUAL TO INVOICE AMOUNT');
               $('#v_paid_amount').focus(); 
                $('#error_pop_v').delay(2000).fadeOut('slow');
               exit;
            }
            
        }
        
        var data_v="set=update_vendor_voucher&v_date="+v_date+"&v_address="+v_address+"&v_inv="+v_inv+"&v_inv_amount="+v_inv_amount+"&v_from="+v_from+
          "&v_paid_amt="+v_paid_amt+"&v_trn_detail="+v_trn_detail+"&v_remark="+v_remark+"&update_id="+update_id+"&v_credit_amount="+v_credit_amount+"&v_purchase_type="+v_purchase_type+"&discount="+discount;
        
        $.ajax({
			type: "POST",
			url: "load_accounts_data.php",
			data: data_v,
			success: function(msg)
			{
                         $('#error_pop_v').show();
                         $('#error_pop_v').css('background-color', '#549056');
                         $('#error_pop_v').text('UPDATED SUCCESSFULLY');
                         $('#error_pop_v').delay(2000).fadeOut('slow');
                         $('.voucher_div').removeClass('md-show');
                         setTimeout(function(){                           
                            search_vendor();                                                   
                        }, 500); 
                             
                             
                        }
                    });
        
        
        
        
        
    }else{
        
       $('#error_pop_v').show();
       
        
        
         if(v_paid_amt==''){
              
               $('#error_pop_v').text('ENTER PAID AMOUNT');
               $('#v_paid_amount').focus();
          }
        
         
        
        
          if(v_inv_amount==''){
              
               $('#error_pop_v').text('ENTER INVOICE AMOUNT');
               $('#v_invoice_amount').focus();
          }
          
          
          if(v_inv==''){
              
               $('#error_pop_v').text('ENTER INVOICE NUMBER');
               $('#v_invoice').focus();
          }
          
          
           if(v_remark==''){
              
               $('#error_pop_v').text('ENTER PARTICULARS');
               $('#v_remarks').focus();
          }
          
          
           if(v_date==''){
              
               $('#error_pop_v').text('SELECT DATE');
               $('.v_date').focus();
          }
          
        $('#error_pop_v').delay(2000).fadeOut('slow');
    }
    
    
        }
        
        
}


function valid_paid(){
    
     var decimal=$('#decimal').val();
    
     var v_invoice_amount=parseFloat($('#v_invoice_amount').val());
 
     var v_paid_amount=parseFloat($('#v_paid_amount').val());
   
   
   if(v_paid_amount==0){
       
       $('#v_paid_amount').val('');
   }
   var bal_pay=parseFloat($('#v_balance').val());

   if(bal_pay >0 ){
       if(v_paid_amount> bal_pay){
       $('#v_paid_amount').val('');
        $('#error_pop_v').show();
        $('#v_credit_amount').val('');
        
               $('#error_pop_v').text('  PAID AMOUNT SHOULD BE LESS THAN BALANCE AMOUNT ');
               $('#v_paid_amount').focus();
               $('#error_pop_v').delay(2000).fadeOut('slow');
   }else{
       
       var credit_amt=(bal_pay-v_paid_amount).toFixed(decimal);
       
       $('#v_credit_amount').val(credit_amt);
       
   }
 
       
       
   }
       
       else{
        
      
   
       if(v_paid_amount> v_invoice_amount){
       $('#v_paid_amount').val('');
        $('#error_pop_v').show();
        $('#v_credit_amount').val('');
        
               $('#error_pop_v').text(' INVALID PAID AMOUNT ');
               $('#v_paid_amount').focus();
               $('#error_pop_v').delay(2000).fadeOut('slow');
   }else{
       
       var credit_amt=(v_invoice_amount-v_paid_amount).toFixed(decimal);
       
       $('#v_credit_amount').val(credit_amt);
       
   }
 
   if(v_invoice_amount=='' || v_invoice_amount=='0' || isNaN(v_invoice_amount)){
       $('#v_paid_amount').val('');
        $('#error_pop_v').show();
        
        
               $('#error_pop_v').text(' ENTER INVOICE AMOUNT FIRST ');
              // $('#v_invoice_amount').focus();
               $('#error_pop_v').delay(2000).fadeOut('slow');
   }
   }
   
}


function delete_supplier_voucher(vid){
     
      var confirm1=confirm(" DELETE VOUCHER ?");
      if(confirm1===true){
          $('#error_pop_v').show();
                         $('#error_pop_v').css('background-color', 'red');
                         $('#error_pop_v').text('DELETING');
                         $('#error_pop_v').delay(5000).fadeOut('slow');
      $.ajax({
			type: "POST",
			url: "load_accounts_data.php",
			data: "set=delete_supplier_voucher&vid="+vid,
			success: function(msg)
			{
                          //location.reload();
                          search_vendor();  
                        }
                    });
                }
}
</script>

<div style="position:fixed;width:auto;right: 20px;bottom:20px;z-index:99999;background-color: #f00;color: white;padding: 10px 20px;display: none;font-size: 15px" id="error_pop_v"> </div>

<div style="display:none" class="confrmation_overlay_proce"></div>
