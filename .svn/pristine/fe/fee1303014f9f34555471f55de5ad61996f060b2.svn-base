}

    function check_ledger_balance()
    {
    var v_from=$('#v_from').val();
    var data_v="set=check_ledger_balance&ledger="+v_from;
    $.ajax({
			type: "POST",
			url: "load_accounts_data.php",
			data: data_v,
			success: function(msg)
			{      
        if($.trim(msg)!='ok'){                 
         $('#v_from').val('');            
         $('#error_pop_v').show();
         $('#error_pop_v').text('NO BALANCE IN LEDGER');
         $('#v_from').focus();
         $('#error_pop_v').delay(2000).fadeOut('slow');         
                  }    
                        }
                    });
    }
    
function search_vendor(n)
{ 
   var v_name=$('#search_name').val();
   var v_date=$('#search_date').val();
   var search_date_to=$('#search_date_to').val();
   var search_inv_no=$('#search_inv_no').val();
   var search_type=$('#search_purchase_type').val();
   var search_payment_type=$('#search_payment_type').val();
   var search_tax_type=$('#search_tax_type').val();
   var data_v="set=search_vendor_voucher&v_name="+v_name+"&fromdt="+v_date+"&todt="+search_date_to+"&search_inv_no="+search_inv_no+"&search_type="+search_type+"&search_payment_type="+search_payment_type+"&search_tax_type="+search_tax_type;
   
//    if($('#search_date').val()!='' && $('#search_date_to').val()!=''){
//       $('.confrmation_overlay_proce').css('display','block');
//       $('.confrmation_overlay_proce').html('<img src="img/ajax-loaders/fetch.gif" />'); 
//    }
   if(!n)
        {
          n=1;
        }

    $.ajax({
			type: "POST",
			url: "load_accounts_data.php?page="+n,
			data: data_v,
            dataType: 'json',
			success: function(msg)
			{        
            $('#load_vendor_data').html(msg.data);  
            $('#show_text').html(msg.show);
            $('#show_pagination').html(msg.pagination);  
            $('.confrmation_overlay_proce').css('display','none');   
            }
        });
}


function datechange()
{
   if($('#search_date').val()!='' && $('#search_date_to').val()!=''){
      $('.confrmation_overlay_proce').css('display','block');
      $('.confrmation_overlay_proce').html('<img src="img/ajax-loaders/fetch.gif" />'); 
      search_vendor();
   }
}
function close_voucher(){
    //location.reload();   
    $('.voucher_div').removeClass('md-show');
    $('.return_div').removeClass('md-show');
    $('#error_pop_v').hide();
    
}


function return_submit(){ 
 var vid= $('#r_vendor_id').attr('ven_id');
 var inv= $('#r_invoice').val();
  var amt=$('#r_amount').val();
  var date=$('#r_date').val();
  var part=$('#r_remarks').val();
  var to_acc=$('#r_to').val();
 var sv_id= $('#r_voucher').val();

 if(date !='' && to_acc!='' && part!='')
       {           
     $.ajax({
			type: "POST",
			url: "load_accounts_data.php",
			data: "set=return_pay&inv="+inv+"&vendor="+vid+"&amt="+amt+"&date="+date+"&part="+part+"&to_acc="+to_acc+"&sv_id="+sv_id,
			success: function(msg)
			{ 
                         $('#error_pop_v').show();
                         $('#error_pop_v').css('background-color', '#549056');
                         $('#error_pop_v').text('RETURN SUCCESSFULL');
                         $('#error_pop_v').delay(2000).fadeOut('slow');
                      
                         setTimeout(function(){                            
                        // location.reload(); 
                        $('.return_div').removeClass('md-show');
                        search_vendor();                          
                        }, 500);                            
                        }
                    });
                }
    else{
        $('#error_pop_v').show(); 
        if(date==''){             
              $('#error_pop_v').text('ENTER RETURN DATE');
              $('#r_date').focus();
         }
         else if(to_acc==''){            
              $('#error_pop_v').text('ENTER TO ACC');
              $('#r_to').focus();
         }
         else if(part==''){              
              $('#error_pop_v').text('ENTER PARTICULAR');
              $('#r_remarks').focus();
         }
         else{
           $('#error_pop_v').delay(2000).fadeOut('slow'); 
         }
         
    }  
}

function return_pay(id,inv,vid,amt,vname){
    
    $("#r_date").val('');
    $("#r_to").val('');
    $("#r_remarks").val('');
    
   $.ajax({
			type: "POST",
			url: "load_accounts_data.php",
			data: "set=return_pay_check&inv="+inv+"&vendor="+vid+"&amt="+amt+"&sv_id="+id,
			success: function(msg)
			{                           
    if($.trim(msg)=='Yes'){                           
       $('.return_div').addClass('md-show');    
       $('#r_invoice').prop("readonly", true);                   
                         
  $('#r_vendor_id').attr('ven_id',vid);
  $('#r_vendor_id').val(vname);  
  $('#r_voucher').val(id);
 
  $('#r_invoice').val(inv);
  $('#r_amount').val(amt);

        }else{
            $('#error_pop_v').show();
                         $('#error_pop_v').css('background-color', 'red');
                         $('#error_pop_v').text('PAID ALREADY');
                         $('#error_pop_v').delay(2000).fadeOut('slow');
        }
    }
                    });      
}



