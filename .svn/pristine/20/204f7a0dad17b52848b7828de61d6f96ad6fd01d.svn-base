.table_viewing_container{
	width:100%;
	height:auto;
	float:left;
	border-top:1px #ccc solid;
	}
.table_select_btn{
	width:auto;
	float:left;
	height:40px;
	background-color:#fff;
	box-shadow:2px 2px 3px #666; 
	line-height:40px;
	text-align:center;
	font-size:14px;
	color:#000;
	margin:2%;
	padding:0 6%;
	border-radius:5px;
	border:solid 1px #D0C2B4;
	
	}
.table_detail_bottom_container{
	width:100%;
	height:50px;
	float:left;
	border:solid 1px #ccc;
	}	
