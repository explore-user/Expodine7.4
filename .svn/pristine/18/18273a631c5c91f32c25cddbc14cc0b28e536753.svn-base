<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<title>Maintenance</title>
</head>
<style>
body{margin:0;padding:0;background-color: #dedede;}
.main_div{width:100%;height:auto;float:left}
.contant_container_cc{width:350px;height:auto;margin:auto;border:solid 1px #ccc;padding-top:50px;padding-bottom:50px;overflow:auto;margin-bottom:20px;margin-top:8%;background-color:#fff;border-radius:20px;}
.contant_container_logo{width:100%;height:150px;float:left;text-align:center;}
.contant_container_text{width:100%;height:auto;float:left;text-align:center;}
.contant_container_text h3{font-size:30px;color:#4a4a4a;text-align:center;height:60px;line-height:80px;font-family:Arial, Helvetica, sans-serif;margin:0;margin-top:10px;}
.contant_container_text p{font-size:15px;color:#a0a0a0;text-align:center;height:30px;line-height:30px;font-family:Arial, Helvetica, sans-serif;margin-top: 0;}
.contant_container_logo img{border-radius: 50%;border: solid 3px #fff;box-shadow: 0px 0px 5px #666;}
</style>
<body>
    <div class="main_div">
    	<div class="contant_container_cc">
        	<div class="contant_container_logo"><img src="img/expodine_logo_round.png" /></div>
            <div class="contant_container_text">
             	<h3>Stopped</h3>
                <p>Please contact service provider</p>
            </div>
        </div>
    </div>
</body>
</html>
