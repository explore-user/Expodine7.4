                                                                 <div style="position:absolute;right: 227px;  top: 11px;  color: #ff1100;font-weight: bold" id="ipping" ></div> 
                                                                <script>
                                                                    $("#sendiptest").click(function() {
                                                                        
                                                                       var ipvalue=$("#iptest").val();
                                                                       
                                                                       if(ipvalue!=''){
                                                                           
                                                                    var dataString = 'ipvalue='+ipvalue;
                                                                    $.ajax({
                                                                        type: "POST",
                                                                        url: "load_pingip.php",
                                                                        data: dataString,
                                                                         beforeSend: function() {
                                                                    $('#ipping').show();
                                                                    $('#ipping').text('Please Wait...');
                                                                    
                                                                             },  
  

                                                                        success: function(data) {
                                                                          
                                                                           $('#ipping').show();
                                                                            $('#ipping').html(data);
                                                                           $('#ipping').fadeOut(3000).slow();
                                                                        }
                                                                    });
                                                                }else{
                                                                     $("#iptest").focus();
                                                                     $('#ipping').show();
                                                                     $('#ipping').html('ENTER IP ADDRESS');
                                                                     $('#ipping').fadeOut(3000).slow();
                                                                     
                                                                     
                                                                }

                                                                          
                                                                            });
