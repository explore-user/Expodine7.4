   function clear_table_orders_pending(){
      
       var confirm1=confirm("  CLEAR PENDING ORDERS IN DINE-IN ?");
    if(confirm1===true){
      var data123="set=clear_table_pending";
      
       $.ajax({
            type: "POST",
            url: "troubleshoot.php",
            data: data123,
            success: function(data) {
               
              $("#dayrevertpopup").show();
              $('.dayalready_closed_popup_text').html('CLEARED ALL PENDING ORDERS');
              $("#dayrevertpopup").fadeOut(4000); 
               setInterval(function () {
                 location.reload();
                }, 2500);
           
    }
        });
   }     
   } 
   
   
   function sale_delete(){
       
       
       
         if($('#from_date').val()!='' && $('#to_date').val()!=''){
             
          var confirm1=confirm(" CONFIRM THE DATE . SALES DATA ON DATE WILL  BE REMOVED FROM SOFTWARE ?");
       
    if(confirm1===true){
        
      
       var date_in1=$('#from_date').val().split('/');   
      var date_in2=$('#to_date').val().split('/');   
             
          $("#dayrevertpopup").show();
     
       $('.dayalready_closed_popup_text').html('DATA REMOVAL IN PROGRESS...'); 
           
           
           
       var from=date_in1[0];
       
        var to=date_in2[0];
       
       
       
       
       var data123="set=sale_delete_datewise&from="+from+"&to="+to;
      
            $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data123,
            success: function(data) {
                
               
     
                $('.dayalready_closed_popup_text').html('DATA REMOVED SUCCESFULLY'); 
                
                $("#dayrevertpopup").fadeOut(3000); 
                
            setTimeout(function(){
         
            location.reload();
        
             }, 3000); 
                
                 
                
            }
        });
        
            }
        
        
    }else{
        alert('SELECT FROM AND TO DATE');
        
    }
    
    
    
   }
   
   
   function go_sync(){
       
       
       
         if($('#sync_date').val()!=''){
             
          var confirm1=confirm(" CONFIRM THE SYNC START DATE . SALES DATA BEFORE DATE WILL NOT BE SYNCED?");
       
    if(confirm1===true){
        
      
       var date_in1=$('#sync_date').val().split('/');   
             
             
       var date_in=date_in1[0];
       
       var data123="set=go_sync&date_to="+date_in;
      
       $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data123,
            success: function(data) {
                
                
                setInterval(function () {
                 location.reload();
                }, 1000);
               
               
            }
        });
        
            }
        
        
    }else{
        alert('SELECT CLOUD SYNC START DATE');
        
    }
    
    
    
   }
   
   function load_printer_all(){
       
              window.location.href='load_printerstatus.php?value=full_load'  
         
   }
   
   
