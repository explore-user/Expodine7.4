        $('.pop_head_new').hide();
      $('.shortcut_pop_data').hide();
      $('.db_size_view_popup_cc').show();
      var data123="set=get_db_size";
      
       $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data123,
            success: function(data) {
             
           $('#load_db_size').html(data);   
           
           
           var data1234="set=get_db_size_valid";
           $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data1234,
            success: function(data) {
                 $('#load_db_size_valid').html(data);   
                
            }
        });
           
    }
        });
        
   }   
   function get_shortcuts(){
       $('.shortcut_pop').show();
       $('.db_size_view_popup_head').hide();
            
         $('.db_size_view_popup_contant').hide();
         $('.pop_head_new').show();
        $('.shortcut_pop_data').show();
   }
   
   function close_db_size(){
       location.reload();
        
   }
   
   
