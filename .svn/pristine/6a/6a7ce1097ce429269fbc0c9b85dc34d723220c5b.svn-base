/**check box**/
.printer_mode_select{
	width:100%;
height:auto;
float:left;}

.printer_mode_select ul li{
  color: #AAAAAA;
  display: block;
  position: relative;
  float: left;
  width: 41%;
  height:70px;
}

.printer_mode_select ul li input[type=radio]{
  position: absolute;
  visibility: hidden;
}

.printer_mode_select ul li label{
  display: block;
  position: relative;
  font-weight: 300;
  font-size: 1.35em;
 padding: 15px 25px 25px 0px;
    margin: 8px auto;
    font-weight: bold;
  height: 30px;
  z-index: 9;
  top:0;
  cursor: pointer;
  -webkit-transition: all 0.25s linear;
  color:#666;
}

.printer_mode_select ul li:hover label{
	color: #000;
}

.printer_mode_select ul li .check{
  display: block;
  position: absolute;
  border: 5px solid #AAAAAA;
  border-radius: 100%;
  height: 35px;
  width: 35px;
  top: 20px;
  left: 20px;
	z-index: 5;
	transition: border .25s linear;
	-webkit-transition: border .25s linear;
}

.printer_mode_select ul li:hover .check {
  border: 5px solid #000;
}

.printer_mode_select ul li .check::before {
  display: block;
  position: absolute;
	content: '';
  border-radius: 100%;
  height: 15px;
  width: 15px;
  top: 5px;
	left: 5px;
  margin: auto;
	transition: background 0.25s linear;
	-webkit-transition: background 0.25s linear;
}

.printer_mode_select input[type=radio]:checked ~ .check {
  border: 5px solid #d41d00;
}

.printer_mode_select input[type=radio]:checked ~ .check::before{
  background: #d41d00;
}

.printer_mode_select input[type=radio]:checked ~ label{
  color: #000;
}

/**end**/



/**ios type checkbox**/

.priner_add_status_checkbox_cc input[type="checkbox"] { /* :root here acting as a filter for older browsers */
	position: absolute;
	opacity: 0;
}

.priner_add_status_checkbox_cc input[type="checkbox"].ios-switch + div {
	display: inline-block;
	vertical-align: middle;
	width: 3em;	height: 1em;
	border: 1px solid rgba(0,0,0,.3);
	border-radius: 999px;
	margin: 0 .5em;
	background: white;
	background-image: linear-gradient(rgba(0,0,0,.1), transparent),                    
					  linear-gradient(90deg, hsl(6, 63%, 46%) 50%, transparent 50%);
	background-size: 200% 100%;
	background-position: 100% 0;
	background-origin: border-box;
	background-clip: border-box;
	overflow: hidden;
	transition-duration: .4s;
	transition-property: padding, width, background-position, text-indent;
	box-shadow: 0 .1em .1em rgba(0,0,0,.2) inset,
	            0 .45em 0 .1em rgba(0,0,0,.05) inset;
	font-size: 150%; /* change this and see how they adjust! */
}

.priner_add_status_checkbox_cc input[type="checkbox"].ios-switch:checked + div {
	padding-left: 2em;	/*width: 1.5em;*/
	background-position: 0 0;
}

.priner_add_status_checkbox_cc input[type="checkbox"].ios-switch + div:before {
	content: 'On';
	float: left;
	width: 1.65em; height: 1.65em;
	margin: -.1em;
	border: 1px solid rgba(0,0,0,.35);
	border-radius: inherit;
	background: white;
	background-image: linear-gradient(rgba(0,0,0,.2), transparent);
	box-shadow: 0 .1em .1em .1em hsla(0,0%,100%,.8) inset,
	            0 0 .5em rgba(0,0,0,.3);
	color: white;
	text-shadow: 0 -1px 1px rgba(0,0,0,.3);
	text-indent: -3.5em;
}

.priner_add_status_checkbox_cc input[type="checkbox"].ios-switch:active + div:before {
	background-color: #eee;
}

.priner_add_status_checkbox_cc:root input[type="checkbox"].ios-switch:focus + div {
	box-shadow: 0 .1em .1em rgba(0,0,0,.2) inset,
	            0 .45em 0 .1em rgba(0,0,0,.05) inset,
	            0 0 .4em 1px rgba(255,0,0,.5);
}

.priner_add_status_checkbox_cc input[type="checkbox"].ios-switch + div:before,
.priner_add_status_checkbox_cc input[type="checkbox"].ios-switch + div:after {
	font: bold 60%/1.9 sans-serif;
	text-transform: uppercase;
}

.priner_add_status_checkbox_cc input[type="checkbox"].ios-switch + div:after {
	content: 'Off';
	float: left;
	text-indent: .5em;
	color: rgba(0,0,0,.45);
	text-shadow: none;

}
.priner_add_status_checkbox_cc{
	width:100%;
	height:auto;
	float:left;
	margin-top:10px;
	position:relative;
	color:#000;
	font-size:18px;
	}

/**end**/

/***printer textboxeffect**/

/* active state */
.add_printer_drop{width:100%;height:35px;background-color:transparent;color:#000;border:0;border-bottom:1px #9e9e9e solid;font-size:18px; }
.printer_add_text_boxes_cc{width:100%;height:auto;float:left;margin-top:0px;}
.printer_add_text_boxes_cc .group 			  { 
  position:relative; 
  margin-bottom:10px; 
 width: 77%;
 margin-left: 11%;
}
.printer_add_text_boxes_cc label 				 {
  color:#999; 
  font-size:18px;
  font-weight:normal;
  position:absolute;
  pointer-events:none;
  left:5px;
  top:10px;
  transition:0.2s ease all; 
  -moz-transition:0.2s ease all; 
  -webkit-transition:0.2s ease all;
}
.printer_add_text_boxes_cc input{
  font-size:18px;
  padding: 15px 10px 5px 5px;
  display:block;
  width:372px !important;
  border:none;
  border-bottom:1px solid #9e9e9e;
  background-color:transparent;
      color: #000;
  }
.printer_add_text_boxes_cc input:focus ~ label, input:valid ~ label 		{
  top:-2px;
  font-size:14px;
  color:#5264AE;
}

/* BOTTOM BARS ================================= */
.printer_add_text_boxes_cc .bar 	{ position:relative; display:block; width:372px; }
.printer_add_text_boxes_cc .bar:before, .bar:after 	{
  content:'';
  height:2px; 
  width:0;
  bottom:1px; 
  position:absolute;
  background:#5264AE; 
  transition:0.2s ease all; 
  -moz-transition:0.2s ease all; 
  -webkit-transition:0.2s ease all;
}
.printer_add_text_boxes_cc  .bar:before {
  left:50%;
}
.printer_add_text_boxes_cc .bar:after {
  right:50%; 
}
.printer_add_text_boxes_cc input:focus{outline:none !important;}
/* active state */
.printer_add_text_boxes_cc input:focus ~ .bar:before, input:focus ~ .bar:after {
  width:50%;
}

/* HIGHLIGHTER ================================== */
.highlight {
  position:absolute;
  height:60%; 
  width:100px; 
  top:25%; 
  left:0;
  pointer-events:none;
  opacity:0.5;
}

/* active state */
input:focus ~ .highlight {
  -webkit-animation:inputHighlighter 0.3s ease;
  -moz-animation:inputHighlighter 0.3s ease;
  animation:inputHighlighter 0.3s ease;
}

/* ANIMATIONS ================ */
@-webkit-keyframes inputHighlighter {
	from { background:#5264AE; }
  to 	{ width:0; background:transparent; }
}
@-moz-keyframes inputHighlighter {
	from { background:#5264AE; }
  to 	{ width:0; background:transparent; }
}
@keyframes inputHighlighter {
	from { background:#5264AE; }
  to 	{ width:0; background:transparent; }
}


/****end****/	

