@font-face {
    font-family: 'yu_gothicregular';
    src: url('../fonts/yugothic-webfont.eot');
    src: url('../fonts/yugothic-webfont.eot?#iefix') format('embedded-opentype'),
         url('../fonts/yugothic-webfont.woff2') format('woff2'),
         url('../fonts/yugothic-webfont.woff') format('woff'),
         url('../fonts/yugothic-webfont.ttf') format('truetype'),
         url('../fonts/yugothic-webfont.svg#yu_gothicregular') format('svg');
    font-weight: normal;
    font-style: normal;

}

body{
	margin:0;
	padding:0;
	height: 100%;
    /*overflow-x: hidden;*/
    font-family: 'CALIBRI_0';
    font-weight: 100;
	background-color:#EDEDED !important;
	
	}
.navbar-default .navbar-brand{margin-left:7px;}	
.navbar {
  background-color: #191919 !IMPORTANT;
  background-image:none !important;
    border-radius: 0px !important;
  min-height: 57px !important;
  border: none !important;
  margin-bottom: 0px !important;
}	
.navbar-brand { padding: 3px 15px !important}
.btn_1 {margin-top: 9px;}
.sitemap_cc {
 width: auto;
       padding: 0 0 0 2%;
  height: 38px;
  margin: auto;
  text-align: center;
  color: #fff;
font-family: 'CALIBRI_0';
  font-size: 16px;
  position: absolute;
  z-index: 999;
  top: 9px;
      left: 280px;
}

  .container {
          position: relative;
          height: 100%;
          width: 100% !important;
          left: 0;
          -webkit-transition:  left 0.4s ease-in-out;
          -moz-transition:  left 0.4s ease-in-out;
          -ms-transition:  left 0.4s ease-in-out;
          -o-transition:  left 0.4s ease-in-out;
          transition:  left 0.4s ease-in-out;
      }
      .container.open-sidebar {
          left: 240px;
      }
      
      .swipe-area {
          position: absolute;
          width: 0px;
          left: 0;
      top: 0;
          height: 100%;
          z-index: 0;
      }
      #sidebar {
          background: #DF314D;
          position: absolute;
          width: 240px;
          height: 92vh;
          left: -240px;
		    z-index: 9;
          box-sizing: border-box;
          -moz-box-sizing: border-box;
      }
      #sidebar ul {
          margin: 0;
          padding: 0;
          list-style: none;
      }
      #sidebar ul li {
          margin: 0;
      }
      #sidebar ul li a {
          padding: 15px 35px;
          font-size: 16px;
          font-weight: 100;
          color: white;
          text-decoration: none;
          display: block;
          border-bottom: 1px solid #C9223D;
          -webkit-transition:  background 0.3s ease-in-out;
          -moz-transition:  background 0.3s ease-in-out;
          -ms-transition:  background 0.3s ease-in-out;
          -o-transition:  background 0.3s ease-in-out;
          transition:  background 0.3s ease-in-out;
      }
#sidebar ul li ul li a	 {
	font-size:12px;
	} 
      #sidebar ul li a:hover{
          background: #C9223D;
      }
      .main-content {
          width: 100%;
          height: 100%;
          padding: 0px;
          box-sizing: border-box;
          -moz-box-sizing: border-box;
          position: relative;
		  top: 2px;
  		   left: -15px;
      }
      .main-content .content{
          box-sizing: border-box;
          -moz-box-sizing: border-box;
      width: 100%;
      }
      .main-content .content h1{
          font-weight: 100;
      }
      .main-content .content p{
          width: 100%;
          line-height: 160%;
      }
      .main-content #sidebar-toggle {
          border-radius: 3px;
          display: block;
          position: relative;
          padding: 10px 7px;
            position: fixed;
		  top: 9px;
		  left: -10px;
      }
.main-content #sidebar-toggle:hover {margin-left:-5px;	 } 
      .main-content #sidebar-toggle .bar{
           display: block;
          width: 18px;
          margin-bottom: 6px;
          height: 2px;
          background-color: #fff;
          border-radius: 1px;   
      }
      .main-content #sidebar-toggle .bar:last-child{
           margin-bottom: 0;   
      }
	 #sidebar ul li ul li:hover a {background-color:rgba(255,255,255,0.2;) !important}
