.main_add_btn_menu_master{
  width: 13%;
  height: 35px;
  float: right;
  margin-top:1px;
	border-radius:3px;
	background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #EF3F00), color-stop(100%, #892A08));
  background-image: -webkit-linear-gradient(#E43535, #741010);
  background-image: -moz-linear-gradient(#E43535, #741010);
  background-image: -o-linear-gradient(#E43535, #741010);
    background-image: linear-gradient(#E43535, #741010);
	margin-left:10px;
	margin-right:1px;
	border-left:1px solid rgba(255,255,255,0.2);
	}
.main_add_btn_menu_master:hover{
  background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #EF3F00), color-stop(100%, #892A08));
  background-image: -webkit-linear-gradient(#fff, #ccc);
  background-image: -moz-linear-gradient(#fff, #ccc);
  background-image: -o-linear-gradient(#fff, #ccc);
  background-image: linear-gradient(#fff, #ccc);

	}				 
.main_add_btn_menu_master a{
	display:block;
	text-align:center;
	line-height:35px;
	font-size: 16px;
  	color: #fff;
 	padding: 0 3px 0 3px;
	}	
.main_add_btn_menu_master a:hover{text-decoration:none;color:#000 }
.main_add_btn_menu_master a:focus{text-decoration:none;color:#000 }		
	
.add_btn_menu_master{
	width:17%;
	height:35px;
	float:right;
	margin-top:1px;
	border-radius:3px;
	background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #EF3F00), color-stop(100%, #892A08));
  background-image: -webkit-linear-gradient(#EF3F00, #892A08);
  background-image: -moz-linear-gradient(#EF3F00, #892A08);
  background-image: -o-linear-gradient(#EF3F00, #892A08);
  background-image: linear-gradient(#EF3F00, #892A08);
	margin-left:10px;
	margin-right:1px;
	border-left:1px solid rgba(255,255,255,0.2);
	}
.add_btn_menu_master:hover{
  background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #EF3F00), color-stop(100%, #892A08));
  background-image: -webkit-linear-gradient(#333, #666);
  background-image: -moz-linear-gradient(#333, #666);
  background-image: -o-linear-gradient(#333, #666);
  background-image: linear-gradient(#333, #666);
	}				 
.add_btn_menu_master a{
	display:block;
	text-align:center;
	line-height:35px;
	font-size:18px;
	color:#fff;
	}	
.add_btn_menu_master a:hover{text-decoration:none;color:#ccc }
.add_btn_menu_master a:focus{text-decoration:none;color:#ccc }	

