.completed_order_tab_btn{
	padding:0 15px 0 15px;
	height:48px;
	float:left;
	text-align:center;
	line-height:48px;
	color:#000;
	cursor:pointer;
	border-right:solid 1px #ccc;
	border-left:solid 1px #ccc;
	background-color:#fff;
	  -moz-box-shadow: 0px 4px 7px #ccc;
  -webkit-box-shadow: 0px 4px 7px #ccc;
  box-shadow: 0px 2px 6px #ccc;
  margin-right:5px;
  position:relative;
  	border-bottom:3px solid #F5351B;
	}
.completed_order_tab_btn::before{
content: "";
  position: absolute;
  top:-4;
  right: 0;
   border-width: 0 15px 15px 0;
  border-style: solid;
  border-color: #ffffff rgba(236, 236, 236, 1);
  -webkit-box-shadow: 0 0 0 rgba(0, 0, 0, 0.4), 0 0 10px rgba(0, 0, 0, 0.3);
