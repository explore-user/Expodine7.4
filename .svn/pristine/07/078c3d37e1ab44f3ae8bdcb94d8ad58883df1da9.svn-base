#outer-left {
    -ms-transform: skew(0deg, 0deg);
    /* IE 9 */
    -webkit-transform:skew(0deg, 0deg);
    /* Chrome, Safari, Opera */
    transform: skew(0deg, 0deg);
     background: rgba(255,255,255,0.3);
  width: 100%;
  margin-bottom:0px;
  cursor:pointer;
  z-index: 20;
   padding: 6px 25px 8px 72px;
  font-size: 15px;
  text-align: center;
  padding-left: 20px;
  color: #fff;
    position:relative;
    left:3px;
	 transition: all .2s ease-out;
	-webkit-transition: all .2s ease-out;
	-moz-transition: all .2s ease-out;
	-o-transition: all .2s ease-out;
}
#outer-left:after {
    content:"";
    display:inline-block;
    position:absolute;
    width:10px;
    height:100%;
     background: rgba(255,255,255,0.3);
    float:right;
    right:0px;
    top:0px;
    z-index:10;
}

#inner-left {
    -ms-transform: skew(0deg, 0deg);
    /* IE 9 */
    -webkit-transform: skew(0deg, 0deg);
    /* Chrome, Safari, Opera */
    transform: skew(0deg, 0deg);
    display:inline-block;
}
#outer-center {
    background:#333333;
    width:200px;
    z-index:20;
    border-bottom:3px solid #2E8DEF;
    padding:10px 20px;
    font-size:20px;
    color:#2E8DEF;
    position:relative;
    text-align:center;
}
#outer-center:after {
    content:"";
    display:inline-block;
    position:absolute;
    width:28px;
    height:calc(100% + 3px);
    background:#2E8DEF;
    float:right;
    right:-14px;
    top:0px;
    z-index:10;
    -ms-transform: skew(0deg, 0deg);
    /* IE 9 */
    -webkit-transform: skew(0deg, 0deg);
    /* Chrome, Safari, Opera */
    transform: skew(0deg, 0deg);
}
#outer-left:hover{background: rgba(255,255,255,0.5);}
