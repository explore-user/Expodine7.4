.reserved_time{
	width:42%;
	height:18px;
	position:absolute;
	background-color:#f00;
	color:#fff;
	top:50px;
	left:40px;
	 border-radius: 5px;
	line-height:18px;
	text-align:center;
	-ms-transform: rotate(-8deg); /* IE 9 */
	-moz-transform: rotate(-8deg); /* IE 9 */
    -webkit-transform: rotate(-8deg); /* Chrome, Safari, Opera */
    transform: rotate(-8deg);
	}
	
