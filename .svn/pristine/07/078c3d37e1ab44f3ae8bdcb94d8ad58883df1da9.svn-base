.button_popup{
font-family: 'CALIBRI_0';
  background: #F5351B;
  text-transform: uppercase;
  box-shadow: inset 0 -34px 33px -20px #8E1302;
  color: #FFF;
  text-shadow: 0 1px 0 #8E1302;
  float: right;
  font-size: 1.3em;
  bottom: 0;
  width: 100%;
  position: absolute;
  cursor: pointer;
  padding: 7px;
  left:0px;
  box-sizing: border-box;
  text-align: center;
  font-size: 1.8em;
}.button_popup:hover{box-shadow: inset 0 34px 33px -20px #8E1302;}
