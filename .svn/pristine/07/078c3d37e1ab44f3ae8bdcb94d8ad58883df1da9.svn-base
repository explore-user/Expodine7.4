.top_menu_cc{
	width:100%;
	height:auto;
	float:left;
	position:relative;
	margin-top:0px;
  margin-bottom: 5px;
	background-color: rgba(255, 255, 255, 0.2);
	z-index:99;
	/*  border-bottom: 1px rgba(188,150,98,0.5) Solid;
  border-top: 1px rgba(188,150,98,0.5) Solid;*/
	}
.top_menu_cc ul{
	margin:0;
	padding:0;
	}		
.top_menu_cc li{
	width:auto;
	float:left;
	list-style:none;
	margin-right:5px;
	 /* background: rgba(144, 88, 31, 0.1);*/
	  padding:7px 10px;
	 border-right: 5px solid rgba(255, 255, 255, 0.3);
	   transition: all .2s ease-out;
	-webkit-transition: all .2s ease-out;
	-moz-transition: all .2s ease-out;
	-o-transition: all .2s ease-out;
	}
	
.top_menu_cc li:hover{ border-right:5px solid rgba(245, 53, 27,0.4); background: rgba(88, 122, 124, 0.9);}	
.top_menu_cc li a{color:#fff;text-align:center;font-size:14px;display:block;}
.top_menu_cc li a:hover{text-decoration:none}

.top_menu_cc ul li ul {
  padding: 0;
  position: absolute;
  top: 40px;
  left: 0;
  width: 150px;
  -webkit-box-shadow: none;
  -moz-box-shadow: none;
  box-shadow: none;
  display: none;
  opacity: 0;
  visibility: hidden;
  -webkit-transiton: opacity 0.2s;
  -moz-transition: opacity 0.2s;
  -ms-transition: opacity 0.2s;
  -o-transition: opacity 0.2s;
  -transition: opacity 0.2s;
}
.top_menu_cc  ul li ul li { 
  background: rgba(190, 50, 22, 0.8);
  display: block;
  width: 100%;
  width: 100%;
  color: #fff;
  text-shadow: 0 -1px 0 #000;
}
.top_menu_cc  ul li ul li:hover { background: rgba(63,63,63,0.8); }
.top_menu_cc  ul li:hover ul {
  display: block;
  opacity: 1;
  visibility: visible;
}

		
