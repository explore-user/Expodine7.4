.logout_kot{
	width:125px;
	height:35px;
	float:right;
	cursor:pointer;
	color:#fff;
	background-repeat:no-repeat;
	font-size:14px;
	padding: 3px 0px 0 25px;
	border-radius:8px;
 	background-color: rgba(255,255,255,0.1);
	background-image:url(../img/logout.png);
	background-position: 90px 4px;
	margin:8px 10px 0 0;
	transition:all .3s ease-in;
	-webkit-transition:all .3s ease-in;
	-moz-tarnsition:all .3s ease-in;
	-ms-tarnsition:all .3s ease-in;
	-o-tarnsition:all .3s ease-in;
	}
.logout_kot:hover{ background-color: rgba(255,255,255,0.2);}
