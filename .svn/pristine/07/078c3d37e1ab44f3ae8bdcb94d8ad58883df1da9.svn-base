.table_sum_popup_button{
	min-width: 125px;
  min-height: 40px;
  line-height:40px;
  margin: 0 0 20px;
  outline: 0;
  border: 1px solid #09707b;
  border-width: 0 0 3px;
  -webkit-border-radius: 3px;
  -moz-border-radius: 3px;
  border-radius: 3px;
  padding: 0 10px;
  background: #0b8593;
  color: #fff;
font-family: 'CALIBRI_0';
  font-size: 1.2em;
  font-weight: 400;
  font-variant: normal;
  text-align: center;
  text-transform: none;
  cursor:pointer;
  letter-spacing: 0;
  -webkit-transition: all .2s ease-in-out;
  -moz-transition: all .2s ease-in-out;
  -o-transition: all .2s ease-in-out;
  -ms-transition: all .2s ease-in-out;
  transition: all .2s ease-in-out;
	}
