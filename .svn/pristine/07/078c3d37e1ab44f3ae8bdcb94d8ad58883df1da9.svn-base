/**date and time css**/
.datebox_container{
	width:100%;
	height: auto;
    padding-bottom: 5px;
	/*background-color: rgba(255, 255, 255, 0.1);*/
	background-color: rgba(86, 131, 140, 0.35);
	margin-top: 65px;
	text-align:center;
	overflow:hidden;
	box-shadow: 0px 0px 20px #091925;
	border-bottom: 4px rgba(197, 151, 78, 0.75) solid;
	-webkit-box-shadow: 0px 0px 20px #091925;
	-moz-box-shadow: 0px 0px 20px #091925;
	}
.day_start_close_cc{
	width:100%;
	height: 13px;
    margin-bottom: 4px;
	float:left;
	/*border-bottom:solid 1px rgba(255,255,255,0.1);*/
	line-height: 16px;
    font-size: 14px;
	color:#fff;
	text-align:center;
	
	}
.day_start_close_cc span{background-color:#997738; padding: 0 2%;}	
.day_start_cc{
	width:100%;
	height:15px;
	float:left;
	line-height:15px;
	color:#fff;
	
	}	
.day_close_cc{
	width:100%;
	height:15px;
	float:left;
	line-height:15px;
	color:#fff;
	text-align:center;
	}			
.date_time_cc{
	width:33%;
	height:50px;
	display:inline-block;
	    float: left;
	}	
.date_time_text{
	width:13%;
	height:35px;
	float:left;
	text-align:left;
	font-size:14px;
	color:#fff;
	line-height:35px;
font-family: 'CALIBRI_0';
	}
.date_time_textbox{
	width:30%;
	height:35px;
	float:left;
	}
.date_time_textbox input{
	width:95%;
	height:27px;
	float:left;
	border:solid 1px #909090;
	padding-left:5px;
	font-size:15px;
	margin-top:5px;
	border-radius:5px;
	background-color:rgba(255,255,255,0.1);
	color:#fff;
	}	
.date_time_btn{
	width:90%;
	height:29px;
	float:left;
	margin-top:3px;
	border-radius:5px;
	background-color:#DC4632;
	color:#fff;
	text-align:center;
	line-height:29px;
	}
.date_time_btn:hover{background-color:#AB8E43;color:#fff;text-decoration:none;box-shadow:0 0 3px #ccc;}		
.date_error{text-align:center;color:#f00;font-size:14px;    font-weight: bold;}

.confrmation_overlay{
	width:100%;
	height:100%;
	position:fixed;
	z-index:999;
	background-color:rgba(0,0,0,0.8);
	top:0;
		}
.index_popup_1{
	width:35%;
	height:85px;
	position:absolute;
	margin:auto;
	background-color:#fff;
	border-radius:5px;
	box-shadow:0 0 5px #ccc;
	right:0;
	left:0;
	top:0;
	bottom:0;
	z-index:9999;
	overflow:hidden;
	}
.index_popup_del{
	width:35%;
	height:80px;
	position:absolute;
	margin:auto;
	background-color:#fff;
	border-radius:5px;
	box-shadow:0 0 5px #ccc;
	right:0;
	left:0;
	top:0;
	bottom:0;
	z-index:9999;
	overflow:hidden;
	}
.index_popup_contant{
	width:100%;
	height:40px;
	float:left;
	text-align:center;
	line-height:40px;
	font-size: 16px;
	}		
.btn_index_popup{
    width: 18%;
    display: inline-block;
    height: 30px;
    line-height: 30px;
	background-color: #FF2306;
	text-align:center;
	margin-right:1%;
	border-radius:5px;
	transition:all 0.2s ease;
	}
.btn_index_popup a{
	color:#fff !important;
	font-size:15px;	
	text-decoration:none;
	display:block;
	}		
.btn_index_popup:hover{background-color:#333;}	
.btn_index_popup a:hover{color:#fff;}

.index_popup_2{
	width:35%;
	height:40px;
	position:absolute;
	margin:auto;
	background-color:#fff;
	border-radius:5px;
	box-shadow:0 0 5px #ccc;
	right:0;
	left:0;
	top:0;
	bottom:0;
	z-index:9999;
	overflow:hidden;
	}
.index_popup_contant span{	
	width: 73%;
    float: left;	
	}
.kotcancel_reason_popup .index_popup_contant span{float:none}
