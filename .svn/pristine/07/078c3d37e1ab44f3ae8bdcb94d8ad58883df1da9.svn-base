.home_back #outer-left{text-align:left;padding-left:8px;-ms-transform: skew(0deg, 0deg);-webkit-transform: skew(0deg, 0deg);transform: skew(0deg, 0deg);}
.home_back #inner-left{-ms-transform: skew(0deg, 0deg);-webkit-transform: skew(0deg, 0deg);transform: skew(0deg, 0deg);}
