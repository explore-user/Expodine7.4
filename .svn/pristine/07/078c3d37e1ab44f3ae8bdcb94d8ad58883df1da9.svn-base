}

.waiter_select_popup{
	width: 450px;
    float: left;
    height: auto;
    float: left;
    background-color: #fff;
    border-radius: 5px;
    position: fixed;
    left: 0;
    right: 0;
    top:20%;
    margin: auto;
    z-index: 99999;
	padding-bottom:10px;
	display:none;
	}
	
.waiter_select_popup_close_btn {
    width: 30px;
    height: 30px;
    position: absolute;
    right: 0;
    top: 0;
    background-image: url(../img/cancel-icon.png);
    background-size: 100%;
    cursor: pointer;
}
.waiter_select_popup_headding {
    width: 100%;
    height: 50px;
    float: left;
    line-height: 50px;
    text-align: center;
    font-size: 20px;
    color: #000;
    font-family: Arial, Helvetica, sans-serif;
    margin-top: 10px;
}

.waiter_select_popup_headding_text {
    width: 100%;
    height: 20px;
    float: left;
    line-height: 0px;
    text-align: center;
    font-size: 13px;
    color: #666;
    font-family: 'CALIBRI_0';
}

.waiter_select_popup_contant {
    width: 95%;
    height: auto;
    float: left;
    text-align: center;
	margin-left:2%;
}
.waiter_select_popup_ok_btn_cc {
    width: 100%;
    height: auto;
    float: left;
    text-align: center;
    margin-top: 7px;
}
.waiter_select_popup_ok_btn {
    width: 111px;
    height: 33px;
    display: inline-block;
    border-radius: 20px;
    background-color: #C9090C;
    text-align: center;
    line-height: 33px;
    color: #fff;
    font-size: 16px;
    font-family: 'CALIBRI_0';
    cursor: pointer;
}
.waiter_select_btn{
	width:auto;
	float:none;
	display:inline-block;
	padding:2% 15px;
	line-height:22px;
	font-size:14px;
	color:#000;
	border:solid 1px #ccc;
	border-radius:10px;
	box-shadow: 0px 0px 6px #E4E4E4;
    -webkit-box-shadow: 0px 0px 6px #E4E4E4;
    -moz-box-shadow: 0px 0px 6px #E4E4E4;
	margin:1.5%;
	}
.waiter_select_btn:hover{background-color:bisque}
.waiter_select_btn_act{background-color:bisque}	
.waiter_select_popup_ok_btn:hover{color:#fff;text-decoration:none;background-color:#750000}


