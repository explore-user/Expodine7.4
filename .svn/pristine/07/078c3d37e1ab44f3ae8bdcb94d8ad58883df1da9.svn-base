.tabe_sum_button{
	width:190px;
	height:70px;
	display:inline-block;
	margin:20px 20px 3px 0px !important;
	 /*border-bottom: 3px solid #163543  !important;*/
	 color:#fff !important;
	 text-align:center !important;
	 font-size:21px;
	 outline:none !important;
	 line-height:63px;
	 cursor:pointer;
	 background-repeat:repeat-x;
  border: solid 1px rgba(255,255,255,0.4);
	/*background-image: -webkit-gradient(linear, left top, left bottom, from(rgba(23, 97, 182, 0.2)), to(#3A6683));
  	background-image: -webkit-linear-gradient(top, rgba(23, 97, 182, 0.2), #3A6683); 
 	background-image: -moz-linear-gradient(top, rgba(23, 97, 182, 0.2)), #3A6683);  
  	background-image: -ms-linear-gradient(top, rgba(23, 97, 182, 0.2), #3A6683); 
  	background-image: -o-linear-gradient(top, rgba(23, 97, 182, 0.2), #3A6683);
  	background-image: linear-gradient(to bottom, rgba(23, 97, 182, 0.2), #285c7e);*/
	background-color:rgba(6,24,39,0.4);
	-moz-box-shadow: 0px 0px 9px #ffffff;
-webkit-box-shadow: 0px 0px 9px #ffffff;
box-shadow: 0px 0px 9px #ffffff;
	border-radius:5px;
	 transition: all .2s ease-out !important;
  -webkit-transition: all .2s ease-out !important;
  -moz-transition: all .2s ease-out !important;
  -o-transition: all .2s ease-out !important;
	}
