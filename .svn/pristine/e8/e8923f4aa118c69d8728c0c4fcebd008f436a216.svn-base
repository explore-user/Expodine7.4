<script>
    
    $(".right_mn_btn").click(function(){
        $(".right_slide_menu_sec").show();
    });
    $(".right_mn_close").click(function(){
        $(".right_slide_menu_sec").hide();
    });


function comp_bill(mn,ord,p,u,b,bw,sl){
    var check = confirm("MARKED ITEM WILL BE COMPLIMENTARY . NO RATE WILL BE INCLUDED IN BILL ?");
	if(check==true)
	{
    
       if($("#comp_bill_"+mn+'_'+sl).prop('checked') == true){
            var chk='yes';
        }else{
             var chk='no';
        }
        
      
          var matches =  $('.comp_bill:checkbox:not(":checked")').length;
      
      if(matches>0){
                var dataString2 = 'set=comp_item_setup&mode=TA&menuid='+mn+"&type=plus&order_id="+ord+"&portion="+p+"&unit="+u+"&base="+b+"&baseweight="+bw+"&sl_no="+sl+"&chk="+chk;
				
                            $.ajax({
				type: "POST",
				url: "load_index.php",
				data: dataString2,
				success: function(data2) {
                     
                     location.reload();
                          
                 }
    });
    
    }else{
              
                $("#comp_bill_"+mn+'_'+sl).attr('checked',false);
                 
               
                alert('ONE ITEM SHOULD BE THERE FOR BILL PRINT WITH RATE ')
            }
    
    
        }else{
          // $("#comp_bill_"+mn+'_'+sl).attr('checked',false);
           location.reload();
        }
    
    }




    function single_cart(mn,p,stk){
        
        var food= $('.online_order_box_act').attr('food_val');
        
         $('.pref_key_entry').val('');
            
                var dataString2 = 'set=check_single_click_cart&mode=TA&menuid='+mn+"&partner="+food+"&stk="+stk;
				
                            $.ajax({
				type: "POST",
				url: "load_index.php",
				data: dataString2,
				success: function(data2) {
                                
                               if($.trim(data2) !='no' && $.trim(data2) !='nostock') {
                                       
                  var decimal=$('#decimal').val();                         
                  var det=$.trim(data2).split('*');         
                  var rate= parseFloat(det[0]).toFixed(decimal); 
                  var portion= parseFloat(det[1]); 
                
                                               
                      $('.product_img').removeClass('take_item_active');  
                      
	    var  dataString = 'value=menusubmission&menuid='+mn+"&portion="+portion+"&rate="+rate+"&qty=1&preferncetext=&mode=Add&order_from=TA&ratetype=Portion&unittype=&unitweight=&baseunitweight=&unitid=&baseunitid=&serialno=&addon=&food="+food;
        
        
                            $.ajax({
				type: "POST",
				url: "load_takeaway.php",
				data: dataString,
				success: function(data) {
                                    
                         
       
                                             var dataString1;
						dataString1 = 'value=orderlistload';
						var request=  $.ajax({
						type: "POST",
						url: "load_takeaway.php",
						data: dataString1,
						success: function(data) {
								$('#ta_orderlist').html(data);
                                                                
                          $('.ta_errormsg').css("display",'block');
			  $('.ta_errormsg').text("ITEM ADDED ");
			  $('.ta_errormsg').delay(500).fadeOut('slow');
                            
                         }
                                                        });
        
        
                             
            }
        });
        
        
                                }else{
                            $('.alert_error_popup_all_in_one').show();
                                    
                        if($.trim(data2)=='nostock'){
                            
                        $('.alert_error_popup_all_in_one').text('NO STOCK IN INVENTORY');
                        
                        }else{
                            
                           $('.alert_error_popup_all_in_one').text('PLS ADD RATE ');  
                        }
                        
                        $('.alert_error_popup_all_in_one').delay(1000).fadeOut('slow');  
                                }
        
        
        
         }
        });
   $('#searchb').focus();
   }
   
   
     function minus_single(mn,ord,qty,p,u,b,bw,sl){
         
        $(".minus_button_ta").css('pointer-events','none');
      
         if(qty >=2 ){   
            
                var dataString2 = 'set=single_click_cart_qty&mode=TA&menuid='+mn+"&type=minus&order_id="+ord+"&portion="+p+"&unit="+u+"&base="+b+"&baseweight="+bw+"&sl_no="+sl;
				//alert(dataString);
                            $.ajax({
				type: "POST",
				url: "load_index.php",
				data: dataString2,
				success: function(data2) {
                          
                            $('.ta_errormsg').css("display",'block');
			  $('.ta_errormsg').text("QTY CHANGED ");
			  $('.ta_errormsg').delay(500).fadeOut('slow');

                     $(".minus_button_ta").css('pointer-events','inherit');       
                          
             var dataString1;
						dataString1 = 'value=orderlistload';
						var request=  $.ajax({
						type: "POST",
						url: "load_takeaway.php",
						data: dataString1,
						success: function(data) {
								$('#ta_orderlist').html(data);
                                                            }
                                                        });
        
         }
         
        });
        
       
        }else{
                         $('.alert_error_popup_all_in_one').show();
                                    
                        $('.alert_error_popup_all_in_one').text('MINIMUM QTY IS ONE');
                        $('.alert_error_popup_all_in_one').delay(1000).fadeOut('slow');
                        
                        $(".minus_button_ta").css('pointer-events','inherit'); 
         }
      
        $('#searchb').focus();
           
     }   
   function plus_single(mn,ord,p,u,b,bw,sl){
       
       
       var dataString1 = 'set=check_plus_cart_stock&menuid='+mn+"&qty=1&weight=1&mode=ta&type=plus&mode_in=Edit";
	var request=  $.ajax({
	type: "POST",
	url: "load_index.php",
	data: dataString1,
	success: function(data) { 
            //counter_menu_popup alert(data);
            if($.trim(data)=='OK'){
       
            
                var dataString2 = 'set=single_click_cart_qty&mode=TA&menuid='+mn+"&type=plus&order_id="+ord+"&portion="+p+"&unit="+u+"&base="+b+"&baseweight="+bw+"&sl_no="+sl;
				
                            $.ajax({
				type: "POST",
				url: "load_index.php",
				data: dataString2,
				success: function(data2) {
                          
                            $('.ta_errormsg').css("display",'block');
			  $('.ta_errormsg').text("QTY CHANGED ");
			  $('.ta_errormsg').delay(500).fadeOut('slow');

                                var dataString1;
						dataString1 = 'value=orderlistload';
						var request=  $.ajax({
						type: "POST",
						url: "load_takeaway.php",
						data: dataString1,
						success: function(data) {
								$('#ta_orderlist').html(data);
                                                            }
                                                        });
        
         }
        });
   $('#searchb').focus();
   
   
   }else{
                        $('.alert_error_popup_all_in_one').show();
                        
                        $('.alert_error_popup_all_in_one').text('NO STOCK IN INVENTORY');
                       
                        $('.alert_error_popup_all_in_one').delay(1000).fadeOut('slow');  
            
        }
                          
        }
        });   
   
   }
   
   function reorder_cancel(bill){
       
                          $('.ta_errormsg').css("display",'block');
			  $('.ta_errormsg').text("REORDER CANCELLED ");
			  $('.ta_errormsg').delay(1000).fadeOut('slow');
                          
