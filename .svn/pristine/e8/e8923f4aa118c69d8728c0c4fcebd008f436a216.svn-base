function barcode_entry(){
      
       
      var barcode = $("#searchb").val(); 
   
         
      var food= $('.online_order_box_act').attr('food_val');    
        
        if(barcode!=''){
                 
              var br_code=barcode.split('#');
                 
             
               if(br_code[1]!='' && br_code[1]!=undefined && br_code[1]!='undefined' ){
               
               var new_menu1=br_code[0].substr(0,4);
              
               var qty='1';
               
               var new_menu=  parseInt(new_menu1, 10);
               
               var weight_in=br_code[1].substr(0,5);
               
               var new_weight=(weight_in*1/1000);
              
               var dataString23 = 'set=check_barcode_plu&plu='+new_menu;
				
                            $.ajax({
				type: "POST",
				url: "load_takeaway.php",
				data: dataString23,
				success: function(data23) {
               var mn_plu=$.trim(data23);
            
               var dataString2 = 'set=check_barcode_ta&menuid='+mn_plu+"&food="+food;
				
                            $.ajax({
				type: "POST",
				url: "load_takeaway.php",
				data: dataString2,
				success: function(data2) {
                                    
            var det=$.trim(data2).split('*');         
            var rate= parseFloat(det[6])*parseFloat(new_weight);  
                
            var dataString = 'value=menusubmission&menuid='+mn_plu+"&portion=&rate="+rate+"&qty="+qty+"&preferncetext=&mode=Add&order_from=TA&ratetype="+det[0]+"&unittype="+det[1]+"&unitweight="+det[3]+"&baseunitweight="+new_weight+"&unitid="+det[4]+"&baseunitid="+det[5]+"&serialno=&addon=&food="+food;
            
                                $.ajax({
				type: "POST",
				url: "load_takeaway.php",
				data: dataString,
				success: function(data) {
                        
                                 location.reload();
                                 }
                                });
                 
         }
        });   
        
         }
        }); 
        
    }else{  
        
			var dataString = 'value=searchnameonly_barcode&term='+barcode;
			$.ajax({
			type: "POST",
			url: "load_takeaway.php",
			data: dataString,
			success: function(data) { 
                        var a= JSON.parse(data);  
                            
                        var id= a[0].id;   
                      
                        $("#valueofsearch_menu").val(id);      
                      
                        if(id!='')
                        {         
                        
                                var menunames = $("#valueofsearch_menu").val();
                                var barcode = $("#search").val();
								
				$(".confrmation_overlay").css("display","block");
                                $('.bottom_edit_cc_popup').css("display","block"); 
                                  
				var request = $.ajax({
				url: "takeaway_popup.php",
				method: "POST",
                                data: {menu:menunames,typesub:'Add',food:food,barcode:barcode},
				
				dataType: "html"
				});
										 
				request.done(function( msg ) { 
                                    
				$("#ta_loadbottomcontent-1" ).html(msg);
				$("#searchb").val('');
                                $('#searchb').blur();
                                $("#valueofsearch_menu").val('');
                                $("#searchb").focus();
                                $(".focussed").focus();
                                $(".enter-qty-act").val('1');
                                
                                $('.tasale_addnew').click();
                                
				});
										
				data = null;
				msg=null;
				request.onreadystatechange = null;
				request.abort = null;
				request = null;
				return false;
                            }
                     }  });
             
             
            }
        }
   }



