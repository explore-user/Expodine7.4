<script src="js/1-11-2-jquery.js"></script>
<script src="js/jquery.fancybox.js"></script>


<script>
  $(document).ready(function() {
      document.onkeydown = function(e){
          if (e.ctrlKey &&
              (e.keyCode === 67 ||
                  e.keyCode === 86 ||
                  e.keyCode === 85 ||
                  e.keyCode === 117)) {
              return false;
          } else {
              return true;
          }
      };
  });
  </script>

<script type="text/javascript">
  $("[data-fancybox]").fancybox({
    // Options will go here
  });



  $(document).keydown(function(e){
    if(e.which === 123){
       return false;
    }
});

  $(document).bind('contextmenu', function() 
    {
       // alert('no right click.');
        return false;
    });
  
    $("#exp_btn").click(function(){
      $("#expodine").show();
      $("#accounts").hide();
      $("#inventory").hide();

      $("#exp_btn").addClass("faq_top_btn_act");
      $("#acc_btn").removeClass("faq_top_btn_act");
      $("#inv_btn").removeClass("faq_top_btn_act");

  }); 
  $("#acc_btn").click(function(){
      $("#expodine").hide();
      $("#accounts").show();
      $("#inventory").hide();

      $("#exp_btn").removeClass("faq_top_btn_act");
      $("#acc_btn").addClass("faq_top_btn_act");
      $("#inv_btn").removeClass("faq_top_btn_act");
  }); 
  $("#inv_btn").click(function(){
      $("#expodine").hide();
      $("#accounts").hide();
      $("#inventory").show();

      $("#exp_btn").removeClass("faq_top_btn_act");
      $("#acc_btn").removeClass("faq_top_btn_act");
      $("#inv_btn").addClass("faq_top_btn_act");
  }); 
  </script>




<script>
  

jQuery(window).scroll(function() {
     var scroll =   jQuery(window).scrollTop();

        if (scroll >= 300) {
               jQuery(".scroll_fix").addClass("scroll-to-fixed-fixed");
          } else {
               jQuery(".scroll_fix").removeClass("scroll-to-fixed-fixed");
         }

         if (scroll >= 300) {
               jQuery(".scroll_fix_top").addClass("scroll-header-fixed-fixed");
          } else {
               jQuery(".scroll_fix_top").removeClass("scroll-header-fixed-fixed");
         }

});




var btn = $('#button');

$(window).scroll(function() {
  if ($(window).scrollTop() > 300) {
    btn.addClass('show');
  } else {
    btn.removeClass('show');
  }
});

btn.on('click', function(e) {
  e.preventDefault();
  $('html, body').animate({scrollTop:0}, '300');
});

</script>


  

