function check_mail(){
      $('.confrmation_overlay_proce').css('display','block');
    $('#sms_email_loader').html('<img src="img/ajax-loaders/ajax-loader.gif" />');
      var data1="set_mail=check_mail";
    
       $.ajax({
        type: "POST",
        url: "load_index.php",
        data: data1,
        success: function(data)
        {
            
           alert($.trim(data));
      
      location.reload();
        }
    });
}


function check_sms(){
      $('.confrmation_overlay_proce').css('display','block');
    $('#sms_email_loader').html('<img src="img/ajax-loaders/ajax-loader.gif" />');
    var data1="set_sms=check_sms";
    
       $.ajax({
        type: "POST",
        url: "load_index.php",
        data: data1,
        success: function(data)
        {
            alert($.trim(data));
            location.reload();
        }
    });
}


function view_logo(){
 $('#add_stock_pop').show();   
    
}


function auth_admin(){
       
    $('#add_stock_pop').show();
      $('#cus_div').hide();
       $('#admin_div').show();
       $('#code_change').val('');
    }
    
    
    function go_lock(){
    
    
         var data1234="set=check_otp_entered";
           $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data1234,
            success: function(data) {
                
                if($('#code_change').val()==$.trim(data)){
                    
                alert('PERMISSION GRANTED');
                
                window.location.href='upload_logo.php';
                
             }else{
            
                 alert('INVALID OTP'); 
                 $('#code_change').val('');
                 $('#code_change').focus();
             }
        
         }
        });
    
    
    }
   
   function ask_admin(){
       
      $('#cus_div').show();
       $('#admin_div').hide();
         $('#code_change').focus();
       
       var data1234="set=otp_reset&mode=logo";
           $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data1234,
            success: function(data) {
                $('#code_change').val('');
                 $('#code_change').focus();
                
            }
        });
       $('#code_change').focus();
    }



</script>
