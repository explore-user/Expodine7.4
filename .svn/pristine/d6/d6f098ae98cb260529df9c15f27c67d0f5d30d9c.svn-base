.center_item_display_cc, .left_mn_menu_odr, .right_potion_mn{  z-index: 0;}
.blr {
  -webkit-filter: blur(3px);
  -moz-filter: blur(3px);
  -o-filter: blur(3px);
  -ms-filter: blur(3px);
  filter: blur(3px);
  width:100%;
  height:100%;
}