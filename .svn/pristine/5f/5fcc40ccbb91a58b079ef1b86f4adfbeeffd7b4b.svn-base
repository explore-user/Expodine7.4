
*,
*:after,
*:before { box-sizing: border-box; }

.tabs {
  list-style: none;
  position: relative;
  padding: 0 25px;
    white-space: nowrap;
	overflow-y:hidden;
  color: #fff;
  margin-bottom:0px;
 /*   background: #fff;
    -moz-box-shadow: 0px 4px 7px #666;
  -webkit-box-shadow: 0px 4px 7px #666;
  box-shadow: 0px 1px 7px #666;*/
  width: 84%;
 float: left;
  margin-left: 1px;
}

.tabs:after {
  content: '';
  width: 100%;
  height: 5px;
  background: #FFF;
  position: absolute;
  z-index: 5;
  bottom: -5px;
  left: 0;
  border-top: 1px solid #a5a5a5;
}

.tab {
  display: inline-block;
  width: auto; 
  height: 37px;
  background: #fff;
  color: #000;
  padding: 5px 25px 0 10px;
  position: relative;
  border-top: 1px solid #728cad;
  margin-right: 6px;
  font-size: 0;
}

.tab > span {
 font-family: 'CALIBRI_0';
 font-size: 15px;
  font-weight: bold;
  line-height: 25px;
}

.tab:before,
.tab:after {
  content: '';
  width: 12px;
  height: 38px;
  background: #fff;
  position: absolute;
  top: 0;
  border-radius: 4px 4px 0 0;
}

.tab:before {
  left: -5px;
  border-left: 1px solid #728cad;
  z-index: 3;
  -webkit-transform: rotate(15deg);
  -moz-transform: rotate(15deg);
  -ms-transform: rotate(15deg);
  -o-transform: rotate(15deg);
  transform: rotate(15deg);
}

.tab:after {
  right: -5px;
  border-right: 1px solid #728cad;
  z-index: 4;
  -webkit-transform: rotate(-15deg);
  -moz-transform: rotate(-15deg);
  -ms-transform: rotate(-15deg);
  -o-transform: rotate(-15deg);
  transform: rotate(-15deg);
}

.tab.active {
   background: #B90504 !important;
  border-bottom: 1px solid #B90504;
  height: 37px;
  margin-bottom: -1px;
  z-index: 10;
  color: #fff;
}

.tab.active:before,
.tab.active:after { background: #B90504; }

button.close {
  padding: 0;
  cursor: pointer;
  background: 0 0;
  border: 0;
  -webkit-appearance: none;
  -moz-appearance: none;
}

.close {
  position: absolute;
  right: 5px;
  z-index:999;
  top: 9px;
  font-size: 20px;
  font-weight: 700;
  line-height: 0;
  width: 16px;
  height: 16px;
  color: #000;
  text-shadow: 0 1px 0 #FFF;
  opacity: .2;
  filter: alpha(opacity=20);
  border-radius: 16px;
}

.close:hover,
.close:focus {
  color: #fff;
  text-decoration: none;
  cursor: pointer;
  opacity: .5;
  filter: alpha(opacity=50);
  background: red;
  font-weight: normal;
  text-shadow: none;
}

.tab-content {
padding:1%;background-color:#FDF5EC;
border:solid 1px #ccc;border-top:solid 0px #ccc;
-moz-box-shadow: 0px 4px 7px #666;
-webkit-box-shadow: 0px 4px 7px #666;
box-shadow: 0px 4px 7px #666;
  height: auto;
   display: inline-block;
   width: 100%;
   position:relative;
   height: 78.3vh !important;
  min-height: 638px !important;
 }

.tab-pane { display: none; }

.tab-pane.active { display: block; }
.kot_right_table{
	-moz-box-shadow: 0px 4px 7px #666;
-webkit-box-shadow: 0px 4px 7px #666;
box-shadow: 0px 4px 7px #666;
	}