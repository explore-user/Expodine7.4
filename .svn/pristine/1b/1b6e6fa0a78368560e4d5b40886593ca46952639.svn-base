<?php

error_reporting(0);

if($_REQUEST['menu_cloud']!=''){
    
    header('location:menu.php?menu_cloud='.$_REQUEST['menu_cloud'].'&reload=yes');

}else if($_REQUEST['cat_cloud']!=''){
    
    header('location:category_master.php');
}
else if($_REQUEST['logo_upload']!=''){
    
    header('location:upload_logo.php');
}
else if($_REQUEST['relogin_ses']!=''){
    
    header('location:logout.php');
}
else if($_REQUEST['set_reorder']!=''){
    
    header('location:counter_sales.php?set_reorder=coming');
}
else if($_REQUEST['auto_close']!=''){
    
    header('location:index.php');
}
else if($_REQUEST['print_logo']!=''){
    
    header('location:index.php');
}
else if($_REQUEST['excel_red']!=''){
    
    header('location:menu_uploads.php');
}

