    function print_kot_ta_missing($kot_id,$billno,$date,$kotprint_tp,$branchofid,$type)
     {
        
        
            $localhost=mysqli_connect(HOST_NAME, USER_NAME, PASSWORD,DATABASE_NAME);
            
            // log_query///         
             
             if($billno[0]=='T'){
                  $typ_log=   'M-TA';
             }else if($billno[0]=='H'){
                 $typ_log=   'M-HD'; 
             }else if($billno[0]=='C'){
                 $typ_log=   'M-CS'; 
             }
             
             
        $date_log_in=  date("Y-m-d H:i:s");
        $data_log= $typ_log.' - '.$kot_id;
        $log_data_print=mysqli_query($localhost,"INSERT INTO tbl_printer_function_log(`tpf_log_data`, `tpf_date_time`, `tpf_print_status`) VALUES"
        . " ('".$data_log."','".$date_log_in."','N')");    
             
             
            $sql_branch5 =  mysqli_query($localhost,"Select * from tbl_branchmaster where be_branchid='".$branchofid."'"); 
		  $num_branch5  = mysqli_num_rows($sql_branch5);
		  if($num_branch5)
		  {
			while($result_branch5  = mysqli_fetch_array($sql_branch5)) 
			{
                            $billref12=$result_branch5['be_billref_in_bill'];
			    $decimal=$result_branch5['be_decimal'];
                                        
                        }
                  }
                  
            $tablecs='';
            $noofpaxcs='';      $urban_order_id='';  $qr_order_id='';
            $sql_portions_bill1  =  mysqli_query($localhost,"SELECT * from tbl_takeaway_billmaster as bm LEFT JOIN tbl_staffmaster as sm ON "
            . " bm.tab_assignedto=sm.ser_staffid LEFT JOIN tbl_takeaway_customer as cr  ON bm.tab_hdcustomerid=cr.tac_customerid  WHERE "
            . " bm.tab_dayclosedate='".$date."' and bm.tab_billno='".$billno."' "); 
			  $num_portions_bill1  = mysqli_num_rows($sql_portions_bill1);
			  if($num_portions_bill1)
			  {
					while($result_portions_bill1  = mysqli_fetch_array($sql_portions_bill1)) 
						{
							
						   if($billref12 !='N' && $result_portions_bill1['tab_bill_ref'] != NULL){
                                                          $refno1=$result_portions_bill1['tab_bill_ref']; 
                                                          
                                                    }
                                                        
                                                 $tablecs=$result_portions_bill1['tab_table_no'];
                                                 $noofpaxcs=$result_portions_bill1['tab_no_pax'];
                                                    
                                                 $onlne_partner=$result_portions_bill1['tab_food_partner'];
                                                 $urban_order_id=$result_portions_bill1['tab_urban_partner_order_no'];
                                                 $qr_order_id=$result_portions_bill1['tab_qr_order_id'];
                          }}
                          
            
            $sql_portions_bill13  =  mysqli_query($localhost,"SELECT tol_name from tbl_online_order  WHERE tol_id='".$onlne_partner."' "); 
	    $num_portions_bill13  = mysqli_num_rows($sql_portions_bill13);
			  if($num_portions_bill13)
			  {
				while($result_portions_bill13  = mysqli_fetch_array($sql_portions_bill13)) 
				{
                                            
