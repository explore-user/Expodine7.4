  function itemimage_create($str,$rand,$Arabic)
  {
		if(!headers_sent()){
		   header("Content-type: image/png"); 
		}
		$im="";
		$im =imagecreate(800, 40);
		$bg = imagecolorallocatealpha($im, 255, 255, 255,45); 
		$textcolor  = imagecolorallocate($im, 0, 0, 0); 
                
                $ver=phpversion();
                
                 $loc= $_SERVER['HTTP_HOST'].$_SERVER['REQUEST_URI'];
                    
                 if(strpos($loc, 'Dropbox') !== false){   
                
               // $font  ='C:\Apache24\htdocs\Dropbox\expodine\src\printlogo/I18N/Arabic/Font/trado.ttf'; 
                 
                 $font  ='C:\Apache24\htdocs\Dropbox\expodine\src\printlogo/I18N/Arabic/Font/NotoSansArabic-Light.ttf';  
                
                 }else{
                     
                     
                  //$font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/NotoSansArabic_Condensed-Regular.ttf';    
                  
                   //$font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/DroidKufi-Regular.ttf';    
                     
                   //$font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/Amiri-Bold.ttf';     
                       
                   //$font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/trado.ttf';    
                   
                    //$font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/Arabic.TTF';    
                    
                    //$font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/tradbdo.ttf';    
                   
                  // $font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/Vazirmatn-ExtraLight.ttf';    
                     
                    $font  ='C:\Apache24\htdocs\expodine\src\printlogo/I18N/Arabic/Font/NotoSansArabic-Light.ttf';  
                 }
                 
		$text =$str; 
		
		
		$text = $Arabic->utf8Glyphs($text); 
		imagettftext($im, 30, 0, 10, 28, $textcolor, $font, $text); 
                
		imagepng($im,'printlogo/printimages/'.$rand.'.png'); 
                // imagecopyresized($im, 'printlogo/printimages/'.$rand.'.png', 0, 0, 0, 0, 200, 20, 800, 40);
		unset($Arabic);
	       // imagedestroy($im); 
	}
        
