    //								
                                                                              $kotheader= array(
                                                                                    new kotheader(" Item(s) ",$ct,$result_kots['pr_style']),
                                                                                    );
                                                                                    foreach($kotheader as $kotheader) {
                                                                                            $printers -> text($kotheader);
                                                                                    }

                                                                    $printers -> cut();
                                                                    $printers -> close();
                                                    }

                                      if($typeof=="android")
                                            {
                                                            if($printers)
                                                            {
                                                                    $prtck++;
                                                            }
                                            }	
                                    $j++;
                         }}}} }
			  
			 if($typeof=="android")
			  {
					  return $prtck;
			  }	else
			  {
				  return true;
			  }
        }	
	
	
	}
    
