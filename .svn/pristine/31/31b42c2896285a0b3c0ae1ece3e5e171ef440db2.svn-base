				{
                    
					$cdid1=	$result_kots['name1']; 
                                        $cdid2=	$result_kots['name2']; 
                                        $cdid3=	$result_kots['name3']; 
                    $tot=$tot+$result_kots['tot']; 
                  }
                  }
                  
                  
                  
                $sql_branch =  mysqli_query($localhost,"Select * from tbl_branchmaster "); 
		  $num_branch  = mysqli_num_rows($sql_branch);
