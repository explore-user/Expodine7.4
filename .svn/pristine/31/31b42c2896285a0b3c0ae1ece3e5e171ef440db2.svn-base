    /* ************Dine in print KOT cancel ends******************  */	
        
        
  function print_kot_cancel_consolidated($cancel_id,$date,$type,$branch)
   {
		/* **********Dine in print KOT cancel consildate starts**************  */
                 
                require_once("Escpos.php");
                
		if($type=="web")
		{
                    $localhost=mysqli_connect(HOST_NAME, USER_NAME, PASSWORD,DATABASE_NAME);
		}else if($type=="android")
		{
                    include("appdbconnection.php");
		}
                
                $otherlang='';
		  $sql_branch =  mysqli_query($localhost,"Select * from tbl_branch_settings_printer where bp_branchid='".$branch."'"); 
		  $num_branch  = mysqli_num_rows($sql_branch);
		  if($num_branch)
		  {
