            left join tbl_menumaster mm on mm.mr_menuid=tbd.tab_menuid 
             left join tbl_kotcountermaster kcm on mm.mr_kotcounter = kcm.kr_kotcode
              left join tbl_printersettings ps on ps.pr_kotcode=mm.mr_kotcounter
              left join tbl_staffmaster sm on sm.ser_staffid = tci.tc_cancelled_by
