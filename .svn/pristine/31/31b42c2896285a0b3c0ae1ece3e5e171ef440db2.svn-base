                                                                 if($card>0){
                                                                $kotheader= array(
										new kotheader("Paid Card ",number_format($card,$decimal) ,$print_style[$array_kot[$j]]),
									);
                                                                
								foreach($kotheader as $kotheader) {
									$printers -> text($kotheader);
								}
                                                                }
                                                                
                                                                
                                                                
                                                                $kotheader= array(
										new kotheader("Balance ",number_format($bal,$decimal),$print_style[$array_kot[$j]]),
									);
                                                                
								foreach($kotheader as $kotheader) {
									$printers -> text($kotheader);
								}
                                                                
                                                                
                                                                      
								$dashedline= array(
										new dashedline("-",$print_style[$array_kot[$j]]),
										);
										foreach($dashedline as $dashedline) {
											$printers -> text($dashedline);
										}
                                                                
                                                                $kotheader= array(
										new kotheader("Paid By",'',$print_style[$array_kot[$j]]),
									);
                                                                
								foreach($kotheader as $kotheader) {
									$printers -> text($kotheader);
								}
                                                                
                                                                
                                                                $kotheader= array(
										new kotheader("Receive By",'',$print_style[$array_kot[$j]]),
									);
                                                                
								foreach($kotheader as $kotheader) {
									$printers -> text($kotheader);
								}
                                                                
                                                                $kotheader= array(
										new kotheader("Remarks",'',$print_style[$array_kot[$j]]),
									);
                                                                
								foreach($kotheader as $kotheader) {
									$printers -> text($kotheader);
								}
                                                                
								
								$printers -> setEmphasis(false);
                                                                
								 $dashedline= array(
										new dashedline("-",$print_style[$array_kot[$j]]),
										);
										foreach($dashedline as $dashedline) {
											$printers -> text($dashedline);
										}
                                                                                
                                                                                
                                                                $printers -> setFont(Escpos::FONT_C);
									$printers -> setJustification(Escpos::JUSTIFY_CENTER);
									$printers -> text($footer4);                
								
                                                                        $printers -> feed();
                                                                        
								$dashedline= array(
										new dashedline("-",$print_style[$array_kot[$j]]),
										);
										foreach($dashedline as $dashedline) {
											$printers -> text($dashedline);
										}
								
								$printers -> cut();
								$printers -> close();
		}
		}
                }
      
}

