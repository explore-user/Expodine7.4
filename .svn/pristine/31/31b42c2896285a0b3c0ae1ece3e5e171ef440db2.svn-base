                                                                                    $printers -> feed();
                                                                                    $printers -> text('     '.$kotno.$dash);
                                                                                    $printers -> feed();
                                                                                }
                                                                             if($dash.$menu)
										{
							                $printers -> setJustification(Escpos::JUSTIFY_LEFT);
								        $printers -> text('     '.$menu.$dash);
