                                                                       }

                                                                   

                                                                    $printers -> cut();
                                                                    $printers -> close();
                                                    }

                                      
                           
            } 
			  
			 if($typeof=="android")
			  {
					  return $prtck;
                          }else
			  {
				  return true;
			  }
        }	
		/* ************************************Dine in print KOT ends******************************************************************  */	

	}
        
        
  function print_kot_cancel_ta_consolidated($cancel_id,$date,$type,$branch)
	{
		 
                  require_once("Escpos.php");
                
		if($type=="web")
