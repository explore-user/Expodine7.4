                                                                                $stln = strlen($menu);
                                                                                $a=0;
                                                                                $spc = 46 - $stln;
                                                                                 for($a=0;$a<$spc;$a++){  
                                                                                     $dash .= ' ';
                                                                       
                                                                 
                                                                                     $itemotherlangname='';
								 if($otherlang=='Y')
								   { 
									  mysqli_query($localhost,"SET NAMES 'utf8'");
									  mysqli_query($localhost,'SET CHARACTER SET utf8');
