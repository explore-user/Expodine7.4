                    tbd.tab_menuid,tbd.tab_slno,tci.tc_cancel_qty,mm.mr_menuid,mm.mr_menuname,ps.pr_printerip,
                    ps.pr_printerport,ps.pr_defaultusb,ps.pr_usbprinterip,ps.pr_usbprinter,ps.pr_style,ps.pr_printcount ,ps.pr_enable
               FROM tbl_takeaway_billmaster tbm 
             left join tbl_takeaway_billdetails tbd on tbd.tab_billno=tbm.tab_billno 
