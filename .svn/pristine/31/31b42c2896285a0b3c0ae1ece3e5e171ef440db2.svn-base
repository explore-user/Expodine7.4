									  }
                                                                    $printers -> setJustification(Escpos::JUSTIFY_CENTER); 
								$logo = new EscposImage("img/print-logo/print_logo_bottom.png");
								
								$printers -> bitImage($logo);
								$printers -> feed();
								}     
                                                                                 
                                                                                 
                                                                                 
                                                                                 
									 $printers -> feed();
									 $printers -> cut();		 
									 $printers -> close();
							}
						}
					
        } }
