                   $sql_invoice2 =  mysqli_query($localhost,"select fi_invoice_no,fi_balance_amt,fi_total_final_rate,fi_discount_amount,"
                   . " fi_total_extra_cost from tbl_function_invoice"
                   . " where fi_function_id='".$functionid."'"); 
        
		  $num_invoice2  = mysqli_num_rows($sql_invoice2);
		  if($num_invoice2)
		  {
				while($result_invoice2  = mysqli_fetch_array($sql_invoice2)) 
