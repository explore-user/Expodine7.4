						 $branchothers2=$result_branch['be_others2'];
						 $branchothers3=$result_branch['be_others3'];
                                                 $branchothers4=$result_branch['be_others4'];
                                                  $footer4=$result_branch['be_footer4'];
                  }}
                  
                                                $ct=count($array_kot);
                                                
					        $printers='';
					  
                                                
