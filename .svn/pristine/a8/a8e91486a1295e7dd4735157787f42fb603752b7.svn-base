* { -moz-box-sizing: border-box; -webkit-box-sizing: border-box; box-sizing: border-box;  margin: 0; padding: 0; }



#wrap { width: 75%; margin: 0 auto;}

#tabwrap {
	
	
  max-height: 150px;
	
}
.tabs1 { overflow: hidden;padding-left: 0px;  width: 100%;padding-right:0;/*text-align:center;*/  margin: 0px !important;}
.tabs1 li { list-style: none;  width: 50%;
  display: inline-block;
  margin: auto !important;}
.tabs1 li a {
	 margin-right: 5px;
  background-color: rgb(34, 157, 161);
  color: #fff;
  line-height: 45px;
  text-align: center;
  cursor: pointer;
  -webkit-box-shadow: inset 0px -3px 1px rgba(0, 0, 0, 0.45), 0px 2px 2px rgba(0, 0, 0, 0.25);
  -moz-box-shadow: inset 0px -3px 1px rgba(0, 0, 0, 0.45), 0px 2px 2px rgba(0, 0, 0, 0.25);
  box-shadow: inset 0px -3px 1px rgba(0, 0, 0, 0.45), 0px 2px 2px rgba(0, 0, 0, 0.25);
  -webkit-border-radius: 3px;
  -moz-border-radius: 3px;
  border-radius: 3px;
  text-shadow: 1px 1px 0px rgba(0, 0, 0, 0.5);
	float: left;
	display: block;
	padding:0px;
	color: #fff;
	font-family: 'yu_gothicregular' !important;
	width: 100%;
	border-raduis:5px;
	margin:0 1px 0 1px;
	text-decoration: none;
	text-align: center;
	
	font-size: 14px;

}

.tabs1 li a:hover {   background-color:rgba(82, 110, 131, 1) }
.tabs1 li:first-child a { border-left: 0; }
.tabs1 li:last-child a { border-right: 0; }

.tabs1 li.current a {
	  background-color:rgb(174, 178, 165);
	color: #fff;
}

.tab_content > div {
	clear: both;
	display: none;
	 top: -8px;
	 left:1px;
	   float: left;
  width: 100%;
  border: 2px solid rgb(174, 178, 165);
  /*border-radius: 13px;*/
  position: relative;
  padding: 1.5%;
  color: rgb(255, 255, 255);
  background-color: rgb(174, 178, 165);
}

.tab_content .current { display: block;
 }
.tab_content #home.first { display: block; }
.tab_content p { margin: 0 0 20px 0;}
