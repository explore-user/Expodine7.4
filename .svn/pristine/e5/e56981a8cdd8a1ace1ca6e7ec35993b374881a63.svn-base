		$(".parent-menu>li").click( function(){
			//alert("l");
			$(".parent-menu>li").removeClass('active');
			if($(this).hasClass('active'))
			{
				//$('body').removeClass('min-nav');
				if($("body").hasClass("min-nav")) //small
				{
					$("body").removeClass('min-nav');
					$(this).addClass('active');
					$(this).removeClass('active_dsble');
				}else
				{
					$(this).removeClass('active');
					$(this).removeClass('active_dsble');
				}
				
			}else
			{
				if($("body").hasClass("min-nav")) //small
				{
					$("body").removeClass('min-nav');
					$(this).addClass('active');
					$(this).removeClass('active_dsble');
				}else
				{
					$(this).addClass('active');
					$(this).removeClass('active_dsble');
				}
			}
		});
		
		$(".toggle-menu").click( function(){
		
		
		if($("body").hasClass("min-nav"))
			{
			  $("body").removeClass('min-nav');
			 // $('.parent-menu li').removeClass('active');
			  $('.parent-menu li').removeClass('active_dsble'); //active_dsble
			}
			else{
				
				$("body").addClass('min-nav');
				$('.parent-menu li').addClass('active_dsble');
				}
		
		});
		
		
		
