.bill_floor_select_btn {
    width: 120px;
    height: 29px;
    display: inline-block;
	 background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #FCAD35), color-stop(100%, #C5912A));
    background-image: -webkit-linear-gradient(#FCAD35, #C5912A);
    background-image: -moz-linear-gradient(#FCAD35, #C5912A);
    background-image: -o-linear-gradient(#FCAD35, #C5912A);
    background-image: linear-gradient(#FCAD35, #C5912A);
	
    text-align: center;
    line-height: 30px;
    margin-top:3px;
    color: #000;
    margin-right:0.5%;
    border-radius: 3px;
	box-shadow:0px 0px 5px #000;
	-moz-box-shadow:0px 0px 5px #000;
	-webkit-box-shadow:0px 0px 5px #000;
	    margin-bottom: 5px;
}

.bill_floor_select_btn_act {
  border-bottom: 3px solid #fff;
       background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #EF3F00), color-stop(100%, #892A08)) ;
    background-image: -webkit-linear-gradient(#EF3F00, #892A08);
    background-image: -moz-linear-gradient(#EF3F00, #892A08);
    background-image: -o-linear-gradient(#EF3F00, #892A08) ;
    background-image: linear-gradient(#EF3F00, #892A08);
    color: #fff;
	box-shadow:0px 0px 0px #000;
	-moz-box-shadow:0px 0px 0px #000;
	-webkit-box-shadow:0px 0px 0px #000;
	position:relative;
}	

.bill_floor_select_btn_act::before{
	content: "";	
    display: block;
    width: 10px;
    height: 10px;
    color: transparent;
    border: 10px solid black;
    border-color: transparent transparent white;
    margin-top: 26px;
    position: absolute;
    left:39%;
	float:left;
	-ms-transform: rotate(180deg); /* IE 9 */
    -webkit-transform: rotate(180deg); /* Safari */
    transform: rotate(180deg);
	}				