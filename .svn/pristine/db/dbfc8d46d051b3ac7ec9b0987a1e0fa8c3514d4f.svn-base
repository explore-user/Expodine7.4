.complimentery_button {
	width:100%;
	height:45px;
	float:left;
	border-bottom:5px #fff solid;
/*	  display: flex;*/
letter-spacing: 0.3px;
	  margin-right: 5px;
	background-color:rgba(243, 19, 0,0.5);
	color:#fff;
	line-height:45px;
	text-align:center;
	cursor:pointer;
   /* -webkit-box-shadow: inset 0px -3px 1px rgba(0, 0, 0, 0.45), 0px 2px 2px rgba(0, 0, 0, 0.25);
    -moz-box-shadow: inset 0px -3px 1px rgba(0, 0, 0, 0.45), 0px 2px 2px rgba(0, 0, 0, 0.25);
    box-shadow: inset 0px -3px 1px rgba(0, 0, 0, 0.45), 0px 2px 2px rgba(0, 0, 0, 0.25);*/
    -webkit-border-radius: 3px;
    -moz-border-radius: 3px;
    border-radius: 3px;
    text-shadow: 0px 0px 0px rgba(0, 0, 0, 0.5);
}
.complimentery_button span{
	width:30%;
	height:39px;
	float:left;
	margin-right:3px;
	padding-top:6px;
	border-right:1px rgba(255,255,255,0.5)   solid;
	}
.complimentery_button a{color:#fff;text-decoration:none;font-family: 'CALIBRI_0';width: 105%;}
.complimentery_button a:hover{color:#fff;}	
.complimentery_button a:focus{color:#fff;}	

.complimentery_button:active { position: relative; top: 3px;
  background-color: rgb(43, 98, 100);
    -webkit-box-shadow: inset 0px -3px 1px rgba(255, 255, 255, 1), inset 0 0px 3px rgba(0, 0, 0, 0.9);
    -moz-box-shadow: inset 0px -3px 1px rgba(255, 255, 255, 1), inset 0 0px 3px rgba(0, 0, 0, 0.9);
    box-shadow: inset 0px -3px 1px rgba(255, 255, 255, 1), inset 0 0px 3px rgba(0, 0, 0, 0.9);
}
.complimentery_button_active { position: relative; top: 3px;
  background-color: rgb(43, 98, 100);
    -webkit-box-shadow: inset 0px -3px 1px rgba(255, 255, 255, 1), inset 0 0px 3px rgba(0, 0, 0, 0.9);
    -moz-box-shadow: inset 0px -3px 1px rgba(255, 255, 255, 1), inset 0 0px 3px rgba(0, 0, 0, 0.9);
    box-shadow: inset 0px -3px 1px rgba(255, 255, 255, 1), inset 0 0px 3px rgba(0, 0, 0, 0.9);
}
.complimentery_button:active:after { content: ""; width: 100%; height: 3px; background: #fff; position: absolute; bottom: -1px; left: 0; }

