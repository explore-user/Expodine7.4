	}
.bottom_menu a{	
color:#fff;
	text-align:center;
	display:block;
	line-height:40px;
	transition:all 0.3s ease-in;
	-moz-transition:all 0.3s ease-in;
	-webkit-transition:all 0.3s ease-in;
	-o-transition:all 0.3s ease-in;
	-ms-transition:all 0.3s ease-in;
}
.bottom_menu a:hover{color:#000 !important;text-decoration:none;font-weight:bold;border-radius:7px;}
.bottom_menu a:focus{color:#fff;text-decoration:none;}
