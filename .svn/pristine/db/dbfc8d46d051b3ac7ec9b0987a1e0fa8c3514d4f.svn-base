/***/

#pagegradient {
  background-image:
        -webkit-gradient(
            radial, 
            50% -50, 
            300, 
            50% 0, 
            0, 
            from(rgba(230, 237, 241, 0)), 
            to(rgba(230, 237, 241, 0.8)));
    
  height:100%;
  left:0px;
  position:absolute;
  top:0;
  width: 600px;
}

.button_proceed {
    position: absolute;
    top: 3px;
    right: 4px;
    display: inline-block;
    margin: 0 auto;
    
    -webkit-border-radius: 10px;
    
    -webkit-box-shadow: 
        0px 3px rgba(128,128,128,1), /* gradient effects */
        0px 4px rgba(118,118,118,1),
        0px 5px rgba(108,108,108,1),
        0px 6px rgba(98,98,98,1),
        0px 7px rgba(88,88,88,1),
        0px 8px rgba(78,78,78,1),
        0px 14px 6px -1px rgba(128,128,128,1); /* shadow */
    
    -webkit-transition: -webkit-box-shadow .1s ease-in-out;
} 

.button_proceed a {
    background-color: #E0E0E0;
    
    background-image: 
        /* gloss gradient */
        -webkit-gradient(
            linear, 
            left bottom, 
            left top, 
            color-stop(50%,rgba(255,255,255,0)), 
            color-stop(50%,rgba(255,255,255,0.3)), 
            color-stop(100%,rgba(255,255,255,0.2))),
        
        /* dark outside gradient */
        -webkit-gradient(
            linear, 
            left top, 
            right top, 
            color-stop(0%,rgba(210,210,210,0.3)), 
            color-stop(20%,rgba(210,210,210,0)), 
            color-stop(80%,rgba(210,210,210,0)), 
            color-stop(100%,rgba(210,210,210,0.3))),
        
        /* light inner gradient */
        -webkit-gradient(
            linear, 
            left top, 
            right top, 
            color-stop(0%,rgba(255,255,255,0)), 
            color-stop(20%,rgba(255,255,255,0.5)), 
            color-stop(80%,rgba(255,255,255,0.5)), 
            color-stop(100%,rgba(255,255,255,0))),        
        
        /* diagonal line pattern */
        -webkit-gradient(
            linear, 
            0% 100%, 
            100% 0%, 
            color-stop(0%,rgba(255,255,255,0)), 
            color-stop(40%,rgba(255,255,255,0)), 
            color-stop(40%,#D2D2D1), 
            color-stop(60%,#D2D2D1), 
            color-stop(60%,rgba(255,255,255,0)), 
            color-stop(100%,rgba(255,255,255,0)));
    
        -webkit-box-shadow:
            0px -1px #fff, /* top highlight */
            0px 1px 1px #FFFFFF; /* bottom edge */
    
    -webkit-background-size: 100%, 100%, 100%, 4px 4px;
    
    -webkit-border-radius: 10px;
    -webkit-transition: -webkit-transform .1s ease-in-out;
	
	background-image: 
        /* gloss gradient */
        -moz-gradient(
            linear, 
            left bottom, 
            left top, 
            color-stop(50%,rgba(255,255,255,0)), 
            color-stop(50%,rgba(255,255,255,0.3)), 
            color-stop(100%,rgba(255,255,255,0.2))),
        
        /* dark outside gradient */
        -moz-gradient(
            linear, 
            left top, 
            right top, 
            color-stop(0%,rgba(210,210,210,0.3)), 
            color-stop(20%,rgba(210,210,210,0)), 
            color-stop(80%,rgba(210,210,210,0)), 
            color-stop(100%,rgba(210,210,210,0.3))),
        
        /* light inner gradient */
        -moz-gradient(
            linear, 
            left top, 
            right top, 
            color-stop(0%,rgba(255,255,255,0)), 
            color-stop(20%,rgba(255,255,255,0.5)), 
            color-stop(80%,rgba(255,255,255,0.5)), 
            color-stop(100%,rgba(255,255,255,0))),        
        
        /* diagonal line pattern */
        -moz-gradient(
            linear, 
            0% 100%, 
            100% 0%, 
            color-stop(0%,rgba(255,255,255,0)), 
            color-stop(40%,rgba(255,255,255,0)), 
            color-stop(40%,#D2D2D1), 
            color-stop(60%,#D2D2D1), 
            color-stop(60%,rgba(255,255,255,0)), 
            color-stop(100%,rgba(255,255,255,0)));
    
        -moz-box-shadow:
            0px -1px #fff, /* top highlight */
            0px 1px 1px #FFFFFF; /* bottom edge */
    border-radius:10px;padding-bottom:2px;
    -moz-background-size: 100%, 100%, 100%, 4px 4px;
	-webkit-box-shadow: inset 0px 1px 0px #D5D5D5, 0px 5px 0px 0px #808080, 0px 10px 5px #999;
	-moz-box-shadow: inset 0px 1px 0px #D5D5D5, 0px 5px 0px 0px #808080, 0px 10px 5px #999;
	-o-box-shadow: inset 0px 1px 0px #D5D5D5, 0px 5px 0px 0px #808080, 0px 10px 5px #999;
	  box-shadow: inset 0px 1px 0px #D5D5D5, 0px 5px 0px 0px #808080, 0px 10px 5px #999;
    
    -moz-border-radius: 10px;
	 -moz-transition: -webkit-transform .1s ease-in-out;
    
    display: inline-block;
    padding:6px 33px 4px 17px;
  color: #3A474D;
  text-transform: uppercase;
font-family: 'CALIBRI_0';
  font-weight: 500;
  font-size: 16px;
    
    text-shadow: 0px 1px #fff, 0px -1px #262F33;
}

        .button_proceed a:hover {
            color: #229DA1;
			text-decoration:none;
            text-shadow: 0px -1px #97A63A;
            cursor: pointer;
        }

        .button_proceed:active {
            -webkit-box-shadow: 
                0px 3px rgba(128,128,128,1),
                0px 4px rgba(118,118,118,1),
                0px 5px rgba(108,108,108,1),
                0px 6px rgba(98,98,98,1),
                0px 7px rgba(88,88,88,1),
                0px 8px rgba(78,78,78,1),
                0px 10px 2px 0px rgba(128,128,128,.6); /* shadow */
			-moz-box-shadow: 
                0px 3px rgba(128,128,128,1),
                0px 4px rgba(118,118,118,1),
                0px 5px rgba(108,108,108,1),
                0px 6px rgba(98,98,98,1),
                0px 7px rgba(88,88,88,1),
                0px 8px rgba(78,78,78,1),
                0px 10px 2px 0px rgba(128,128,128,.6); 
				 -moz-background-size: 100%, 100%, 100%, 4px 4px;
	-webkit-box-shadow: inset 0px 1px 0px #D5D5D5, 0px 4px 0px 0px #4A4A4A, 0px 2px 52px #999;
	-moz-box-shadow: inset 0px 1px 0px #D5D5D5, 0px 5px 0px 0px #4A4A4A, 0px 10px 5px #999;
	-o-box-shadow: inset 0px 1px 0px #D5D5D5, 0px 5px 0px 0px #4A4A4A, 0px 10px 5px #999;
	  box-shadow: inset 0px 1px 0px #D5D5D5, 0px 0px 0px 0px #4A4A4A, 0px 1px 1px #999;
	   top: 6px;  
        }

        .button_proceed:active a{
            -webkit-transform: translate(0, 5px); /* depth of button press */
        }

    .button_proceed a:after {
        content: ">";
        display: block;
        width: 10px;
        height: 10px;
    	text-decoration:none;
        position: absolute;
        right: 14px;
        top: 2px;    
        
        font-family: 'Cabin';
        font-weight: 700;
        color: #229DA1;
        text-shadow: 0px 1px #fff, 0px -1px #97A63A;
        font-size: 26px;
    }
