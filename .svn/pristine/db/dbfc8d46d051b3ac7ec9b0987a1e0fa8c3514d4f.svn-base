body{
	margin:0;
	padding:0;
	background-image:url(../img/hd_paper.jpg);
	background-repeat:repeat;
	  background-size: 17% !important;
	 overflow-x:hidden !important;
	/*background-color:#efefef;*/
	}
	
.navbar-default .navbar-brand{margin-left:-7px !important;}
.kot_new_main_cc{
	width:100%;
	height:auto;
	float:left;
	margin-top: -3px;

	}
	
.kot_full_width{
	width:99.8%;
	/*height:85vh;*/
	/*height:auto;*/
	overflow:hidden;
	position:relative;
	min-height:550px;
	float:left;
	padding:1%;
	border:solid 1px #ccc;
	}
.kot_list_table{
	width:200px;
	height:200px;
	float:left;
	background-color:#fff;
	border:solid 1px #ccc;
	
	}	
	

		.pricing_table {
			line-height: 150%; 
			font-size: 12px; 
			margin: 0 auto; 
			width: 100%; 
			text-align: center;
			padding-top:10px;
			  padding-left: 0px !important;
		}
		
		.price_block {
			text-align: center; 
			width: 100%; 
			color: #fff; 
			display:inline-block;
			list-style-type: none; 
			transition: all 0.25s; 
			position: relative; 
			box-sizing: border-box;
			
			margin-bottom: 10px; 
			border-bottom: 1px solid transparent; 
		}
		
		/*Price heads*/
		.pricing_table h3 {
			text-transform: uppercase; 
			padding: 6px 0; 
			background: #420304; 
			margin: 0px 0 1px 0;
			font-size: 15px;
 			color: #fff;
		}
		
		/*Price tags*/
		.price {
			display: table; 
			background-color:transparent; 
			width: 100%; 
			height: 70px; 
			  background-color: rgb(249, 194, 145);
		}
		.price_figure {
			font-size: 24px; 
			text-transform: uppercase; 
			vertical-align: middle; 
			display: table-cell;
		}
		.price_number {
			  font-size: 18px;
  			line-height: 30px;
			display: block;
			color:#333;
		}
		.price_tenure {
			font-size: 11px; 
		}
		
		/*Features*/
		.features {
			/*background: #DEF0F4; */
			color: #000;
			  margin: 0px;
  			padding: 0px;
			 /* display: inline-table;*/
			border:solid 1px #ccc;
			border-bottom:solid 0px #ccc;
		}
		.features li {
			padding: 8px 15px;
			border-bottom: 1px solid #ccc; 
			font-size: 13px; 
			list-style-type: none;
		}
		
		.footer {
			/*padding: 15px; 
			background: #DEF0F4;*/
			float:left;
			width:100%;
		}
		.action_button {
			text-decoration: none; 
			color: #333; 
			font-weight: bold; 
			/*border-radius: 5px; */
			 /* background: linear-gradient(#8B8A8A, #4F4F4F);*/
			/*padding: 5px 20px; */
			font-size: 11px; 
			  border: solid 1px #A8A5A5;
  				background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.1));
			  width: 100%;
			  /* height: 24px; */
			  float: left;
			  text-align: center;
			  padding: 2.1%;
			/*  margin: 1px;*/
			  text-transform: uppercase;
			text-transform: uppercase;
			transition:all 0.3s ease-in;
		}
.action_button:hover{text-decoration:none;color:#fff;}		
		.price_block:hover {
			box-shadow: 0 0 0px 5px rgba(0, 0, 0, 0.5); 
			transform: scale(1.04) translateY(-5px); 
			z-index: 1; 
			border-bottom: 0 none;
		}
		.price_block:hover .price {
			background: linear-gradient(#CD1619, #A50003); 
		}
		.price_block:hover .price_number{color:#fff;}	 
		.price_block:hover h3 {
			background: #222;
		}
		.price_block:hover .action_button {
			color:#fff !important;
			background: linear-gradient(#525252, #202020) ; 
		}
		
.kot_active{
			box-shadow: 0 0 0px 4px rgba(0, 0, 0, 0.5) !important; 
			transform: scale(1.04) translateY(-5px); 
			z-index: 1; 
			border-bottom: 0 none;
	}	
.kot_active h3{background-color:#191919;}	
.kot_active .price {
			  background: linear-gradient(#CD1619, #A50003) !important;
			box-shadow: inset 0 0 0px 0px #DB7224 !important;
		}
.kot_active .price .price_number{color:#fff;}		

.kot_active .price_block h3 {
			background: #222 !important;
		}
.kot_active .action_button {
	color:#fff !important;
  background: linear-gradient(#323232, #202020) !important;
  border: solid 0px #A8A5A5; 
  }	
 .kot_active  .features{background-color:#fff;} 	
				
		@media only screen and (min-width : 480px) and (max-width : 768px) {
			.price_block {width: 50%;}
			.price_block:nth-child(odd) {border-right: 1px solid transparent;}
			.price_block:nth-child(3) {clear: both;}
			
			.price_block:nth-child(odd):hover {border: 0 none;}
		}
		@media only screen and (min-width : 768px){
			.price_block {width: 15%; margin: 0 5px 30px 5px;  
			-moz-box-shadow: 0px 4px 7px #000;
  			-webkit-box-shadow: 0px 4px 7px #000;
 			 box-shadow: 0px 4px 7px #000;}
			.price_block {border-bottom: 0 none;cursor:pointer;}
			.price_block:last-child {border-right: 0 none;}
			
			.price_block:hover {border: 0 none;}
		}
		
		
		
		
		
	
		
		
		
		
		.skeleton, .skeleton ul, .skeleton li, .skeleton div, .skeleton h3, .skeleton span, .skeleton p {
			border: 5px solid rgba(255, 255, 255, 0.9);
			border-radius: 5px;
			margin: 7px !important;
			background: rgba(0, 0, 0, 0.05) !important;
			padding: 0 !important;
			text-align: left !important;
			display: block !important;
			
			width: auto !important;
			height: auto !important;
			
			font-size: 10px !important;
			font-style: italic !important;
			text-transform: none !important;
			font-weight: normal !important;
			color: black !important;
		}
		.skeleton .label {
			font-size: 11px !important;
			font-style: italic !important;
			text-transform: none !important;
			font-weight: normal !important;
			color: white !important;
			border: 0 none !important;
			padding: 5px !important; 
			margin: 0 !important;
			float: none !important;
			text-align: left !important;
			text-shadow: 0 0 1px white;
			background: none !important;
		}
		.skeleton {
			display: none !important;
			margin: 100px !important;
			clear: both;
		}			
		
