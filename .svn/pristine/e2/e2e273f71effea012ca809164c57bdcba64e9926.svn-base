.keys span, .top span.clear {
    float: left;
    position: relative;
    top: 0;
    cursor: pointer;
    width: 30%;
    height: 45px;
    background: rgba(78, 94, 104, 0.4);
    border-radius: 3px;
    box-shadow: 0px 4px rgba(0, 0, 0, 0.8);
    -moz-box-shadow: 0px 4px rgba(0, 0, 0, 0.8);
    -webkit-box-shadow: 0px 4px rgba(0, 0, 0, 0.8);
    margin: 0 3% 4% 0;
    color: #fff;
    font-size: 15px;
    line-height: 3em;
    text-align: center;
    user-select: none;
    transition: all 0.2s ease;
    -moz-transition: all 0.2s ease;
    -webkit-transition: all 0.2s ease;
    -o-transition: all 0.2s ease;
    -ms-transition: all 0.2s ease;
}
     .settle_key span, .top span.clear{background-color:#fff !important;color:#000 !important;font-size:16px; }
.settle_key span:hover{box-shadow:none;}
