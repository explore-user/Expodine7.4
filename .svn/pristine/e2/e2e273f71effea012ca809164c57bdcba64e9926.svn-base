.item_contain_3rd{
	  width: auto;
  padding: 1px 20px;
  /* float: left; */
  display: inline-block;
  margin: 0.5%;
	position:relative;
	overflow:hidden;
	border-radius:5px;
	border:solid 1px rgba(255,255,255,0.2);
	margin-right:0;
	cursor:pointer;
	  background-color: #3B4236;
	  transition: all .2s ease-out;
  -webkit-transition: all .2s ease-out;
