@font-face {
    font-family: 'bisque';
    src: url('../fonts/bisque.eot');
    src: url('../fonts/bisque.eot') format('embedded-opentype'),
         url('../fonts/bisque.woff2') format('woff2'),
         url('../fonts/bisque.woff') format('woff'),
         url('../fonts/bisque.ttf') format('truetype'),
         url('../fonts/bisque.svg#bisque') format('svg');
}


body{    background-image: url(../img/Dark-Blurred-Blue.jpg) !important;margin:0;padding:0;/*background-image:url(../img/order_bg.jpg)*/background-image:url(../img/wood.jpg);  background-repeat: repeat;background-repeat: round;background-attachment:fixed;
 -webkit-background-size: cover !important;
	  -moz-background-size: cover !important;
	   -o-background-size: cover !important;
	    background-size: cover !important;
}
.no-padding{padding:0px !important}	
.top_container{
	width:100%;
	/*height:75px;*/
	height:auto;
	position: relative;
	z-index: 1;
	float:left;
	background-color:rgba(255,255,255,0.1);
	border-bottom:1px solid rgba(255,255,255,0.2);
	/*box-shadow: 0px 0px 13px #666;
	-moz-box-shadow: 0px 0px 13px #666;*/
	padding-bottom: 3px;
    padding-top: 5px;
	}
.logo_container{
  width: 25%;
  height: 38px;
  float: left;
  margin: 0.3% 0 0 1%;
  margin-left: 2%;

	}		
.logo{
	width: 130px;
    height: 40px;
    float: left;
    margin-left: -14px;
    margin-top: -2px;
	}
.logo img{width:100%}
.right_notification_item{
	width:200px;
	height:40px;
	float:right;
	margin-top:20px;
	}	
.notification_icon{
	width:35px;
	height:35px;
	float:left;
	margin-left:13px;
	border-radius:50%;
	background-color:transparent;
	border:solid 1px rgba(255,255,255,0.5);
	text-align: center;
  line-height: 35px;
  transition:all 0.2s ease;
  cursor:pointer;
  
	}
.notification_icon img{width:75%;  vertical-align: middle;  padding-top: 4px;}	
.notification_icon:hover{margin-top:-3px;}
.user_logout_cc{
	width:136px;
	height:35px;
	float:right;
	margin-top:5px;
	cursor:pointer;
	}
.user_name{
	margin-right:5px;
	height:35px;
	float:left;
	line-height:35px;
	color:#ccc;
	text-align:left;
	font-size:18px;
	text-transform: capitalize;
	}	
.logout_arrow{
	width:10px;
	height:10px;
	float:left;
	margin-top:15px;
	background-image:url(../img/arrow_btn.png);
	background-repeat:no-repeat;}
	
	
	
/***********oldddddd***********/

.middle_container{
	width:100%;
	height:auto;
	float:left;
	position:relative;
	/*padding-top:1%;*/
	}
.left_contant_container{
	width:80%;
	  /*height: 49.2vh;*/
	  height:70vh;
  min-height:535px;
	float:left;
	padding-top:1%;
	/*overflow:auto;*/
	text-align:center;
	position:relative;
	/*background-color:rgba(255,255,255,0.5)*/
	padding-bottom:45px;
	text-align:center;
	}	
.main_item{
	width:190px;
	height:220px;
	/*float:left;*/
	  margin: auto !important;
  margin-top:1% !important;
   margin-right:1% !important;
    margin-left:1% !important;
  display: inline-block;
	margin:0.8%;
	border-radius:5px;
	background-color:rgba(255,255,255,0.2);
	padding:0.3%;
	border:solid 1px rgba(0,0,0,0.2);
	position:relative;
	cursor:pointer;
	}	
.main_item_bg{
	width:100%;
	height:100%;
	float:left;
	border-radius:5px;
	overflow:hidden;
	position:relative
	}
.main_item_bg img{
	  transition: all .2s ease-out;
  -webkit-transition: all .2s ease-out;
  -moz-transition: all .2s ease-out;
  -o-transition: all .2s ease-out;
	}	
.main_item:hover .main_item_bg img{
	-webkit-transform: scale(1.1);
    -moz-transform: scale(1.1);
    -o-transform: scale(1.1);
    -ms-transform: scale(1.1);
    transform: scale(1.1);	
	}
.main_item_text_bg{
	width:100%;
	height:103px;
	position:absolute;
	bottom:3px;
	z-index:9;
	overflow:hidden;
	}
.main_item_text{
	width: 125px;
	height: 60px;
	  word-wrap: break-word;
	position: absolute;
	bottom: 10px;
	text-align:center;
	padding-left:2px;
	padding-right:2px;
	 font-size: 23px;
	word-wrap:break;
	color:#fff;
	font-weight:bold;
	vertical-align: middle;
	-moz-border-radius-topleft: 0px;
	-moz-border-radius-topright: 80px;
	-moz-border-radius-bottomleft: 0px;
	-moz-border-radius-bottomright: 0px;
	-webkit-border-top-left-radius: 0px;
	-webkit-border-top-right-radius: 80px;
	-webkit-border-bottom-left-radius: 0px;
	-webkit-border-bottom-right-radius: 0px;
	border-top-left-radius: 0px;
	border-top-right-radius: 80px;
	border-bottom-left-radius: 0px;
	border-bottom-right-radius: 0px;
	font-family: 'CALIBRI_0'; 

	}
.main_item_shadow{
	width:100%;
	height:25px;
	position:absolute;
	background-repeat:no-repeat;
	bottom:-25px;
	background-size:100%;
	background-image:url(../img/main_item_shadow.png);
	}
