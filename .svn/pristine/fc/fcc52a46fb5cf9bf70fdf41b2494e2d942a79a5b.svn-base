CREATE TABLE IF NOT EXISTS `tbl_store_action` (
  `ts_id` int(11) NOT NULL AUTO_INCREMENT,
  `ts_store` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_platfrorm` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_status` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_reference_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_status_webhook` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_date_webhook` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  PRIMARY KEY (`ts_id`),
  UNIQUE KEY `ts_store` (`ts_store`)
) ENGINE=InnoDB  DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci AUTO_INCREMENT=24 ;

