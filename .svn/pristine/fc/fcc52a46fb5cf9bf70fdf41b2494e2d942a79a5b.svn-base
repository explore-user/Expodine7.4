--
-- Table structure for table `tbl_order_item_tax_charge_details`
--

CREATE TABLE IF NOT EXISTS `tbl_order_item_tax_charge_details` (
  `tx_id` int(11) NOT NULL AUTO_INCREMENT,
  `tx_store_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tx_order_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tx_menu_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tx_rate` decimal(15,3) DEFAULT NULL,
  `tx_value` decimal(15,3) DEFAULT NULL,
  `tx_tax_title` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tx_date` datetime DEFAULT NULL,
  `tx_type` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tx_pos_sync` char(1) COLLATE utf8_unicode_ci NOT NULL DEFAULT 'N',
  PRIMARY KEY (`tx_id`),
  UNIQUE KEY `tx_store_id` (`tx_store_id`,`tx_order_id`,`tx_menu_id`,`tx_value`,`tx_tax_title`)
) ENGINE=InnoDB  DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci AUTO_INCREMENT=1742 ;

