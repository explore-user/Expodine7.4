--
-- Table structure for table `tbl_order_relay_customer`
--

CREATE TABLE IF NOT EXISTS `tbl_order_relay_customer` (
  `tor_id` int(11) NOT NULL AUTO_INCREMENT,
  `tor_store_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_order_no` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_customer` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_email` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_phone` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_city` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_guest_mode` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_landmark` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_latitude` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_line1` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_line2` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_longitude` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_pin` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_sublocality` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_tag` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tor_date` datetime DEFAULT NULL,
  `tor_sync_pos` char(1) COLLATE utf8_unicode_ci DEFAULT NULL,
  PRIMARY KEY (`tor_id`),
  UNIQUE KEY `tor_store_id` (`tor_store_id`,`tor_order_no`),
  UNIQUE KEY `tor_store_id_2` (`tor_store_id`,`tor_order_no`),
  UNIQUE KEY `tor_store_id_3` (`tor_store_id`,`tor_order_no`,`tor_customer`,`tor_phone`)
) ENGINE=InnoDB  DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci AUTO_INCREMENT=491 ;

