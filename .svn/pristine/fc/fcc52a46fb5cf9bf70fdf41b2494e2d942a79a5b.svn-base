--
-- Table structure for table `tbl_order_payment_details`
--

CREATE TABLE IF NOT EXISTS `tbl_order_payment_details` (
  `tp_id` int(11) NOT NULL AUTO_INCREMENT,
  `tp_store_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_order_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_amount` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_option` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_srvr_trx_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_date` datetime DEFAULT NULL,
  `tp_pos_sync` char(1) COLLATE utf8_unicode_ci NOT NULL DEFAULT 'N',
  PRIMARY KEY (`tp_id`),
  UNIQUE KEY `tp_store_id` (`tp_store_id`,`tp_order_id`,`tp_amount`,`tp_option`)
) ENGINE=InnoDB  DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci AUTO_INCREMENT=472 ;

