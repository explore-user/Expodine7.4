-- --------------------------------------------------------

--
-- Table structure for table `tbl_order_relay_platform`
--

CREATE TABLE IF NOT EXISTS `tbl_order_relay_platform` (
  `tp_id` int(11) NOT NULL AUTO_INCREMENT,
  `tp_name` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_platform_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_kind` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_del_type` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_extra` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_30_min_del` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_cash_to_collect` decimal(15,3) DEFAULT NULL,
  `tp_store_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_order_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `tp_date` datetime DEFAULT NULL,
  `tp_pos_sync` char(1) COLLATE utf8_unicode_ci DEFAULT 'N',
  PRIMARY KEY (`tp_id`),
  UNIQUE KEY `tp_name` (`tp_name`,`tp_platform_id`,`tp_store_id`,`tp_order_id`)
) ENGINE=InnoDB  DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci AUTO_INCREMENT=436 ;

