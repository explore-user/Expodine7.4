--
-- Table structure for table `tbl_order_store_details`
--

CREATE TABLE IF NOT EXISTS `tbl_order_store_details` (
  `ts_id` int(11) NOT NULL AUTO_INCREMENT,
  `ts_store_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_order_id` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_name` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_address` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_id_in` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_latitude` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_logintude` varchar(250) COLLATE utf8_unicode_ci DEFAULT NULL,
  `ts_date` datetime DEFAULT NULL,
  `ts_pos_sync` char(1) COLLATE utf8_unicode_ci NOT NULL DEFAULT 'N',
  PRIMARY KEY (`ts_id`),
  UNIQUE KEY `ts_store_id` (`ts_store_id`,`ts_order_id`,`ts_name`)
) ENGINE=InnoDB  DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci AUTO_INCREMENT=432 ;

