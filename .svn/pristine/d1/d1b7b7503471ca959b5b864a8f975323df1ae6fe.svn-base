.header_main_container{
	width:100%;
	height:auto;
	/*overflow:auto;*/
	background-color: #FFFFFF;
	  padding-top:0;
  padding-bottom: 0;
 	border-top: 10px #E5E5E5 solid;
   border-left:10px #E5E5E5 solid;
   border-right:10px #E5E5E5 solid;
   display: inline-block;
	}
.filter_heading{
	  width: 10%;
	margin-bottom:0px;
	  float:left;
    height: 40px;
	text-align:center;
  line-height: 44px;
font-family: 'CALIBRI_0';
    font-size: 16px;
  color: #FFF;
 background-color:#F5351B;
	}
.search_name_box_main_last_branch {
  width: 27%;
  height: auto;
  float: left;
  text-align: left;
  margin-left: 0%;
   margin-bottom: 0;
  margin-top:2px;
}
.text-selection_branch-name {
  width: 35%;
  margin-left: 4%;
  height: auto;
  float: left;
font-family: 'CALIBRI_0';
  color: #333;
  font-size: 13px;
  line-height: 37px;
  text-align: left !important;
}
.search_name_branch-name {
  width: 61%;
  height: auto;
  float: left;
}
.filter_botton_main {
  width: 100px !important;
  height: 35px;
  float: left;
  margin-top: 3px;
  line-height: 35px;
  margin-left: 20px;
  border: none !important;
  background-color: #606060;
  font-family: 'CALIBRI_0';
  font-size: 15px;
  color: #FFF;
  text-align: center;
  border-radius: 5px;
  -webkit-border-radius: 5px;
  -moz-border-radius: 5px;
  -o-border-radius: 5px;
  -ms-border-radius: 5px;
  border-color: rgba(0, 0, 0, 0.1) rgba(0, 0, 0, 0.1) rgba(0, 0, 0, 0.25);
  text-shadow: 0 -1px 0 rgba(0, 0, 0, 0.25);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.2), 0 1px 2px rgba(0,0,0,.05);
  -webkit-box-shadow: inset 0 1px 0 rgba(255,255,255,.2), 0 1px 2px rgba(0,0,0,.05);
  -moz-box-shadow: inset 0 1px 0 rgba(255,255,255,.2), 0 1px 2px rgba(0,0,0,.05);
  -o-box-shadow: inset 0 1px 0 rgba(255,255,255,.2), 0 1px 2px rgba(0,0,0,.05);
  -ms-box-shadow: inset 0 1px 0 rgba(255,255,255,.2), 0 1px 2px rgba(0,0,0,.05);
  
}
.table_main_heading_user_page {
  width: 80%;
  height: 20px;
  line-height: 24px;
  text-align: left;
  margin-bottom: 10px;
  font-family: 'CALIBRI_0';
  font-size: 15px;
  color: #434343;
  margin-top: 15px;
  text-align: center;
}
.usr-list_table_scroll {
  width:87%;
height:auto;
float:left;
  overflow: auto;
  white-space: nowrap;
}
.table-bordered {
  background-color: #F6F5F5;
  box-shadow: -5px 0px 12px #4D4D4D;
  -webkit-box-shadow: -5px 0px 12px #4D4D4D;
  -moz-box-shadow: -5px 0px 12px #4D4D4D;
  -o-box-shadow: -5px 0px 12px #4D4D4D;
  -ms-box-shadow: -5px 0px 12px #4D4D4D;
}
.table-bordered td{border:solid 1px #ccc !important;height: 40px;  padding: 0px !important;text-align:center !important }
.table-font {
  font-family: 'CALIBRI_0';
  color: #333;
  font-size: 12px;
}
.table-bordered {
  border: 1px solid #ddd;
  margin-bottom:0px !important;
}	

.table_heading {
  /* background-color: #0F80A5 !important; */
  background-color: #1E4653 !important;
  color: #fff;
  text-align: center !important;
  font-family: 'CALIBRI_0' !important;
}
.search_name_branch-name .form-control{height:36px !important;}
.attendence_name_cc{
	width:100%;
	float:left;
	min-height: 452px;
	height:60vh;
  overflow: hidden;
	}
.attendence_name{
	width:13%;
	height:auto;
	float:left;
	position:relative;
	}	
.check_in{
	width:20px;
	height:20px;
	display: inline-block;
	border:solid 1px #ccc;
	background-color:#B33838;
	}
.check_out{
	width:20px;
	height:20px;
	display: inline-block;
	border:solid 1px #ccc;
	background-color:#009931;
	}	
.check_out, .check_in{padding:0px !important}	
.check_out:hover{background-color:#0C6 !important;}	
.check_in:hover{background-color:#f00 !important;}	
.form-group{float:left;}	
.sub_btn{width:100% !important;padding:0;text-align:center;}

.form-control_main {
  display: block;
  width: 50%;
  float: left;
  height: 34px;
  padding: 6px 12px;
  font-size: 14px;
  line-height: 1.42857143;
  color: #555;
  background-color: #fff;
  background-image: none;
  border: 1px solid #ccc;
  border-radius: 4px;
  -webkit-box-shadow: inset 0 1px 1px rgba(0, 0, 0, .075);
  box-shadow: inset 0 1px 1px rgba(0, 0, 0, .075);
  -webkit-transition: border-color ease-in-out .15s, -webkit-box-shadow ease-in-out .15s;
  -o-transition: border-color ease-in-out .15s, box-shadow ease-in-out .15s;
  transition: border-color ease-in-out .15s, box-shadow ease-in-out .15s;
}