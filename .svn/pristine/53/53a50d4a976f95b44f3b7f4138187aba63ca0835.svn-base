@font-face {
    font-family: 'CALIBRI_0';
    src: url('../fonts/CALIBRI_0.eot');
    src: url('../fonts/CALIBRI_0.eot') format('embedded-opentype'),
         url('../fonts/CALIBRI_0.woff2') format('woff2'),
         url('../fonts/CALIBRI_0.woff') format('woff'),
         url('../fonts/CALIBRI_0.ttf') format('truetype'),
         url('../fonts/CALIBRI_0.svg#CALIBRI_0') format('svg');
}

.main_header_wrapper{
	    width: 100%;
    height: 76px;
    padding-top: 15px;
    background: #000;
	
	
	}
	

.button_bottom{	
        width: 240px;
    height: 40px;
    line-height: 40px;
    display: block;
    text-align: center;
    text-transform: uppercase;
    font-size: 15px;
    float: left;
    color: #fff;
    cursor: pointer;
    text-decoration: none;
    margin-top: 0;
    background-color: #1b9406!important;
}

.button_bottom:hover{
	color: #fff;
    text-decoration: none;
	}
.main_name_container{
	    width: 40%;
    height: 35px;
    line-height: 35px;
    float: left;
    font-size: 16px;
    color: #676767;
	}
	
.main_container{
	width:80%;
	height:auto;
	overflow:auto;
	font-family: 'CALIBRI_0';
	margin:0 auto;
	    padding-bottom: 90px;
	}
	
.keyftur_head{
	text-align:center;
	padding-top:10px;
	padding-bottom:10px;
	 font-family: 'CALIBRI_0';
	border-bottom:1px solid #b9b9b9;
	}
	
.keyftur_head_first{
	text-align:center;
	padding-top:20px;
	    letter-spacing: 2px;
	 font-family: 'CALIBRI_0';
	}	
	
.navbar-brand_main{
	width:182px;
	height:70px;
	margin:0 auto;
	}
	
	.foot_last {
    color: #848383;
    font-family: 'CALIBRI_0';
    font-size: 14px;
    text-align: center;
    line-height: 55px;
}			
	
	
textarea{
	resize:none;
	}	
.install_main_error{
	width:60%;
	height:30px;
	line-height:30px;
	float:right;
	color:#f00;
	}
.field_erro_txt{
	    width: 59%;
    height: auto;
    float: right;
    color: #f00;
    position: absolute;
    right: 0;
    bottom: -19px;
	}	
.excel_upload_table{
    width: 100%;
    height: auto;
    float: left;
        
}

.excel_upload_table td{border: solid 1px #ccc;padding: 8px}
.button_xlmudpdates{
    width: 120px;
        height: 33px;
    line-height: 33px;
    display: block;
    text-align: center;
    text-transform: uppercase;
    font-size: 14px;
    float: left;
    color: #fff !important;
    cursor: pointer;
    text-decoration: none !important;
    margin-top: 0;
    background-color: #a97f00;
    border-bottom: 3px #00000042 solid;
    border-radius: 5px;
}	
	.loading_popup_ok_btn{
width: 111px;
    height: 37px;
    display: inline-block;
    border-radius: 20px;
    background-color: #C9090C;
    text-align: center;
    line-height: 36px;
    color: #fff !important;
    font-size: 16px;
    font-family: 'CALIBRI_0';
    cursor: pointer;
	}
.loading_popup_overlay{
	position:fixed;
	width:100%;
	height:100%;
	background-color:rgba(0,0,0,0.8);
	top:0;
	left:0;
	z-index:9999;
	display:none;
	}
	.loading_popup{
	width:400px;
	float:left;
	height:195px;
	float:left;
	background-color:#fff;
	border-radius:5px;
	display:none;
	position:fixed;
	left:0;
	right:0;
	top:0;
	bottom:0;
	margin:auto;
	z-index:99999;
	}
	.loading_popup_headiing{
	width:100%;
	height:50px;
	float:left;
	line-height:50px;
	text-align:center;
	font-size:20px;
	color:#000;
	font-family: 'CALIBRI_0';
	margin-top:10px;
	}
	.loading_popup_headiing_text{
	width:100%;
	height:20px;
	float:left;
	line-height:0px;
	text-align:center;
	font-size:13px;
	color:#666;
	font-family: 'CALIBRI_0';
	}
	.loading_popup_area{
	width:100%;
	height:auto;
	float:left;
	text-align:center;
	margin-top: 7px;
	}		