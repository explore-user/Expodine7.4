}

.main_mn_1st{width: 66.88667% !important;height:60px; overflow-x:auto;overflow: auto;
	position: relative;
	-webkit-box-sizing: border-box; -moz-box-sizing: border-box; box-sizing: border-box;}
.main_mn_1st_count{width: 100% !important;height:60px; overflow-x:auto;overflow: auto;
	position: relative;
	-webkit-box-sizing: border-box; -moz-box-sizing: border-box; box-sizing: border-box;}	
