.dish_img_displaying_cc{
	width:100%;
	height:67.6vh;
	float:left;
	overflow:auto;
	margin-top:5px;
	  border: solid 1px rgba(255,255,255,0.1);
	 overflow-x: auto;
	position: relative;
	-webkit-box-sizing: border-box; -moz-box-sizing: border-box; box-sizing: border-box;
	max-height:100%;
	
	}
	
.dish_display_img{
	width:135px !important;
	height:130px;
	margin:20px 2px 0 11px;
	float:left;
	cursor:pointer;
	position:relative;
	 transition: all .2s ease-out;
	-webkit-transition: all .2s ease-out;
	-moz-transition: all .2s ease-out;
	-o-transition: all .2s ease-out;
	
	}	

	
.dish_display_img img:focus{
	 border: solid 1px rgba(255,255,255,0.8);
	}	
.dish_display_img img{
  width: 120px;
  height:130px;	
  border-radius:10px;
	}
.dish_display_img_text{
	width:120px;
	height:auto;
	min-height:30px;
	bottom:0;
	font-size:14px;
	position:absolute;
	background-color:rgba(0,0,0,0.7);
	color:#fff;
	text-align:center;
	line-height:20px;
	bottom:0;
	z-index:9;
	 border-bottom-left-radius: 10px;
	  border-bottom-right-radius:10px;
	  
	}
