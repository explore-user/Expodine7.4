body{margin:0;padding:0;background-image:url(../img/bg_cont.jpg) !important;}
a{color:#fff;font-size:14px;text-decoration:none;}
a:hover{color:#997A47;}
.add_new_dropdown_1{  width: 100%;height: 30px !important;margin-top:4px;  padding:0px 12px !important;}
.text{font-family: 'CALIBRI_0';font-size:14px;color:#fff;line-height:35px;}
.top_container{
	width:100%;
	height:35px;
	background-color:rgba(255,255,255,0.1);
	text-align:center;
	font-size:18px;
	margin-top:3px;
	font-family: 'CALIBRI_0';
	line-height:35px;
	color:#FFFAF0;
	 transition: all .2s ease-out;
	-webkit-transition: all .2s ease-out;
	-moz-transition: all .2s ease-out;
	-o-transition: all .2s ease-out;
}
.main_container{
	width:100%;
	max-width:1345px;
	margin:auto;
	height:auto;
	}
.side_menu{
	padding:0;
	height:auto;
	padding-right: 0px !important;
	margin-left: -12px;
	  max-height: 75vh;
  overflow-x: auto;
  overflow-y:hidden;
	
	}
.side_menu_item_head{
	width:210px;
	float:left;
	height:50px;
	margin-bottom:5px;
	background-color:rgba(255,255,255,0.1);
	font-family: 'CALIBRI_0';
	font-size:18px;
	text-align:center;
	line-height:50px;
	color:#CFCFCF;
	}
.side_menu_item{
	width:210px;
	float:left;
	padding-left:10px;
	height:40px;
	color:#fff;
	line-height:40px;
	cursor:pointer;
	text-align:center;
	border:none;
	outline:none;
	margin-bottom:5px;
	background-color:rgba(255,255,255,0.1);
	 transition: all .2s ease-out;
	-webkit-transition: all .2s ease-out;
	-moz-transition: all .2s ease-out;
	-o-transition: all .2s ease-out;
	
	}
.side_menu_item:hover{width:207px;margin-left:3px;background-color:rgba(255, 255, 255, 0.4);text-decoration:none;color:#fff;}	
.counter_mn_focus{width:210px !important;background-color:rgba(255, 255, 255, 0.3);text-decoration:none;color:#fff;}	
.counter_mn_focus:hover{width:210px !important;background-color:rgba(255, 255, 255, 0.3);margin-left:0 ;}
.side_menu_item:focus{width:207;margin-left:1px;background-color:rgba(100, 77, 45, 1);}	
	

.top_button{
	padding:0 10px;
	height:40px;
	float:right;
	margin:0px 8px 0 0;
	border:solid 1px rgba(255,255,255,0.2);
	border-top:solid 0px ;
	border-bottom:solid 0px ;
	text-align:center;
	font-size:15px;
	background-color:rgba(255,255,255,0.1);
	cursor:pointer;
	color:#fff;
	line-height:40px;
	 transition: all .2s ease-out;
	-webkit-transition: all .2s ease-out;
	-moz-transition: all .2s ease-out;
	-o-transition: all .2s ease-out;
	}
.top_button:hover{background-color:rgba(255,255,255,0.2);}		

.center_container{
	margin-top:5px;
	height:auto;
	padding-right:0!important;
	padding-left:0!important;
	float: right !important;
	}
.center_container_count{
	margin-top:5px;
	height:auto;
	padding-right:0!important;
	padding-left:0!important;
	}	
.detail_display{
	padding:1%;
	background-color:rgba(255,255,255,0.1);
	}	
.table_no{width:100%;float:left; height:40px;border:solid 1px rgba(255,255,255,0.1);margin-bottom:3px;}	
.table_no_detail{width:100%;height:60px;margin-bottom:3px;margin-top:10px;}
.table_report{
	width:100%;
	height:62vh;
	float:left;
	border:solid 1px rgba(255,255,255,0.1)
	}	
.table_report_botom_cc{width:100%;height:40px;background-color:rgba(255,255,255,0.1);
float:left;font-family: 'CALIBRI_0';font-size:16px;color:#fff;line-height:40px;}	
.billgenrations_table{
	width:100%;
	float:left;
	}	
.billgenrations_table td{
	text-align:center;
	font-family: 'CALIBRI_0';
	font-size:16px;
	color:#fff;
	background-color: rgba(255,255,255,0.1); 
	border-right:solid 1px rgba(255,255,255,0.1); 
	height:30px;
	}
.ln{border-right:1px solid  rgba(255,255,255,0.2);width:30px;margin-right:20px;}	
.btn_save{
	text-align:center;
	background-color:rgba(255, 126, 0, 0.4);
	border-radius:3px;
	cursor:pointer; transition: all .2s ease-out;
	-webkit-transition: all .2s ease-out;
	-moz-transition: all .2s ease-out;
	-o-transition: all .2s ease-out;}	
.btn_save:hover{background-color:rgba(255, 126, 0, 0.6);}
.menu_catogery_cc{
	width:100%;
	float:left;
	height:40px;
	}
.pading_0{padding-right:0 !important;padding-left:0 !important;}
.tabs_first_menu{
width:100%;
height:60px;
float:left;
}
::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
  
    border-radius: 10px;
}

::-webkit-scrollbar-thumb {
    border-radius: 10px;
  
}

::scrollbar {
    width: 10px;
}

::scrollbar-track {
  
    border-radius: 10px;
}

::scrollbar-thumb {
    border-radius: 10px;
 
}


.back_home_cc_1{width:7%;height:auto;float:right;margin-top:0px;color:#fff;}	
.back_home_cc_1 a{color:#fff;}
.back_home_cc_1 a:hover{color:#666;text-decoration:none;}
.back_home_cc_1 a:focus{color:#666;text-decoration:none;}
