.keys{width:100%;
height:auto;
float:left;padding:5%;}	
	
.keys span, .top span.clear {
	float: left;
	position: relative;
	top: 0;
	cursor: pointer;
	width:30%;
	height:45px;
	background: rgba(78, 94, 104, 0.4);
	border-radius: 3px;
	box-shadow: 0px 4px rgba(0, 0, 0, 0.8);
	  margin: 0 3% 4% 0;
	color: #fff;
	font-size: 15px;
	line-height: 44px;
	text-align: center;
	/* prevent selection of text inside keys */
	user-select: none;
	/* Smoothing out hover and active states using css3 transitions */
	transition: all 0.2s ease;
	-moz-transition: all 0.2s ease;
	-webkit-transition: all 0.2s ease;
	-o-transition: all 0.2s ease;
	-ms-transition: all 0.2s ease;
}
.position_mn_cc li a{background: rgba(78, 94, 104, 0.4)}

/* Remove right margins from operator keys */
/* style different type of keys (operators/evaluate/clear) differently */
.keys span.operator {
	background: #FFF0F5;
	margin-right: 0;
}
.keys span.clear{background: rgba(78, 94, 104, 0.4) !important;color:#fff !important;}
.keys div.eval {
	background: #F5351B !important;
  box-shadow: 0px 4px #AD1A07 ;
	float: left;
  position: relative;
    padding: 5.5%;
  top: 0;
  cursor: pointer;
  width: 80px;
  height: 50px;
  background: white;
  border-radius: 3px;
  box-shadow: 0px 4px rgba(0, 0, 0, 0.8);
  margin: 0 12px 11px 0;
  color: #fff;
  line-height: 50px;
  text-align: center;
  user-select: none;
  transition: all 0.2s ease;
}
.keys div.eval:hover{    background-color: #620B0B !important;color:#fff}

.keys span.clear {
  box-shadow: 0px 4px #000;
	color: #000;
	  clear: inherit;
	    width: 64%;
}
.keys span.clear:hover{   background-color: #620B0B !important;color:#fff}

/* Some hover effects */
.keys span:hover {
	background: #c5103d;
	box-shadow: 0px 4px #570E21;
	color: #fff;
}

.keys span.eval:hover {
	background: #fff;
	box-shadow: 0px 4px #717a33;
	color: #ffffff;
}

.top span.clear:hover {
	  background-color: #620B0B !important;
	box-shadow: 0px 4px #d3545d;
	color: white;
}

/* Simulating "pressed" effect on active state of the keys by removing the box-shadow and moving the keys down a bit */
.keys span:active {
	box-shadow: 0px 0px #6b54d3;
	top: 4px;
}

.keys span.eval:active {
	box-shadow: 0px 0px #717a33;
	top: 4px;
}

.top span.clear:active {
	top: 4px;
	box-shadow: 0px 0px #d3545d;
}

.keys div.eval:active {
	box-shadow: 0px 0px #717a33;
	top: 4px;
}	
	
