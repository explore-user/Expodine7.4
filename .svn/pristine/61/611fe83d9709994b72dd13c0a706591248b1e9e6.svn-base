h2{  margin-top: 8px;}
.form-group{margin-bottom:-15px !important}

#boxscroll {

	overflow: auto;

}
#boxscroll2 {
	padding: 40px;
	height: 120px;
	width: 730px;
	border: 2px solid #F00;
	overflow: auto;
}
#boxscroll3 {
	overflow: hidden;
}
#boxframe {
	position:absolute;
	top:28px;
	left:420px;
	width:400px;
	height:300px;
	overflow:auto;
	border: 2px solid #0F0;
}
#boxscroll4 {
	height: 300px;
	margin-top: 40px;
	background-color: #00FF66;
	font-family: 'CALIBRI_0';
	font-size: 18px;
	padding: 20px;
	color: #006633;
	overflow: auto;
}
.mCSB_container_wrapper > .mCSB_container {padding-right: 4px !important;}
.chosen-container a {height: 30px !important;line-height:30px !important;}
.chosen-container-single .chosen-single div {top: 3px !important;}
.filter_right_search_cc, .filter_drop	.form-control {height: 30px;margin-top: -15px;}
.filtering_cc{height:110px;}
.filter_drop label{font-size:12.5px;  height: 14px;}
.chosen-container{ margin-top: -15px;float: left;}
.filter_drop_contain{width:100%;  margin-top: -11px}
.filter_drop{width:31.7%;height:auto;  margin-bottom: -22px;}
.chosen-container .chosen-results{  border-top: 1px #ccc solid;}
.filter_drop{margin-top:-1px;}
.right_form_cc{   height:auto; float: left;overflow: visible;}
.top{width: 95%; position: absolute; top: 25px;}
.menu{ text-align: right; display: inline-block; width: 70%;}
/*.menu li {display: inline-block; padding: 2px 15px;}*/
.examples{position: relative; width: 100%; margin: 30px 10px;}
.examples ul{text-align: center}
.examples ul li{display: inline-block; padding: 5px 10px;}
.tabs li.current a { background-color: #333;color:#fff;}
.tabs li a{background-color:#693827;  padding: 11px 80px 12px 40px !important;  border-radius: 10px;}.tabs li a:hover{background-color:#333;}
.tabs li{display: inline-block; width: 130px;}
.tabs{  width: 100%; height: 62px;padding-left:0;  min-width: 100% !important;white-space: nowrap;overflow-x: auto;float: left;margin-top: 3px;}
.tab_content > div{padding:2%;}
.right_form_cc { padding: 4px 0 0px 6px;}
.menu_master_left_cc{width:53%}
.menu_master_right_cc {width: 46.5% !important;}
.menu_master_right_cc1 {width: 46.5%;}
#myTab{width:100% !important;padding:0 !important;}
.tab2_content{
	width:100%;
	height:auto;
	float:left;
	}
.tab2_drop_head{
	width:100%;
	height:107px;
	float:left;
	border:1px #ccc solid;
	background-color:rgba(255,255,255,0.8);
	padding:5px 5px 0 5px;
	}
.tab_multidropdown_cc{
	width:100% ;
	height:43px;
	float:left;
	margin-right:5px;
	margin-top:5px;
	}
.chosen-container-multi .chosen-choices li.search-choice{  margin: 3px 0px 3px 2px;padding: 3px 19px 3px 2px;}	
.tab_multidropdown_cc a{display:block;width:15% !important;float:left;margin-top:5px;}
.tab_multidropdown_cc  a:hover{text-decoration:none}
.tab_multidropdown_cc .chosen-container{margin-top:1px;width:85% !important}			
.tab_dropdown_cc{
	width:35%;
	height:50px;
	float:left;
	margin-right:5px;
	}
.tab_dropdown_cc a:hover{text-decoration:none}	
.tab_portiondropdown_cc a:hover{text-decoration:none}	
.tab_rate_cc a:hover{text-decoration:none}	
.tab_portiondropdown_cc{
	width:53%;
	height:50px;
	float:left;
	margin-right:7px;
	}
/*.tab_portiondropdown_cc a{
	  display: block;
  width: 28% !important;
  float: left;
  margin-top: 5px;
	}*/	
.tab_portiondropdown_cc .chosen-container{width:71% !important;}	
.portion_txt{display:block;width:28% !important;float:left;margin-top:5px;}
.tab_rate_cc{
	 margin-right: 9px;
	width:27%;
	height:50px;
	float:left;
	}
.tab_rate_cc a{display:block;width:28% !important;float:left;margin-top:5px;}

.chosen-container-multi .chosen-choices{border-radius:5px !important;}		
.tab_portiondropdown_cc .chosen-search	{display:none}		
.search-choice .search-choice-close{  height: 12px !important;}
.tab_dropdown_cc .chosen-container{margin-top:1px;}
.tab_portiondropdown_cc .chosen-container{margin-top:1px;}
.chosen-container-multi .chosen-choice{height:28px !important;padding-right:8px;}
.chosen-container-multi .chosen-choices li.search-choice .search-choice-close {top: -1px;}
.tab_rate_box{height:31px;width:70%}
.tab_btn_cc{
	width:15%;
	height:50px;
	float:left;
	margin-right:0px;
	}
.tab_sub_btn{width:100%;height:30px;
float:right;background-color:#333;color:#fff;
text-align:center;font-size:14px;border:none;
border-radius:4px;
}
.tab_list_cc{
	width:100%;
	margin-top:5px;
	height:auto;
	min-height:224px;
	background-color:rgba(255,255,255,0.8);
	float:left;
	border:solid 1px #ccc;
	}
.tab_list_cc table{width:99%;margin-left:3px;margin-top:3px;margin-bottom:5px; }	
.tab_list_cc td, th{
		text-align:center;
		border:solid 1px #ccc;
		height:30px;
		}
.tab_list_cc th	{
		background-color:#EDE0C8;
	}
.tab_edt_btn{
	float:left;
	padding:0 10px;
	height:25px;
	float:left;
	margin-left:6px;
	display:block;
	border:solid 1px #ccc;
	}
			
.tab_edt_btn .glyphicon{font-size:18px;}
.tab_dropdown_cc a {display:block;width:60px;float:left;}	
#left_div_scroll {height: 70.7vh;min-height: 501px !important;}
.right_list_cc{min-height: 622px !important;  height: 85.3vh !important;}