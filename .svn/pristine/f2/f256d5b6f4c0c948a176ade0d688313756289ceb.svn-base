  function close_master(){
      
          $('.master_pop_new').hide();
          $(".language_overlay").css("display","none");
  }

  function go_click(mode){
       
    
    if(mode=='DI'){
    
        window.location.replace('table_selection.php');
    }
    
    if(mode=='TA'){
       
           window.location.replace('take_away_.php');
    }
    
     if(mode=='CS'){
        
         window.location.replace('counter_sales.php');
    }
    
    if(mode=='BR'){
         
         $('.master_pop_new').show();
         $(".language_overlay").css("display","block");
    }
    
    if(mode=='TR'){
         
        window.location.replace('troubleshoot.php');
    }
     
}


function go_drawer(){
    
       var ip='all';
       var port='all';
      	var usb='all';		 
			$.ajax({
			type: "POST",
			url: "expodine_machines.php",
			data: "value=cash_drawer_check&ip="+ip+"&port="+port+"&usb="+usb,
                        
			success: function(data){ 
                        $('.alert_error_popup_all_in_one').show();
                                    
                        $('.alert_error_popup_all_in_one').text('Opening Drawer ');
                        $('.alert_error_popup_all_in_one').delay(500).fadeOut('slow');
                        
                        }
                        });
			
        
    }

</script>
