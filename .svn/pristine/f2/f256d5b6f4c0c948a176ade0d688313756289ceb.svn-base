//auto dayclose //
 
localStorage.auto_close='Y';
 
var auto_close_day=$('#auto_close_day').val();

if(auto_close_day=='Y'){ 
    
    setInterval(function() {  
    
        var exp_close_day = $('#exp_close_day').val();
    
                var tdate = new Date();
                var dd = tdate.getDate(); 
                var MM = tdate.getMonth(); 
                var yyyy = tdate.getFullYear(); 
                var xxx = dd+ "-"+( MM+1)+ "-" +yyyy;
                var xxx1 = yyyy+ "-"+( MM+1)+ "-" +dd;
		var from='a';
		var to=xxx;
                
       
    var snd=$('#chkrpts').val();
          
    var chkmail=$('#chkmail').val();
    
    
   var currentdate = new Date(); 
   var time =  currentdate.getHours() + ":" + currentdate.getMinutes() + ":" + currentdate.getSeconds();


    var d = new Date($.now());
    var datetime=d.getFullYear()+"-"+(d.getMonth() + 1)+"-"+d.getDate()+" "+d.getHours()+":"+d.getMinutes()+":"+d.getSeconds();

    
     var data6="set=auto_day_finder";
   
       $.ajax({
        type: "POST",
        url: "load_index.php",
        data: data6,
        success: function(data36)
        { 
  
        var current_date_auto = $.trim(data36);
   
       if((current_date_auto!=exp_close_day) && exp_close_day!='' && exp_close_day!='undefined' &&  localStorage.auto_close=='Y'){
           
       localStorage.auto_close='N';
       
       $('.alert_error_popup_all_in_one').show();
                                    
       $('.alert_error_popup_all_in_one').text('AUTOMATING DAYCLOSE');
            
       var data="set=auto_dayclose&date="+current_date_auto+"&time="+time+"&datetime="+datetime;
   
       $.ajax({
        type: "POST",
        url: "load_index.php",
        data: data,
        success: function(data3)
        { 
            
                                      if($.trim(data3)=='Day close successfull!'){
              
                                       $('#exp_close_day').val(current_date_auto);
                                          
                                        ///dayclose mail///      
                                        $.post("text1.php", {type:snd,from:from,to:to,mail:chkmail},
                                        function(data2)
                                        { 
                                             ///dayclose print///    
					     $.post("print_report_new.php", {type:snd,hidfr:from,hidto:to},
					     function(data3)
					     { 
                                               
                                               //day open on /// 
                                               $.post("load_index.php", {set:'auto_dayopen'},
					       function(data3)
					       { 
                                                   localStorage.auto_close='Y';
                                                   
                                                   window.location.href='dont_delete.php?auto_close=done';
                                                 
            
                                             }); 
                                             
                                                 
                                         }); 
                                         
                                         });
         }else{
             
               localStorage.auto_close='Y';
               $('.alert_error_popup_all_in_one').hide();
               alert($.trim(data3));
               
               location.reload();
               
         }
         
       
        }
       }); 
       
          
       ///db backup dayclose///    
    
                    var data2="set_backup=backup_dayclose&db_select=DATABASE_NAME_REPORT";
