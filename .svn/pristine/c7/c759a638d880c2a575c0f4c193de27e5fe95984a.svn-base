<script>
$("#staff_btn").click(function(){
  $("#staff_btn").addClass('faq_contant_row_btn_act');
  $("#menu_btn").removeClass('faq_contant_row_btn_act');
  $("#common_btn").removeClass('faq_contant_row_btn_act');
  $("#printer_btn").removeClass('faq_contant_row_btn_act');

  $("#staff_box").show();
  $("#menu_box").hide();
  $("#common_box").hide();
  $("#printer_box").hide();

  $("#staff_sub").toggleClass("hgt_auto");
  $("#printer_sub").removeClass("hgt_auto");
  $("#menu_sub").removeClass("hgt_auto");
  $("#master_sub").removeClass("hgt_auto");
  
});

$("#menu_btn").click(function(){
  $("#staff_btn").removeClass('faq_contant_row_btn_act');
  $("#menu_btn").addClass('faq_contant_row_btn_act');
  $("#common_btn").removeClass('faq_contant_row_btn_act');
  $("#printer_btn").removeClass('faq_contant_row_btn_act');

  $("#staff_box").hide();
  $("#menu_box").show();
  $("#common_box").hide();
  $("#printer_box").hide();

  $("#menu_sub").toggleClass("hgt_auto");
  $("#master_sub").removeClass("hgt_auto");
  $("#staff_sub").removeClass("hgt_auto");
  $("#printer_sub").removeClass("hgt_auto");

});

$("#common_btn").click(function(){
  $("#staff_btn").removeClass('faq_contant_row_btn_act');
  $("#menu_btn").removeClass('faq_contant_row_btn_act');
  $("#common_btn").addClass('faq_contant_row_btn_act');
  $("#printer_btn").removeClass('faq_contant_row_btn_act');

  $("#staff_box").hide();
  $("#menu_box").hide();
  $("#common_box").show();
  $("#printer_box").hide();

  $("#master_sub").toggleClass("hgt_auto");
  $("#staff_sub").removeClass("hgt_auto");
  $("#menu_sub").removeClass("hgt_auto");
  $("#printer_sub").removeClass("hgt_auto");

});

$("#printer_btn").click(function(){
$("#staff_btn").removeClass('faq_contant_row_btn_act');
  $("#menu_btn").removeClass('faq_contant_row_btn_act');
  $("#common_btn").removeClass('faq_contant_row_btn_act');
  $("#printer_btn").addClass('faq_contant_row_btn_act');

  $("#staff_box").hide();
  $("#menu_box").hide();
  $("#common_box").hide();
  $("#printer_box").show();

  $("#printer_sub").toggleClass("hgt_auto");
  $("#master_sub").removeClass("hgt_auto");
  $("#staff_sub").removeClass("hgt_auto");
  $("#menu_sub").removeClass("hgt_auto");


});


jQuery(window).scroll(function() {
     var scroll =   jQuery(window).scrollTop();

        if (scroll >= 200) {
               jQuery(".scroll_fix").addClass("scroll-to-fixed-fixed");
          } else {
               jQuery(".scroll_fix").removeClass("scroll-to-fixed-fixed");
         }

         if (scroll >= 200) {
               jQuery(".scroll_fix_top").addClass("scroll-header-fixed-fixed");
          } else {
               jQuery(".scroll_fix_top").removeClass("scroll-header-fixed-fixed");
         }

});




var btn = $('#button');

$(window).scroll(function() {
  if ($(window).scrollTop() > 300) {
    btn.addClass('show');
  } else {
    btn.removeClass('show');
  }
});

btn.on('click', function(e) {
  e.preventDefault();
  $('html, body').animate({scrollTop:0}, '300');
});

</script>

</body>
</html>
