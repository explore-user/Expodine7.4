	width: auto;
	height: 70px;
	float: left;
	margin-left: 30px;
    margin-top: 30px;
}
.order_split_select_text{
	width: auto;
	height: auto;
	float: left;
	color: #7b7b7b;
	font-size: 23px;
	text-transform: uppercase;
}

.order_split_checkbox {
    display: block;
    position: relative;
    padding-left: 35px;
    margin-bottom: 12px;
    cursor: pointer;
    font-size: 20px;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
	line-height: 29px;
}

/* Hide the browser's default checkbox */
.order_split_checkbox input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
}

/* Create a custom checkbox */
.checkmark {
    position: absolute;
    top: 4px;
    left: 0;
    height: 25px;
    width: 25px;
    background-color: #dadada;
}

/* On mouse-over, add a grey background color */
.order_split_checkbox:hover input ~ .checkmark {
    background-color: #ccc;
}

/* When the checkbox is checked, add a blue background */
.order_split_checkbox input:checked ~ .checkmark {
    background-color: #e45d03;
}

/* Create the checkmark/indicator (hidden when not checked) */
.checkmark:after {
    content: "";
    position: absolute;
    display: none;
}

/* Show the checkmark when checked */
.order_split_checkbox input:checked ~ .checkmark:after {
    display: block;
}

/* Style the checkmark/indicator */
.order_split_checkbox .checkmark:after {
        left: 9px;
    top: 2px;
    width: 8px;
    height: 16px;
    border: solid white;
    border-width: 0 3px 3px 0;
    -webkit-transform: rotate(45deg);
    -ms-transform: rotate(45deg);
    transform: rotate(45deg);
}
