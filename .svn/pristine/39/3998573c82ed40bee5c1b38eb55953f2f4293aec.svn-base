.cb-enable, .cb-disable, .cb-enable span, .cb-disable span { /*background: url(../img/switch.png) repeat-x;*/ display: block; float: left;border-radius: 5px;  }
	.cb-enable span, .cb-disable span { line-height: 40px; display: block; background-repeat: no-repeat; font-weight: bold;   color: #000;font-size: 13.5px;text-align:center}
	.cb-enable span {width:102%; background-position: left -90px;  
	-moz-box-shadow: 0px 4px 7px #000;
  -webkit-box-shadow: 0px 4px 7px #000;
  box-shadow: 0px 4px 7px #000; }
	.cb-disable span { background-position: right -180px;text-align:center;width:100%;float:left; }
	.cb-disable.selected { background-position: 0 -30px; border: 1px solid rgba(255,255,255,0.2);height:40px;margin-left: 5px;
	  -moz-box-shadow: inset 0px 0px 8px #000000 !important;
  -webkit-box-shadow: inset 0px 0px 8px #000000 !important;
  box-shadow: inset 0px 0px 8px #000000 !important;
 /* background-color: #7C4300 !important;*/
     background-color: #8B0B00 !important;}
	.cb-disable.selected span { background-position: right -210px; color: #fff;border: Solid 0px #000;}
	.cb-enable.selected { background-position: 0 -60px;  border: Solid 0px #000;  margin-right: 4px;
	  }
	.cb-enable.selected span { background-position: left -150px; color: #fff; 
	 margin-left: 0px;border: 1px solid rgba(255,255,255,0.2);height:40px;  -moz-box-shadow: inset 0px 0px 8px #000000 !important;
  -webkit-box-shadow: inset 0px 0px 8px #000000 !important;
  box-shadow: inset 0px 0px 8px #000000 !important;
 background-color: #8B0B00 !important;}
	.switch label {width:48%; cursor: pointer;background-color:#fff;height:40px;  border: Solid 1px #000;-moz-box-shadow: -1px -1px 5px #000000;
-webkit-box-shadow: -1px -1px 5px #000000;
box-shadow: -1px -1px 5px #000000; }	

