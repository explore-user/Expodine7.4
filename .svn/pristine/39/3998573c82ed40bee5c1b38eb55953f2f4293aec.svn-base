.table_floor_select_btn{
	/*width:120px;*/
	    width: auto;
    padding: 0 1%;
	height:37px;
	display:inline-block;
	background-image: -webkit-linear-gradient(#FCAD35, #C5912A);
    background-image: -moz-linear-gradient(#FCAD35, #C5912A);
    background-image: -o-linear-gradient(#FCAD35, #C5912A);
    background-image: linear-gradient(#FCAD35, #C5912A);
	text-align:center;
	line-height:30px;
	 margin-top: 9px;
	color:#000;
	margin-right:1%;
    border-radius: 3px;
    position: relative;
	top:-5px;
	}
.table_floor_select_btn a{color:#000 !important;font-size:16px;text-decoration:none;display:block;cursor:pointer;}	
.table_floor_select_btn a:hover{text-decoration:none}
.table_floor_select_btn_act{
	background-image: -webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #EF3F00), color-stop(100%, #892A08)) !important;
    background-image: -webkit-linear-gradient(#EF3F00, #892A08) !important;
    background-image: -moz-linear-gradient(#EF3F00, #892A08) !important;
    background-image: -o-linear-gradient(#EF3F00, #892A08) !important;
    background-image: linear-gradient(#EF3F00, #892A08) !important;
	border-bottom: 3px solid #fff;
	color:#fff;
	}
.table_floor_select_btn_act::before{
	content: "";	
    display: block;
    width: 10px;
    height: 10px;
    color: transparent;
    border: 10px solid black;
    border-color: transparent transparent white;
    margin-top: 35px;
    position: absolute;
    left:39%;
	float:left;
	-ms-transform: rotate(180deg); /* IE 9 */
    -webkit-transform: rotate(180deg); /* Safari */
    transform: rotate(180deg);
	}		
.table_floor_select_btn_act a{color:#fff !important;font-size:13px;text-decoration:none;display:block;text-align:center}


.change_table_btn{
	width:130px;
	height:40px;
	float:right;
	background-color:#ccc;
	margin-right: 16px;
	background-image: linear-gradient(bottom, rgb(90, 11, 0) 0%, rgb(193, 24, 0) 100%);
	background-image: -o-linear-gradient(bottom, rgb(90, 11, 0) 0%, rgb(193, 24, 0) 100%);
	background-image: -moz-linear-gradient(bottom, rgb(90, 11, 0) 0%, rgb(193, 24, 0) 100%);
	background-image: -webkit-linear-gradient(bottom, rgb(90, 11, 0) 0%, rgb(193, 24, 0) 100%);
	background-image: -ms-linear-gradient(bottom, rgb(90, 11, 0) 0%, rgb(193, 24, 0) 100%);
	background-image: -webkit-gradient( linear, left bottom, left top, color-stop(0, rgb(90, 11, 0)), color-stop(1, rgb(193, 24, 0)) );
	border-radius:5px;
	text-align: center;
	font-size: 14px;
	line-height: 40px;
	margin-top: -20px;
	color: #fff;
	letter-spacing: 0.5px;
	font-family: 'CALIBRI_0' !important;
	}	
		
