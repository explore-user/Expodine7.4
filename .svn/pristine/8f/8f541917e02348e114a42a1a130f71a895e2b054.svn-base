    function go_lock(){
    
    
         var data1234="set=check_otp_entered";
           $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data1234,
            success: function(data) {
                
                if($('#code_change').val()==$.trim(data)){
                    
                alert('WELCOME TO ADMIN SETTINGS SECTION');
                
                window.location.href='admin_settings.php';
                
             }else{
            
                  alert('INVALID OTP'); 
                  $('#code_change').val('');
                  $('#code_change').focus();
             }
        
         }
        });
    
    
    }
   
   function ask_admin(){
       
         $('#cus_div').show();
         $('#admin_div').hide();
         $('#code_change').focus();
       
       var data1234="set=otp_reset&mode=admin";
           $.ajax({
            type: "POST",
            url: "load_index.php",
            data: data1234,
            success: function(data) {
                $('#code_change').val('');
                 $('#code_change').focus();
                
            }
        });
        
       $('#code_change').focus();
    }
   
   
   
   function backup_admin(){
       
       $('#add_stock_pop22').hide(500);
       
       $("#btn_export").click();
       
    }
    
