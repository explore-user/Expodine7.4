      $('.dayalready_closed_popup_text').html('Day is Reverting');
            
      var data123="set=dayrevertok&staff_reverted="+dt[1];
      
       $.ajax({
            type: "POST",
            url: "troubleshoot.php",
            data: data123,
            success: function(data) {
               
             var data1=$.trim(data);
            
            $('.dayalready_closed_popup_text').html(data1);
            $("#dayrevertpopup").fadeOut(4000); 
            
           if($('#revert_check').val()=='revert_ok'){
               
               $('#revert_check').val('');
               window.location.href='index.php';
           }
        }
        });
        } else{
        
                        $("#pin_error").css("display","block");
			$("#pin_error").text("No Permission To Revert");
			$("#pin_error").delay(2000).fadeOut('slow');
                        $("#pin").val('');
                        $('#pin').focus();
    }
        } else{
        
                        $("#pin_error").css("display","block");
			$("#pin_error").text("Enter Valid Pin");
			$("#pin_error").delay(2000).fadeOut('slow');
                        $("#pin").val('');
                        $('#pin').focus();
    }
    
        });
       } else{
                        $("#pin_error").css("display","block");
			$("#pin_error").text("Enter Pin");
			$("#pin_error").delay(2000).fadeOut('slow');
                        $("#pin").val('');
                        $('#pin').focus();
        
    }
     
        
    });    
    
    
      $('.pin_close').click(function(){
           $('.kotcancel_reason_popup_new').hide();
           $(".change_pass_overlay").hide();
      });
    
      $('.pin_close_reset').click(function(){
           $('.reset_popup').hide();
           $(".change_pass_overlay").hide();
      });
      
      
       $('.pin_close_reset_acc').click(function(){
           $('.reset_acc_popup').hide();
           $(".change_pass_overlay").hide();
      });
      
      
       $('.pin_close_reset_inv').click(function(){
           $('.reset_inv_popup').hide();
           $(".change_pass_overlay").hide();
      });
    
    
 document.onkeydown= function(ev){
   
  var keyCode = ev.keyCode || ev.which;   
    if (keyCode == 13) { 
        if($('.kotcancel_reason_popup_new').css('display') == 'block'){
      $('.submit_day_revert').click();
   
       return false;
    }else if($('.reset_popup').css('display') == 'block'){
         $('.submit_bill_reset').click();
           return false;
    }
    else if($('.reset_acc_popup').css('display') == 'block'){
         $('.submit_acc_reset').click();
           return false;
    }
     else if($('.reset_inv_popup').css('display') == 'block'){
        $('.submit_inv_reset').click();
           return false;
    }
    
    
  }
    
  
} 
    
    
  $('.calculator_settle').click( function(event) {
          
	    event.stopImmediatePropagation();
                
            if($('.kotcancel_reason_popup_new').css('display') == 'block'){
                  
                $('#focusedtext').val('pin');
                
             }else if($('.reset_popup').css('display') == 'block'){
                 
                 $('#focusedtext').val('pin_reset');
            }
            else if($('.reset_acc_popup').css('display') == 'block'){
                 
                 $('#focusedtext').val('pin_reset_acc');
            }
             else if($('.reset_inv_popup').css('display') == 'block'){
                 
                 $('#focusedtext').val('pin_reset_inv');
            }
            
                
		var focused=$('#focusedtext').val();
               
		var calval=($(this).text());
		
		var org=$('#'+focused).val();
			if(calval>=0)
			{
                            if(org.length < 4){
				if(org==0)
				{
					 $('#'+focused).val(calval);
				}else if(org>0)
				{
					$('#'+focused).val(org+calval);
				  
				}else if(org<0)
				{
					$('#'+focused).val(org+calval);
				}
                            }
			}else if(calval=="Clear")
			{
				$('#'+focused).val("");
			}else if(calval==".")
			{
				$('#'+focused).val(org+".");
			}
			$('#'+focused).change();
		$('#'+focused).focus();
	
 });
        
  $("#btn_export").click(function(){
           
            $('#ipping').show();
            $('#ipping').html('DB BACKUP DONE');
            $("#ipping").delay(5000).fadeOut(5000); 
            
       var data="set_backup=backup_dayclose";
     
        $.ajax({
        type: "POST",
        url: "export/export.php",
        data:data,
        success: function(data1)
        {
            
        }
    });      
        
      });     
        
    </script>


