            <?php
           
            $two_days_ago = strtotime("-2 days");
            $manual='NOT FOUND'; $arc_bkp='NOT FOUND';  $fulldb='NOT FOUND'; 

            
            $locationdb="C:\backup_new";
            $sql_db  =  $database->mysqlQuery("select be_dbbackuplocation  from tbl_branchmaster"); 
            $num_db   = $database->mysqlNumRows($sql_db);
            if($num_db){
            $result_dbloc  = $database->mysqlFetchArray($sql_db);
            
              $locationdb= $result_dbloc['be_dbbackuplocation'];										  
            }
            
            if (is_dir($locationdb)) {
            $files = scandir($locationdb);
            foreach ($files as $file) {
            if ($file == '.' || $file == '..') continue;
                $filepath = $locationdb .'\\'. $file;
                if (is_file($filepath)) {
                if (filemtime($filepath) >= $two_days_ago) {
                $manual='FOUND';
                break;
            } } } }

            
            $location_fullarc='..\util\Dayclose_DB_Backup\Archieve_tables';
            
            if (is_dir($location_fullarc)) {
            $files = scandir($location_fullarc);
            foreach ($files as $file) {
            if ($file == '.' || $file == '..') continue;
                $filepath = $location_fullarc .'\\'. $file;
                if (is_file($filepath)) {
                if (filemtime($filepath) >= $two_days_ago) {
                $arc_bkp='FOUND';
                break;
            } } } }
            
            
            $location_fulldb='..\util\Dayclose_DB_Backup\Full_db_normal';
            
            if (is_dir($location_fulldb)) { 
            $files = scandir($location_fulldb);
            foreach ($files as $file) { 
            if ($file == '.' || $file == '..') continue;
                $filepath = $location_fulldb .'\\'. $file;
                
                if (is_file($filepath)) { 
                if (filemtime($filepath) >= $two_days_ago) {
                $fulldb='FOUND';
                break;
            } } } }
            
            ?>
            
            <style>@keyframes blink { 20% { opacity: 0.6; } } </style>

            <input readonly style="<?php if($fulldb!='FOUND' || $arc_bkp!='FOUND' || $manual!='FOUND'){ ?> color:red; animation: blink 1s infinite; <?php }else{ ?> color:black ; <?php } ?> background: white;border-radius: 5px;border: solid 1px black;padding:10px;
            width:100%;float:left;margin: 0%;  font-size: 63%; margin-left: 0%;margin-top: -13px;font-weight: bold"
            class="" value="DB BACKUP IN LAST 2 DAYS  &nbsp; : &nbsp; MANUAL - <?=$manual?>  &nbsp; | &nbsp;  FULL DB - <?=$fulldb?>  &nbsp; | &nbsp; ARC DB - <?=$arc_bkp?> "  /> 
   
            
            <?php if($fulldb!='FOUND' || $arc_bkp!='FOUND' || $manual!='FOUND'){
                
                
                 echo '<script type="text/javascript">';
                 echo 'jQuery(function($) { ';
                 echo '$("#dayrevertpopup").show();';
                 echo '$(".dayalready_closed_popup_text").html("KINDLY CHECK OUT DB BACKUP SECTION");';
                 echo '$("#dayrevertpopup").fadeOut(5000);';
                 echo '});';
                 echo '</script>';
                
                
                
            } ?>
            
            
            
            
            
            
            
