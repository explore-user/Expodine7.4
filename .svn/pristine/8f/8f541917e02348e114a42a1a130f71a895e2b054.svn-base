 <script>
                    
                    
                    
                    
       $("#log_btn_new").click(function() {
           
           window.location.href='log_list_page.php';
           
       });            
                    
            $("#reprint_all").click(function() {
               
                var bill_reprintno=$("#bill_reprintno").val();
                var db_name=$('#db_name').val();
                
                if(bill_reprintno!=''){
                                                                           
                                                                    var dataString = 'bill_reprintno='+bill_reprintno+"&db_name="+db_name;
                                                                    $.ajax({
                                                                    type: "POST",
                                                                    url: "print_details.php",
                                                                    data: dataString,
                                                                    beforeSend: function() {
                                                                    $('#ipping').show();
                                                                    $('#ipping').text('REPRINTING');
                                                                    
                                                                    },  
  

                                                                        success: function(data) { 
                                                                          
                                                                           $('#ipping').show();
                                                                           $('#ipping').html(data);
                                                                           $('#ipping').fadeOut(3000).slow();
                                                                           $("#bill_reprintno").val('');
                                                                        }
                                                                    });
                                                                    
                                                                }else{
                                                                    
                                                                     $("#bill_reprintno").focus();
                                                                     $('#ipping').show();
                                                                     $('#ipping').html('ENTER BILLNO');
                                                                     $('#ipping').fadeOut(3000).slow();
                                                                     
                                                                     
                                                                }
           });                                                          
                                                                    
                                                                    
          $("#sendiptest").click(function() {
                                                                        
                                                                    var ipvalue=$("#iptest").val();
                                                                       
                                                                    if(ipvalue!=''){
                                                                           
                                                                    var dataString = 'ipvalue='+ipvalue;
                                                                    $.ajax({
                                                                        type: "POST",
                                                                        url: "load_pingip.php",
                                                                        data: dataString,
                                                                        beforeSend: function() {
                                                                    $('#ipping').show();
                                                                    $('#ipping').text('Please Wait...');
                                                                    
                                                                             },  
  

                                                                        success: function(data) {
                                                                          
                                                                           $('#ipping').show();
                                                                            $('#ipping').html(data);
                                                                           $('#ipping').fadeOut(3000).slow();
                                                                        }
                                                                    });
                                                                }else{
                                                                     $("#iptest").focus();
                                                                     $('#ipping').show();
                                                                     $('#ipping').html('ENTER IP ADDRESS');
                                                                     $('#ipping').fadeOut(3000).slow();
                                                                     
                                                                     
                                                                }

                                                                          
                                                                            });
