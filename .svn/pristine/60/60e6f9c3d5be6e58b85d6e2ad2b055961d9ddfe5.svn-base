#preview{
	position:absolute;
	border:1px solid #ccc;
	background:#ffffff;
	padding:5px;
	display:none;
	color:#fff;
overflow:hidden;
width:180px;
height:130px;
padding-bottom:5px;
z-index:99999;
	
	}
#preview img{width:100%;}	



.styleall{
display:block !important; /* or inline-block */
    width: auto !important; padding: 8px 5px 8px 40px !important; text-align:center;    
    background:url(../images/upload.png) no-repeat !important; color:#000000 !important;
	border:solid 1px #ccc;
float:left;
	cursor:pointer !important;
	  background-size: contain !important;
	  -webkit-background-size: contain !important;
	    -moz-background-size: contain !important;
		-o-background-size: contain !important;
		  /*margin: 5px 0 -8px 0 !important;*/

}
.styleall:hover {opacity:0.8; }
